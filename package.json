{
  "name": "personas-desktop",
  "version": "0.1.0-1",
  "private": true,
  "type": "module",
  "description": "Local-first desktop app for building, orchestrating, and monitoring AI agent personas — encrypted credentials, visual pipelines, real-time observability.",
  "author": "Personas contributors",
  "license": "MIT",
  "homepage": "https://github.com/xkazm04/personas#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/xkazm04/personas.git"
  },
  "bugs": {
    "url": "https://github.com/xkazm04/personas/issues"
  },
  "keywords": [
    "tauri",
    "desktop",
    "ai-agents",
    "local-first",
    "personas",
    "automation"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "node scripts/run-codegen.mjs predev",
    "dev": "vite",
    "prebuild": "node scripts/run-codegen.mjs prebuild",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check:dead": "knip",
    "check:dead:files": "knip --include files",
    "check:i18n": "node scripts/i18n/check-coverage.mjs",
    "check:i18n-dead": "node scripts/i18n/find-unused-i18n-keys.mjs",
    "check:error-registry": "node scripts/i18n/check-error-registry-parity.mjs",
    "check:contracts": "node scripts/check-command-contract.mjs && node scripts/check-event-registry.mjs",
    "check:tiers": "node scripts/check-tiers.mjs",
    "check:tauri-configs": "node scripts/check-tauri-configs.mjs",
    "gen:catalog": "node scripts/docs/gen-shared-catalog.mjs",
    "check:catalog": "node scripts/docs/gen-shared-catalog.mjs --check",
    "check": "npm run check:contracts && npm run check:tiers && npm run check:tauri-configs && npm run check:catalog && tsc --noEmit && eslint src/",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:playwright": "playwright test --config=playwright.config.ts",
    "test:playwright:companion": "playwright test --config=playwright.config.ts athena-conversation",
    "test:playwright:guidance": "playwright test --config=playwright.config.ts athena-guided-walkthrough",
    "test:playwright:tour": "playwright test --config=playwright.config.ts getting-started-tour",
    "test:playwright:tours": "playwright test --config=playwright.config.ts tours-explore",
    "test:tours:fresh": "node scripts/test/run-tours-fresh.mjs",
    "test:watch": "vitest",
    "test:e2e:cli": "vitest run --config vitest.e2e.config.ts",
    "test:integration:cli": "vitest run --config vitest.integration.config.ts",
    "test:cli": "vitest run --config vitest.cli.config.ts",
    "tauri": "tauri",
    "analyze": "ANALYZE=true vite build",
    "check:budget": "node scripts/check-bundle-budget.mjs",
    "check:assets": "node scripts/optimize-assets.mjs --dry-run",
    "check:themes": "node scripts/check-themes.mjs",
    "audit:security": "bash scripts/security-audit.sh",
    "clean:rust": "cd src-tauri && cargo clean",
    "clean:ort": "node scripts/clean-ort.mjs",
    "cache:report": "node scripts/cache-budget.mjs --report",
    "clean:cache": "node scripts/cache-budget.mjs --enforce",
    "clean:worktrees": "node scripts/worktree-gc.mjs",
    "build:starter": "VITE_APP_TIER=starter npm run build",
    "build:team": "VITE_APP_TIER=team npm run build",
    "build:builder": "VITE_APP_TIER=builder npm run build",
    "ensure:ort-cache": "node scripts/ensure-ort-cache.mjs",
    "pretauri:build": "node scripts/ensure-ort-cache.mjs",
    "pretauri:build:stable": "node scripts/ensure-ort-cache.mjs",
    "pretauri:dev": "node scripts/ensure-ort-cache.mjs",
    "pretauri:dev:stable": "node scripts/ensure-ort-cache.mjs",
    "pretauri:dev:test:full": "node scripts/ensure-ort-cache.mjs",
    "tauri:build": "tauri build",
    "tauri:build:lite": "tauri build --config src-tauri/tauri.lite.conf.json",
    "tauri:build:stable": "tauri build --config src-tauri/tauri.stable.conf.json",
    "tauri:dev": "tauri dev",
    "tauri:dev:lite": "tauri dev --config src-tauri/tauri.lite.conf.json",
    "tauri:dev:stable": "tauri dev --config src-tauri/tauri.stable.conf.json",
    "tauri:dev:test": "node scripts/dev/tauri-dev-test.mjs",
    "tauri:dev:test:full": "tauri dev -- --features test-automation",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.19",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/react": "^10.52.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/three": "^0.184.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.1",
    "dompurify": "^3.4.2",
    "framer-motion": "^12.38.0",
    "highlight.js": "11.11.1",
    "immer": "10.2.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
