{
  "name": "personas-desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "node scripts/generate-command-names.mjs",
    "dev": "vite",
    "prebuild": "node scripts/generate-command-names.mjs && node scripts/generate-template-checksums.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit && eslint src/",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:cli": "vitest run --config vitest.e2e.config.ts",
    "test:integration:cli": "vitest run --config vitest.integration.config.ts",
    "tauri": "tauri",
    "analyze": "ANALYZE=true vite build",
    "check:budget": "node scripts/check-bundle-budget.mjs",
    "check:assets": "node scripts/optimize-assets.mjs --dry-run",
    "audit:security": "bash scripts/security-audit.sh",
    "build:starter": "VITE_APP_TIER=starter npm run build",
    "build:team": "VITE_APP_TIER=team npm run build",
    "build:builder": "VITE_APP_TIER=builder npm run build",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.19",
    "@sentry/react": "^10.45.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xyflow/react": "^12.10.1",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
