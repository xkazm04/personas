+  test("renders a long US human date (Month Day, Year)", () => {
+    // 2026-05-26 — construct via explicit Y/M/D to avoid TZ-parse drift.
+    const d = new Date(2026, 4, 26);
+    expect(firm.dateFormat(d)).toBe("May 26, 2026");
+  });
+
+  test("spells the month in full and has no zero-padded day", () => {
+    const d = new Date(2026, 0, 4); // January 4
+    expect(firm.dateFormat(d)).toBe("January 4, 2026");
+  });
+
+  test("renders December correctly (year boundary)", () => {
+    const d = new Date(2025, 11, 31);
+    expect(firm.dateFormat(d)).toBe("December 31, 2025");
+  });
+
+  test("is a pure function — same date yields the same string", () => {
+    const d = new Date(2026, 6, 15);
+    expect(firm.dateFormat(d)).toBe(firm.dateFormat(new Date(2026, 6, 15)));
+  });
+});
