+import { describe, expect, test } from "vitest";
+import {
+  formatCurrency,
+  formatLegalUsd,
+  formatAiCostUsd,
+  formatSignedCurrency,
+  formatNumber,
+  formatPercent,
+} from "./format";
+
+// U+2212 MINUS SIGN — formatSignedCurrency deliberately uses the typographic
+// minus, not the ASCII hyphen-minus (U+002D). Demand letters render this.
+const MINUS = "−";
+
+describe("formatCurrency", () => {
+  test("with decimals (default) renders two fraction digits", () => {
+    expect(formatCurrency(1234.5)).toBe("$1,234.50");
+    expect(formatCurrency(1234.5, true)).toBe("$1,234.50");
+  });
+
+  test("without decimals renders whole dollars", () => {
+    expect(formatCurrency(1234.4, false)).toBe("$1,234");
+    expect(formatCurrency(1234.6, false)).toBe("$1,235");
+  });
+
+  test("zero with decimals reads as $0.00 (not a bug-looking $0)", () => {
+    expect(formatCurrency(0)).toBe("$0.00");
+  });
+});
+
+describe("formatLegalUsd — legal-damages context", () => {
+  test("always whole dollars, grouped, no cents", () => {
+    expect(formatLegalUsd(187000)).toBe("$187,000");
+    expect(formatLegalUsd(3750000)).toBe("$3,750,000");
+  });
+
+  test("rounds fractional cents away (specials/demands are whole)", () => {
+    expect(formatLegalUsd(8500.49)).toBe("$8,500");
+    expect(formatLegalUsd(8500.5)).toBe("$8,501");
+  });
+
+  test("zero damages render as $0, never with cents", () => {
+    expect(formatLegalUsd(0)).toBe("$0");
+  });
+});
+
+describe("formatAiCostUsd — AI-cost context", () => {
+  test("always three decimals so a sub-cent cost never reads as $0", () => {
+    expect(formatAiCostUsd(0)).toBe("$0.000");
+    expect(formatAiCostUsd(0.004)).toBe("$0.004");
+    expect(formatAiCostUsd(0.012)).toBe("$0.012");
+  });
+
+  test("retains three decimals for larger cumulative costs", () => {
+    expect(formatAiCostUsd(1.5)).toBe("$1.500");
+  });
+});
+
+describe("context-separation contract (CULTURE.md invariant)", () => {
+  test("legal and AI-cost contexts format the same value differently", () => {
+    // A demand must not show fragile precision; a cost must not read as $0.
+    expect(formatLegalUsd(0.004)).toBe("$0");
+    expect(formatAiCostUsd(0.004)).toBe("$0.004");
+    expect(formatLegalUsd(187000)).toBe("$187,000");
+    expect(formatAiCostUsd(187000)).toBe("$187,000.000");
+  });
+});
+
+describe("formatSignedCurrency", () => {
+  test("positive values get a leading + and two decimals", () => {
+    expect(formatSignedCurrency(100)).toBe("+$100.00");
+  });
+
+  test("negative values use the typographic minus (U+2212), not a hyphen", () => {
+    expect(formatSignedCurrency(-100)).toBe(`${MINUS}$100.00`);
+    expect(formatSignedCurrency(-100).charCodeAt(0)).toBe(0x2212);
+    expect(formatSignedCurrency(-100).startsWith("-")).toBe(false);
+  });
+
+  test("zero is unsigned", () => {
+    expect(formatSignedCurrency(0)).toBe("$0.00");
+  });
+
+  test("absolute value is formatted (sign carried separately, no double minus)", () => {
+    const out = formatSignedCurrency(-1234.5);
+    expect(out).toBe(`${MINUS}$1,234.50`);
+    expect(out.split(MINUS).length - 1).toBe(1);
+  });
+});
+
+describe("formatNumber", () => {
+  test("groups thousands with no currency symbol", () => {
+    expect(formatNumber(1234567)).toBe("1,234,567");
+    expect(formatNumber(0)).toBe("0");
+  });
+});
+
+describe("formatPercent", () => {
+  test("defaults to zero decimals and rounds", () => {
+    expect(formatPercent(33)).toBe("33%");
+    expect(formatPercent(33.7)).toBe("34%");
+  });
+
+  test("honours an explicit decimals argument", () => {
+    expect(formatPercent(33.33, 1)).toBe("33.3%");
+    expect(formatPercent(100, 2)).toBe("100.00%");
+  });
+
+  test("handles negative percentages", () => {
+    expect(formatPercent(-5, 1)).toBe("-5.0%");
+  });
+});
