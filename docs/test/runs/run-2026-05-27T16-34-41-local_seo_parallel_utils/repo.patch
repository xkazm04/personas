new file mode 100644
index 0000000..d52c492
--- /dev/null
+++ b/src/lib/num.test.ts
@@ -0,0 +1,52 @@
+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { clamp, roundTo } from "./num";
+
+test("clamp returns value when within range", () => {
+  assert.equal(clamp(5, 0, 10), 5);
+});
+
+test("clamp snaps to inclusive bounds", () => {
+  assert.equal(clamp(-3, 0, 10), 0);
+  assert.equal(clamp(99, 0, 10), 10);
+  assert.equal(clamp(0, 0, 10), 0);
+  assert.equal(clamp(10, 0, 10), 10);
+});
+
+test("clamp snaps ±Infinity value to a bound", () => {
+  assert.equal(clamp(Infinity, 0, 10), 10);
+  assert.equal(clamp(-Infinity, 0, 10), 0);
+});
+
+test("clamp propagates NaN value", () => {
+  assert.ok(Number.isNaN(clamp(NaN, 0, 10)));
+});
+
+test("clamp throws RangeError on min > max", () => {
+  assert.throws(() => clamp(5, 10, 0), RangeError);
+});
+
+test("clamp throws RangeError on non-finite bounds", () => {
+  assert.throws(() => clamp(5, NaN, 10), RangeError);
+  assert.throws(() => clamp(5, 0, Infinity), RangeError);
+});
+
+test("roundTo beats binary-float error", () => {
+  assert.equal(roundTo(1.005, 2), 1.01);
+  assert.equal(roundTo(2.345, 2), 2.35);
+});
+
+test("roundTo handles zero decimals and rounding direction", () => {
+  assert.equal(roundTo(2.5, 0), 3);
+  assert.equal(roundTo(1234.567, 1), 1234.6);
+});
+
+test("roundTo returns non-finite value unchanged", () => {
+  assert.ok(Number.isNaN(roundTo(NaN, 2)));
+  assert.equal(roundTo(Infinity, 2), Infinity);
+});
+
+test("roundTo treats negative/NaN decimals as 0", () => {
+  assert.equal(roundTo(3.7, -1), 4);
+  assert.equal(roundTo(3.7, NaN), 4);
+});
diff --git a/src/lib/num.ts b/src/lib/num.ts
new file mode 100644
index 0000000..2797fe9
--- /dev/null
+++ b/src/lib/num.ts
@@ -0,0 +1,35 @@
+/**
+ * Constrain `value` to the inclusive range [min, max].
+ *
+ * - `±Infinity` value snaps to the nearer bound.
+ * - `NaN` value propagates as `NaN` (caller decides what to do with it).
+ * - Throws `RangeError` if a bound is non-finite or if `min > max`, since an
+ *   ill-defined range is a programmer error, not a value to silently clamp.
+ */
+export function clamp(value: number, min: number, max: number): number {
+  if (!Number.isFinite(min) || !Number.isFinite(max)) {
+    throw new RangeError(`clamp: bounds must be finite, got [${min}, ${max}]`);
+  }
+  if (min > max) {
+    throw new RangeError(`clamp: min (${min}) must be <= max (${max})`);
+  }
+  if (Number.isNaN(value)) return NaN;
+  return Math.min(Math.max(value, min), max);
+}
+
+/**
+ * Round `value` to `decimals` places, dodging binary-float error.
+ *
+ * Naive `Math.round(value * 10**d) / 10**d` mis-rounds cases like 1.005 → 1.00
+ * because 1.005 is not exactly representable. Re-parsing through exponential
+ * notation rounds on the decimal string instead, so `roundTo(1.005, 2) === 1.01`.
+ *
+ * - Non-finite `value` (NaN/±Infinity) is returned unchanged.
+ * - Non-finite or negative `decimals` is treated as 0.
+ */
+export function roundTo(value: number, decimals: number): number {
+  if (!Number.isFinite(value)) return value;
+  const d = Number.isFinite(decimals) && decimals > 0 ? Math.floor(decimals) : 0;
+  const shifted = Number(`${value}e${d}`);
+  return Number(`${Math.round(shifted)}e-${d}`);
+}
