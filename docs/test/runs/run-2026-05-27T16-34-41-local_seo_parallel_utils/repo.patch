+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { slugify } from "./slug";
+
+test("slugify lowercases and hyphenates words", () => {
+  assert.equal(slugify("Hello World"), "hello-world");
+});
+
+test("slugify collapses runs of non-alphanumerics into a single hyphen", () => {
+  assert.equal(slugify("a   b___c!!!d"), "a-b-c-d");
+});
+
+test("slugify trims and strips leading/trailing separators", () => {
+  assert.equal(slugify("  --Hello, World!--  "), "hello-world");
+});
+
+test("slugify preserves digits", () => {
+  assert.equal(slugify("Top 10 SEO Tips"), "top-10-seo-tips");
+});
+
+test("slugify returns empty string for empty or separator-only input", () => {
+  assert.equal(slugify(""), "");
+  assert.equal(slugify("   "), "");
+  assert.equal(slugify("---!!!---"), "");
+});
+
+test("slugify is idempotent", () => {
+  const once = slugify("Already a slug? Maybe!");
+  assert.equal(slugify(once), once);
+});
+
+test("slugify is ASCII-only — non-Latin chars become separators (by design)", () => {
+  assert.equal(slugify("Café déjà vu"), "caf-d-j-vu");
+});
diff --git a/src/lib/slug.ts b/src/lib/slug.ts
new file mode 100644
index 0000000..231ca1e
--- /dev/null
+++ b/src/lib/slug.ts
@@ -0,0 +1,17 @@
+/**
+ * Convert arbitrary text into a URL-safe slug.
+ *
+ * Pipeline: lowercase → trim → collapse every run of non-alphanumerics into a
+ * single hyphen → strip leading/trailing hyphens.
+ *
+ * ASCII-only by design: characters outside [a-z0-9] (including accented Latin
+ * letters) are treated as separators, so "Café déjà vu" → "caf-d-j-vu". If SEO
+ * ever needs diacritic folding (café → cafe) that is a separate, explicit task.
+ */
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .trim()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "");
+}
