@@ -0,0 +1,36 @@
+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { truncate, titleCase } from "./str";
+
+test("truncate leaves within-budget text unchanged", () => {
+  assert.equal(truncate("Hello", 10), "Hello");
+  assert.equal(truncate("Hello", 5), "Hello");
+});
+
+test("truncate counts the ellipsis against the budget", () => {
+  const out = truncate("Hello world", 8);
+  assert.equal(out, "Hello w…");
+  assert.equal(out.length, 8);
+});
+
+test("truncate honors a custom ellipsis", () => {
+  assert.equal(truncate("Hello world", 8, "..."), "Hello...");
+});
+
+test("truncate with max <= ellipsis length returns a prefix of the ellipsis", () => {
+  assert.equal(truncate("Hello world", 2, "..."), "..");
+});
+
+test("truncate with max <= 0 returns empty string", () => {
+  assert.equal(truncate("Hello", 0), "");
+  assert.equal(truncate("Hello", -3), "");
+});
+
+test("titleCase capitalizes each word and lowercases the rest", () => {
+  assert.equal(titleCase("hello WORLD"), "Hello World");
+});
+
+test("titleCase preserves whitespace runs", () => {
+  assert.equal(titleCase("hello   world"), "Hello   World");
+  assert.equal(titleCase("  leading and trailing  "), "  Leading And Trailing  ");
+});
diff --git a/src/lib/str.ts b/src/lib/str.ts
new file mode 100644
index 0000000..11dc9fa
--- /dev/null
+++ b/src/lib/str.ts
@@ -0,0 +1,29 @@
+/**
+ * Truncate `text` to at most `max` characters, appending `ellipsis` when cut.
+ *
+ * The ellipsis is counted against the budget, so the result length never
+ * exceeds `max`: truncate("Hello world", 8) === "Hello w…" (length 8).
+ *
+ * - Text already within budget is returned unchanged.
+ * - If `max <= ellipsis.length` there is no room for content, so a prefix of
+ *   the ellipsis (length `max`) is returned; `max <= 0` yields "".
+ */
+export function truncate(text: string, max: number, ellipsis = "…"): string {
+  if (text.length <= max) return text;
+  if (max <= 0) return "";
+  if (max <= ellipsis.length) return ellipsis.slice(0, max);
+  return text.slice(0, max - ellipsis.length) + ellipsis;
+}
+
+/**
+ * Title-case each whitespace-separated word: first character upper, rest lower.
+ *
+ * Original whitespace runs are preserved exactly ("hello   world" →
+ * "Hello   World"), so the function is layout-safe for already-spaced text.
+ */
+export function titleCase(text: string): string {
+  return text.replace(
+    /\S+/g,
+    (word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase(),
+  );
+}
