+// Unit tests for currency-aware money formatting.
+//
+// Runner: Node's built-in test runner via the tsx loader. Run the whole suite
+// with `npm test` (globs src/**/*.test.ts), or this file alone with:
+//   npx tsx --test ./src/features/ledger/lib/format.test.ts
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { formatMoney } from "./format";
+import { addMoney } from "./arithmetic";
+import { MoneyArithmeticError } from "./arithmetic";
+
+test("USD with default locale (en-US): symbol + two minor units", () => {
+  assert.equal(formatMoney(1234.5, "USD"), "$1,234.50");
+  assert.equal(formatMoney(0, "USD"), "$0.00");
+  assert.equal(formatMoney(7, "USD"), "$7.00");
+});
+
+test("EUR with de-DE: comma decimal, dot grouping, trailing â‚¬ symbol", () => {
+  assert.equal(formatMoney(1234.56, "EUR", "de-DE"), "1.234,56Â â‚¬");
+});
+
+test("JPY has zero minor units (no decimal places)", () => {
+  assert.equal(formatMoney(1235, "JPY"), "ÂĄ1,235");
+  assert.equal(formatMoney(1234.4, "JPY"), "ÂĄ1,234"); // rounds to whole yen
+});
+
+test("formats negative values with the locale's sign placement", () => {
+  assert.equal(formatMoney(-1234.5, "USD"), "-$1,234.50");
+  // -0 is normalized to 0 by roundMoney â†’ never renders "-$0.00".
+  assert.equal(formatMoney(-0, "USD"), "$0.00");
+  assert.equal(formatMoney(addMoney(0.1, 0.1, "USD") - 0.2, "USD"), "$0.00");
+});
+
+test("formats very large values with full grouping and no precision loss", () => {
+  assert.equal(formatMoney(1234567.89, "USD"), "$1,234,567.89");
+  assert.equal(formatMoney(999999.99, "USD"), "$999,999.99");
+});
+
+test("rejects non-finite values with a typed MoneyArithmeticError", () => {
+  assert.throws(() => formatMoney(NaN, "USD"), MoneyArithmeticError);
+  assert.throws(() => formatMoney(Infinity, "USD"), MoneyArithmeticError);
+  assert.throws(() => formatMoney(-Infinity, "USD"), MoneyArithmeticError);
+  assert.throws(
+    () => formatMoney(NaN, "USD"),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "not-finite",
+  );
+  // Extends RangeError â†’ existing fail-loud catch sites still catch it.
+  assert.throws(() => formatMoney(NaN, "USD"), RangeError);
+});
+
+test("rejects mixed-currency Money objects with a typed error", () => {
+  assert.throws(
+    () => formatMoney({ amount: 5, currency: "EUR" }, "USD"),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "mixed-currency",
+  );
+  // A matching tagged Money is accepted and unwrapped.
+  assert.equal(formatMoney({ amount: 1234.5, currency: "USD" }, "USD"), "$1,234.50");
+});
+
+test("display is consistent with stored value across prior arithmetic (Reviewer check)", () => {
+  // The canonical end-to-end guarantee: arithmetic + formatting agree exactly.
+  assert.equal(formatMoney(addMoney(0.1, 0.2, "USD"), "USD"), "$0.30");
+  assert.equal(formatMoney(addMoney(0.1, 0.2, "USD"), "USD", "en-US"), "$0.30");
+});
