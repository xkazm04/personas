+"use client";
+
+import { useEffect, useState } from "react";
+
+// Light "paper" cream  ↔  dark "ink" black. A single attribute on <html>
+// (`data-theme="ink"`) flips the CSS custom properties; this component
+// just persists the choice and renders an accessible sun/moon switch.
+// Hydration safety: the actual attribute is written by an inline script
+// in `<head>` (see layout.tsx) BEFORE first paint — this component only
+// reads the already-applied value so the initial render matches the DOM.
+type Theme = "paper" | "ink";
+
+function getInitialTheme(): Theme {
+  if (typeof document === "undefined") return "paper";
+  const attr = document.documentElement.getAttribute("data-theme");
+  return attr === "ink" ? "ink" : "paper";
+}
+
+export function ThemeToggle({ className = "" }: { className?: string }) {
+  const [theme, setTheme] = useState<Theme>("paper");
+  const [mounted, setMounted] = useState(false);
+
+  // After mount we read the resolved theme that the head script already
+  // applied. This keeps SSR and the first client paint identical.
+  useEffect(() => {
+    setTheme(getInitialTheme());
+    setMounted(true);
+  }, []);
+
+  function toggle() {
+    const next: Theme = theme === "ink" ? "paper" : "ink";
+    setTheme(next);
+    document.documentElement.setAttribute("data-theme", next);
+    try {
+      window.localStorage.setItem("ledgerline-theme", next);
+    } catch {
+      /* storage may be blocked — toggle still works for the session */
+    }
+  }
+
+  const isInk = theme === "ink";
+  const label = isInk ? "Switch to paper mode" : "Switch to ink mode";
+
+  return (
+    <button
+      type="button"
+      onClick={toggle}
+      aria-label={label}
+      aria-pressed={isInk}
+      title={label}
+      className={
+        "inline-flex h-9 w-9 items-center justify-center rounded-control border border-rule-strong bg-surface text-foreground transition hover:border-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40 " +
+        className
+      }
+    >
+      {/* We render BOTH icons and hide one with CSS-via-attribute so the
+          server markup is deterministic. Once mounted, the active icon
+          is reaffirmed from React state to keep aria in sync. */}
+      <span aria-hidden className="relative block h-4 w-4">
+        {/* sun → visible in ink mode (so you know clicking returns you to paper) */}
+        <svg
+          viewBox="0 0 24 24"
+          fill="none"
+          stroke="currentColor"
+          strokeWidth="1.8"
+          strokeLinecap="round"
+          strokeLinejoin="round"
+          className={
+            "absolute inset-0 h-4 w-4 transition-opacity duration-200 " +
+            (mounted ? (isInk ? "opacity-100" : "opacity-0") : "opacity-0")
+          }
+        >
+          <circle cx="12" cy="12" r="4" />
+          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
+        </svg>
+        {/* moon → visible in paper mode */}
+        <svg
+          viewBox="0 0 24 24"
+          fill="none"
+          stroke="currentColor"
+          strokeWidth="1.8"
+          strokeLinecap="round"
+          strokeLinejoin="round"
+          className={
+            "absolute inset-0 h-4 w-4 transition-opacity duration-200 " +
+            (mounted ? (isInk ? "opacity-0" : "opacity-100") : "opacity-100")
+          }
+        >
+          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" />
+        </svg>
+      </span>
+    </button>
+  );
+}
