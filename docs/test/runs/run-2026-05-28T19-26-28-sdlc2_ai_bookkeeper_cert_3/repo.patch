+++ b/src/lib/motion.ts
+// Shared motion vocabulary for the "Ruled Ledger" identity.
+// One ease curve everywhere, one stagger rhythm, one travel distance.
+// Components consume these variants so the whole site choreographs as
+// a single document — pages turn, lines draw, ink settles.
+import type { Variants } from "framer-motion";
+
+// The signature curve — Apple's softer "ease-in-out" cousin. It feels
+// like a fountain pen finishing a stroke: quick start, long settle.
+export const easeLedger: [number, number, number, number] = [
