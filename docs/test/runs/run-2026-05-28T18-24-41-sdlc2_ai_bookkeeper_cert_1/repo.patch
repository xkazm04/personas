+// Unit tests for currency-aware money addition/subtraction.
+//
+// Runner: Node's built-in test runner via the tsx loader. Run the whole suite
+// with `npm test` (globs src/**/*.test.ts), or this file alone with:
+//   npx tsx --test ./src/features/ledger/lib/arithmetic.test.ts
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import {
+  MoneyArithmeticError,
+  addMoney,
+  subtractMoney,
+} from "./arithmetic";
+import { roundMoney } from "./round";
+
+test("adds and subtracts same-currency amounts", () => {
+  assert.equal(addMoney(10.25, 4.5, "USD"), 14.75);
+  assert.equal(subtractMoney(10.25, 4.5, "USD"), 5.75);
+  assert.equal(addMoney(100, 200, "USD"), 300);
+  assert.equal(subtractMoney(200, 50, "USD"), 150);
+});
+
+test("eliminates sub-cent precision drift (0.1 + 0.2 === 0.30, USD)", () => {
+  // The whole point of integer-minor-unit arithmetic: no 0.30000000000000004.
+  const sum = addMoney(0.1, 0.2, "USD");
+  assert.equal(sum, 0.3);
+  assert.ok(Object.is(sum, 0.3));
+  // A chain of penny adds stays exact.
+  assert.equal(addMoney(addMoney(0.1, 0.2, "USD"), 0.1, "USD"), 0.4);
+  assert.equal(subtractMoney(0.3, 0.1, "USD"), 0.2);
+});
+
+test("handles large magnitudes without losing precision", () => {
+  assert.equal(addMoney(999_999.99, 0.01, "USD"), 1_000_000);
+  assert.equal(subtractMoney(1_000_000, 0.01, "USD"), 999_999.99);
+  assert.equal(addMoney(123_456.78, 876_543.21, "USD"), 999_999.99);
+});
+
+test("produces valid negative results from subtraction", () => {
+  assert.equal(subtractMoney(4.5, 10.25, "USD"), -5.75);
+  assert.equal(subtractMoney(0, 0.3, "USD"), -0.3);
+  // -0 is normalized to 0 (matches roundMoney's contract).
+  assert.equal(subtractMoney(0.1, 0.1, "USD"), 0);
+  assert.ok(Object.is(subtractMoney(0.1, 0.1, "USD"), 0));
+});
+
+test("respects non-2dp currencies (JPY 0dp, BHD 3dp)", () => {
+  assert.equal(addMoney(1234, 1, "JPY"), 1235);
+  assert.equal(subtractMoney(1000, 1, "JPY"), 999);
+  assert.equal(addMoney(1.001, 0.002, "BHD"), 1.003);
+});
+
+test("rejects NaN and Infinity operands with a typed error", () => {
+  assert.throws(() => addMoney(NaN, 1, "USD"), MoneyArithmeticError);
+  assert.throws(() => addMoney(1, Infinity, "USD"), MoneyArithmeticError);
+  assert.throws(() => subtractMoney(-Infinity, 1, "USD"), MoneyArithmeticError);
+  assert.throws(
+    () => addMoney(NaN, 1, "USD"),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "not-finite",
+  );
+  // MoneyArithmeticError extends RangeError → fail-loud catch sites still catch.
+  assert.throws(() => addMoney(NaN, 1, "USD"), RangeError);
+});
+
+test("rejects mixed-currency operands with a typed error", () => {
+  assert.throws(
+    () => addMoney({ amount: 5, currency: "EUR" }, 3, "USD"),
+    MoneyArithmeticError,
+  );
+  assert.throws(
+    () => subtractMoney(10, { amount: 2, currency: "GBP" }, "USD"),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "mixed-currency",
+  );
+  // Matching tagged currency is accepted and unwrapped.
+  assert.equal(
+    addMoney({ amount: 1.1, currency: "USD" }, { amount: 2.2, currency: "USD" }, "USD"),
+    3.3,
+  );
+});
+
+test("composes with roundMoney: result is already canonical (idempotent)", () => {
+  // The Reviewer's key check — feeding the result back through roundMoney is a
+  // no-op, proving arithmetic emits a value canonical to the currency's units.
+  for (const [a, b, ccy] of [
+    [0.1, 0.2, "USD"],
+    [2.675, 0.005, "USD"],
+    [1234, 1, "JPY"],
+    [1.001, 0.002, "BHD"],
+  ] as const) {
+    const r = addMoney(a, b, ccy);
+    assert.equal(roundMoney(r, ccy), r);
+    const s = subtractMoney(a, b, ccy);
+    assert.equal(roundMoney(s, ccy), s);
+  }
+});
+
+test("rejects a blank/invalid currency code (via roundMoney/minorUnits guard)", () => {
+  assert.throws(() => addMoney(1, 2, ""), RangeError);
+  assert.throws(() => subtractMoney(1, 2, "   "), RangeError);
+});
