+const ZERO_FIT = makeGrant({
+  id: "zero-fit",
+  title: "Vermont rural bridge repair",
+  agency: "Vermont State DOT",
+  closeDate: "06/01/2026",
+  awardFloor: 5_000,
+  awardCeiling: 20_000,
+});
+
+describe("getMatches", () => {
+  beforeEach(() => {
+    clearGrants();
+  });
+
+  afterAll(() => {
+    clearGrants();
+    closeDb();
+  });
+
+  it("returns [] when the grants table is empty", () => {
+    expect(getMatches()).toEqual([]);
+  });
+
+  it("excludes zero-fit grants (the total > 0 filter)", () => {
+    upsertGrants([ZERO_FIT]);
+    expect(getMatches()).toEqual([]);
+  });
+
+  it("ranks by fit descending regardless of insertion order", () => {
+    // Insert in an order that does NOT match fit so a missing/incorrect
+    // sort would surface a different row first.
+    upsertGrants([FEDERAL_BROAD, ZERO_FIT, HOUSTON_YOUTH, UNKNOWN_AWARD]);
+    const out = getMatches();
+    expect(out.map((m) => m.id)).toEqual([
+      "houston-youth",
+      "unknown-award",
+      "federal-broad",
+    ]);
+    // Fit is monotonically non-increasing and the zero-fit grant is gone.
+    const fits = out.map((m) => m.fit);
+    expect(fits).toEqual([...fits].sort((a, b) => b - a));
+    expect(out.find((m) => m.id === "zero-fit")).toBeUndefined();
+  });
+
+  it("respects the limit (default 5 and explicit)", () => {
+    const many = Array.from({ length: 8 }, (_, i) =>
+      makeGrant({
+        id: `youth-${i}`,
+        title: "Houston youth after-school mentoring",
+        awardFloor: 50_000,
+        awardCeiling: 100_000,
+      })
+    );
+    upsertGrants(many);
+    expect(getMatches()).toHaveLength(5); // default limit
+    expect(getMatches(undefined, 3)).toHaveLength(3);
+    expect(getMatches(undefined, 100)).toHaveLength(8); // capped by row count
+  });
+
+  describe("GrantMatch shape / formatting", () => {
+    it("maps the agency to funder and formats an award range + MM/DD/YYYY due date", () => {
+      upsertGrants([HOUSTON_YOUTH]);
+      const [m] = getMatches();
+      expect(m.id).toBe("houston-youth");
+      expect(m.funder).toBe("U.S. Department of Education");
+      expect(m.amount).toBe("$50K–$100K");
+      expect(m.due).toBe("Jun 01"); // MM/DD/YYYY -> 'Mon DD'
+      expect(m.fit).toBeGreaterThan(0);
+    });
+
+    it("falls back to 'Unknown funder', 'Amount TBD' and 'TBD' due for null fields", () => {
+      upsertGrants([UNKNOWN_AWARD]);
+      const [m] = getMatches();
+      expect(m.funder).toBe("Unknown funder");
+      expect(m.amount).toBe("Amount TBD");
+      expect(m.due).toBe("TBD");
+    });
+
+    it("formats a million-dollar ceiling and passes ISO close dates through verbatim", () => {
+      // Pins current behavior: formatCloseDate only reformats MM/DD/YYYY;
+      // an ISO date is shown raw. deadline-radar parses ISO, getMatches
+      // does not — a deliberate inconsistency this guards against silent change.
+      upsertGrants([FEDERAL_BROAD]);
+      const [m] = getMatches();
+      expect(m.amount).toBe("$500K–$1.0M");
+      expect(m.due).toBe("2026-07-14");
+    });
+
+    it("truncates programs longer than 80 chars with an ellipsis", () => {
+      const longTitle = `Houston youth ${"funding ".repeat(20)}`.trim();
+      expect(longTitle.length).toBeGreaterThan(80);
+      upsertGrants([
+        makeGrant({
+          id: "long-title",
+          title: longTitle,
+          awardFloor: 50_000,
+          awardCeiling: 100_000,
+        }),
+      ]);
+      const [m] = getMatches();
+      expect(m.program.length).toBe(80);
+      expect(m.program.endsWith("…")).toBe(true);
+      expect(m.program.startsWith("Houston youth")).toBe(true);
+    });
+  });
+});
+

diff --git a/src/features/grant-ingest/grantsGov.test.ts b/src/features/grant-ingest/grantsGov.test.ts
