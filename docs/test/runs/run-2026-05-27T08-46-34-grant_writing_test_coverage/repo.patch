+++ b/src/features/grant-ingest/grantsGov.test.ts
+import { describe, expect, it } from "vitest";
+import { htmlToPlain, normalize, toNum } from "./grantsGov";
+import type { GrantsGovOpportunity } from "./types";
+
+// Regression tests for the grants.gov NORMALIZATION BOUNDARY — the pure
+// functions every stored grant passes through before scoring, drafting,
+// deadline-radar and certificate generation ever see it. Network fetching
+// is deliberately out of scope here: normalize/toNum/htmlToPlain are pure,
+// so we exercise the field coercions and the documented invariants that,
+// if broken, silently corrupt every downstream feature.
+//
+// These are NOT trivial assertions: each test pins a specific way a
+// real grants.gov payload has been observed to vary (string-encoded
+// numbers, "none" sentinels, missing ids, array-vs-scalar cfdaList,
+// hand-authored synopsis HTML) and an invariant the storage layer relies
+// on (id stability for ON CONFLICT(id) upserts).
+
+function raw(overrides: Partial<GrantsGovOpportunity> = {}): GrantsGovOpportunity {
+  return { ...overrides };
+}
+
+describe("toNum — award-amount coercion (feeds awardSize scoring + amount display)", () => {
+  it("passes through finite numbers", () => {
+    expect(toNum(50000)).toBe(50000);
+    expect(toNum(0)).toBe(0);
+  });
+
+  it("parses string-encoded numbers the API sends", () => {
+    expect(toNum("50000")).toBe(50000);
+  });
+
+  it("strips currency formatting before parsing", () => {
+    expect(toNum("$1,250,000")).toBe(1250000);
+  });
+
+  it("treats null, undefined and empty string as 'unknown' (null)", () => {
+    expect(toNum(null)).toBeNull();
+    expect(toNum(undefined)).toBeNull();
+    expect(toNum("")).toBeNull();
+  });
+
+  it("treats the literal 'none' sentinel as unknown, case-insensitively", () => {
+    // grants.gov sends the string "None" for unbounded awards; if this
+    // leaked through as NaN/0 the award sweet-spot scorer would mis-fire.
+    expect(toNum("none")).toBeNull();
+    expect(toNum("NONE")).toBeNull();
+  });
+
+  it("returns null (never NaN) for unparseable junk", () => {
+    expect(toNum("not a number")).toBeNull();
+  });
+});
+
+describe("normalize — id stability (storage relies on ON CONFLICT(id) upsert)", () => {
+  it("prefers the explicit id", () => {
+    expect(normalize(raw({ id: "OPP-123", number: "FOO-1" })).id).toBe("OPP-123");
+  });
+
+  it("falls back to the opportunity number when id is absent", () => {
+    expect(normalize(raw({ number: "FOO-1" })).id).toBe("FOO-1");
+  });
+
+  it("produces a STABLE id for the same payload across repeated ingests", () => {
+    // REGRESSION GUARD: the random-id fallback for payloads missing both
+    // id and number means re-ingesting the same grant inserts a NEW row
+    // every run (it never collides on the PRIMARY KEY), instead of
+    // upserting. Two normalizations of an identical payload must yield the
+    // same id, or the grants table silently accumulates duplicates.
+    const payload = raw({ agencyCode: "ED", title: "After-school fund" });
+    const a = normalize(payload).id;
+    const b = normalize(payload).id;
+    expect(a).toBe(b);
+  });
+});
+
+describe("normalize — field mapping & defaults the downstream shape depends on", () => {
+  it("defaults a missing title rather than emitting undefined", () => {
+    expect(normalize(raw()).title).toBe("(untitled opportunity)");
+  });
+
+  it("resolves agency through the documented fallback chain", () => {
+    expect(normalize(raw({ agencyName: "Dept of Ed" })).agency).toBe("Dept of Ed");
+    expect(normalize(raw({ agency: "USDA" })).agency).toBe("USDA");
+    expect(normalize(raw({ agencyCode: "ED-OESE" })).agency).toBe("ED-OESE");
+    expect(normalize(raw()).agency).toBeNull();
+  });
+
+  it("takes the first CFDA when cfdaList is an array", () => {
+    expect(normalize(raw({ cfdaList: ["84.215", "84.287"] })).cfdaNumber).toBe("84.215");
+  });
+
+  it("accepts a scalar cfdaList (the API sends both shapes)", () => {
+    expect(normalize(raw({ cfdaList: "84.215" })).cfdaNumber).toBe("84.215");
+  });
+
+  it("normalizes a missing cfdaList to null, never undefined", () => {
+    expect(normalize(raw()).cfdaNumber).toBeNull();
+  });
+
+  it("defaults eligibilityCodes to an empty array so scoring can iterate safely", () => {
+    expect(normalize(raw()).eligibilityCodes).toEqual([]);
+    expect(normalize(raw({ alnist: ["25", "12"] })).eligibilityCodes).toEqual(["25", "12"]);
+  });
+
+  it("coerces string-encoded award bounds via toNum", () => {
+    const g = normalize(raw({ awardFloor: "10000", awardCeiling: "None" }));
+    expect(g.awardFloor).toBe(10000);
+    expect(g.awardCeiling).toBeNull();
+  });
+
+  it("preserves the full raw payload as rawJson for later reshaping", () => {
+    const payload = raw({ id: "X", title: "T", docType: "synopsis" });
+    expect(JSON.parse(normalize(payload).rawJson)).toEqual(payload);
+  });
+});
+
+describe("htmlToPlain — synopsis cleanup (feeds mission-keyword scoring)", () => {
+  it("strips tags and collapses whitespace", () => {
+    expect(htmlToPlain("<p>After-school   youth\nmentoring</p>")).toBe(
+      "After-school youth mentoring"
+    );
+  });
+
+  it("decodes the entities agencies actually emit", () => {
+    expect(htmlToPlain("K&amp;12 &lt;tutoring&gt; &quot;programs&quot; &#39;here&#39;")).toBe(
+      `K&12 <tutoring> "programs" 'here'`
+    );
+  });
+
+  it("flattens list markup into scoreable plain text", () => {
+    expect(htmlToPlain("<ul><li>youth</li><li>education</li></ul>")).toBe("youth education");
+  });
+
+  it("returns null for empty / nullish / tags-only input (so enrichment leaves the row alone)", () => {
+    expect(htmlToPlain(null)).toBeNull();
+    expect(htmlToPlain(undefined)).toBeNull();
+    expect(htmlToPlain("")).toBeNull();
+    expect(htmlToPlain("<br/> &nbsp; ")).toBeNull();
+  });
+});
+
