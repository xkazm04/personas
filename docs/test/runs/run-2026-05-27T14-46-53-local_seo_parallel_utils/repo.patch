index 0000000..b1d68c7
--- /dev/null
+++ b/src/lib/str.ts
@@ -0,0 +1,23 @@
+/**
+ * Truncate `text` so the returned string is at most `max` characters,
+ * counting the ellipsis against that budget.
+ *
+ * - Text already within budget is returned unchanged.
+ * - When `max <= ellipsis.length` only (a prefix of) the ellipsis is returned.
+ */
+export function truncate(text: string, max: number, ellipsis = "…"): string {
+  if (text.length <= max) return text;
+  if (max <= ellipsis.length) return ellipsis.slice(0, Math.max(0, max));
+  return text.slice(0, max - ellipsis.length) + ellipsis;
+}
+
+/**
+ * Title-case `text`: uppercase the first character of each word, lowercase the
+ * rest. Original whitespace runs are preserved (`"a   b"` -> `"A   B"`).
+ */
+export function titleCase(text: string): string {
+  return text.replace(
+    /\S+/g,
+    (word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase(),
+  );
+}

