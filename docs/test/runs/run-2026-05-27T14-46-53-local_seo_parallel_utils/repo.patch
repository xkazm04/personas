+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { truncate, titleCase } from "./str";
+
+test("truncate: text within budget is unchanged", () => {
+  assert.equal(truncate("Hello", 10), "Hello");
+  assert.equal(truncate("Hello", 5), "Hello");
+});
+
+test("truncate: counts ellipsis against max (result length <= max)", () => {
+  const out = truncate("Hello world", 8);
+  assert.equal(out, "Hello w…");
+  assert.equal(out.length, 8);
+});
+
+test("truncate: max <= ellipsis length returns (prefix of) ellipsis", () => {
+  assert.equal(truncate("Hello", 1), "…");
+  assert.equal(truncate("Hello", 0), "");
+});
+
+test("truncate: honors a custom multi-char ellipsis within budget", () => {
+  const out = truncate("Hello world", 8, "...");
+  assert.equal(out, "Hello...");
+  assert.equal(out.length, 8);
+});
+
+test("titleCase: capitalizes each word and lowercases the rest", () => {
+  assert.equal(titleCase("hello WORLD"), "Hello World");
+  assert.equal(titleCase("the QUICK brown FoX"), "The Quick Brown Fox");
+});
+
+test("titleCase: preserves original whitespace runs", () => {
+  assert.equal(titleCase("hello   world"), "Hello   World");
+  assert.equal(titleCase("  leading space"), "  Leading Space");
+});
+
+test("titleCase: empty string yields empty string", () => {
+  assert.equal(titleCase(""), "");
+});
