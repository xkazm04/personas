+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { slugify } from "./slug";
+
+test("slugify: lowercases and hyphenates spaces", () => {
+  assert.equal(slugify("Hello World"), "hello-world");
+});
+
+test("slugify: collapses runs of separators into a single hyphen", () => {
+  assert.equal(slugify("a   b___c!!!d"), "a-b-c-d");
+});
+
+test("slugify: trims surrounding whitespace and strips edge hyphens", () => {
+  assert.equal(slugify("  --Hello, World!--  "), "hello-world");
+});
+
+test("slugify: empty and all-separator input yields empty string", () => {
+  assert.equal(slugify(""), "");
+  assert.equal(slugify("   "), "");
+  assert.equal(slugify("!!! --- ???"), "");
+});
+
+test("slugify: is idempotent", () => {
+  const once = slugify("Local SEO Agency — Rankings!");
+  assert.equal(slugify(once), once);
+  assert.equal(once, "local-seo-agency-rankings");
+});
+
+test("slugify: preserves existing alphanumerics including digits", () => {
+  assert.equal(slugify("Top 10 Keywords 2026"), "top-10-keywords-2026");
+});
+
+test("slugify: is ASCII-only — accents act as separators (documented)", () => {
+  assert.equal(slugify("Café déjà vu"), "caf-d-j-vu");
+});
+
+test("slugify: leading/trailing alphanumerics are kept", () => {
+  assert.equal(slugify("foo-bar"), "foo-bar");
+});
