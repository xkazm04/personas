new file mode 100644
index 0000000..bf38120
--- /dev/null
+++ b/src/lib/num.ts
@@ -0,0 +1,35 @@
+/**
+ * Constrain `value` to the inclusive range [min, max].
+ *
+ * - `±Infinity` value snaps to the nearer bound.
+ * - `NaN` value propagates as `NaN` (caller's bug to surface, not hide).
+ * - A non-finite or inverted bound (`min > max`) is a programming error and
+ *   throws `RangeError` rather than returning a silently-wrong result.
+ */
+export function clamp(value: number, min: number, max: number): number {
+  if (!Number.isFinite(min) || !Number.isFinite(max)) {
+    throw new RangeError(`clamp: bounds must be finite (min=${min}, max=${max})`);
+  }
+  if (min > max) {
+    throw new RangeError(`clamp: min (${min}) must not exceed max (${max})`);
+  }
+  if (Number.isNaN(value)) return NaN;
+  if (value < min) return min;
+  if (value > max) return max;
+  return value;
+}
+
+/**
+ * Round `value` to `decimals` decimal places, correcting binary-FP error so
+ * that half-values round up predictably (`roundTo(1.005, 2) === 1.01`).
+ *
+ * - Non-finite `value` is returned unchanged.
+ * - Non-finite or negative `decimals` is treated as 0.
+ */
+export function roundTo(value: number, decimals: number): number {
+  if (!Number.isFinite(value)) return value;
+  const d = Number.isFinite(decimals) && decimals > 0 ? Math.floor(decimals) : 0;
+  // Shift via exponential notation to avoid float representation drift.
+  const shifted = Math.round(Number(`${value}e${d}`));
+  return Number(`${shifted}e-${d}`);
+}
