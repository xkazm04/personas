index 0000000..8c9a4f6
--- /dev/null
+++ b/src/lib/slug.ts
@@ -0,0 +1,17 @@
+/**
+ * Convert arbitrary text into a URL-safe slug.
+ *
+ * Pipeline: lowercase -> trim -> collapse every run of non-alphanumeric
+ * characters into a single hyphen -> strip leading/trailing hyphens.
+ *
+ * ASCII-only by design: characters outside [a-z0-9] (including accented
+ * letters) are treated as separators, NOT transliterated. `Café` -> `caf`.
+ * If SEO ever requires diacritic folding (café -> cafe), that is a new task.
+ */
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .trim()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "");
+}
