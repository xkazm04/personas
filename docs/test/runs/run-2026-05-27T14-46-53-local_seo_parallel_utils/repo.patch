@@ -0,0 +1,50 @@
+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { clamp, roundTo } from "./num";
+
+test("clamp: returns value when within range (inclusive bounds)", () => {
+  assert.equal(clamp(5, 0, 10), 5);
+  assert.equal(clamp(0, 0, 10), 0);
+  assert.equal(clamp(10, 0, 10), 10);
+});
+
+test("clamp: snaps out-of-range values to the nearer bound", () => {
+  assert.equal(clamp(-3, 0, 10), 0);
+  assert.equal(clamp(99, 0, 10), 10);
+});
+
+test("clamp: ±Infinity value snaps to a bound", () => {
+  assert.equal(clamp(Infinity, 0, 10), 10);
+  assert.equal(clamp(-Infinity, 0, 10), 0);
+});
+
+test("clamp: NaN value propagates as NaN", () => {
+  assert.ok(Number.isNaN(clamp(NaN, 0, 10)));
+});
+
+test("clamp: throws RangeError on inverted or non-finite bounds", () => {
+  assert.throws(() => clamp(5, 10, 0), RangeError);
+  assert.throws(() => clamp(5, NaN, 10), RangeError);
+  assert.throws(() => clamp(5, 0, Infinity), RangeError);
+});
+
+test("roundTo: corrects binary-FP so halves round up", () => {
+  assert.equal(roundTo(1.005, 2), 1.01);
+  assert.equal(roundTo(2.345, 2), 2.35);
+});
+
+test("roundTo: basic rounding and zero decimals", () => {
+  assert.equal(roundTo(3.14159, 2), 3.14);
+  assert.equal(roundTo(2.5, 0), 3);
+  assert.equal(roundTo(1234.5, 0), 1235);
+});
+
+test("roundTo: non-finite value returned unchanged", () => {
+  assert.equal(roundTo(Infinity, 2), Infinity);
+  assert.ok(Number.isNaN(roundTo(NaN, 2)));
+});
+
+test("roundTo: non-finite or negative decimals treated as 0", () => {
+  assert.equal(roundTo(2.7, -1), 3);
+  assert.equal(roundTo(2.7, NaN), 3);
+});
