+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { isValidSignedAmount, MAX_AMOUNT, parseAmount } from "./amount";
+
+test("accepts a clean expense magnitude and signs it negative", () => {
+  const r = parseAmount("184.22", "debit");
+  assert.deepEqual(r, { ok: true, value: -184.22 });
+});
+
+test("accepts a clean income magnitude and keeps it positive", () => {
+  const r = parseAmount(580, "credit");
+  assert.deepEqual(r, { ok: true, value: 580 });
+});
+
+test("strips currency symbols and thousands separators", () => {
+  assert.deepEqual(parseAmount("$1,284.50", "credit"), { ok: true, value: 1284.5 });
+});
+
+test("rejects non-numeric input", () => {
+  assert.deepEqual(parseAmount("twelve dollars", "debit"), { ok: false, error: "not-a-number" });
+});
+
+test("rejects empty / null input", () => {
+  assert.deepEqual(parseAmount("   ", "debit"), { ok: false, error: "empty" });
+  assert.deepEqual(parseAmount(null, "debit"), { ok: false, error: "empty" });
+});
+
+test("rejects NaN and Infinity", () => {
+  assert.deepEqual(parseAmount(NaN, "credit"), { ok: false, error: "not-a-number" });
+  assert.deepEqual(parseAmount(Infinity, "credit"), { ok: false, error: "not-finite" });
+});
+
+test("rejects a negative magnitude (sign is the caller's job)", () => {
+  assert.deepEqual(parseAmount(-50, "credit"), { ok: false, error: "negative-magnitude" });
+});
+
+test("rejects zero", () => {
+  assert.deepEqual(parseAmount("0.00", "debit"), { ok: false, error: "zero" });
+});
+
+test("rejects more than two decimal places", () => {
+  assert.deepEqual(parseAmount("10.001", "debit"), { ok: false, error: "too-many-decimals" });
+});
+
+test("rejects amounts above the per-transaction ceiling", () => {
+  assert.deepEqual(parseAmount(MAX_AMOUNT + 0.01, "credit"), { ok: false, error: "out-of-range" });
+});
+
+test("absorbs binary floating-point noise within cents", () => {
+  // 1284.5 is representable; constructions like 0.1 + 0.2 are not — the
+  // validator should treat a true 2-decimal value as valid.
+  assert.deepEqual(parseAmount(70.7, "debit"), { ok: true, value: -70.7 });
+});
+
+test("isValidSignedAmount guards canonical stored values", () => {
+  assert.equal(isValidSignedAmount(-184.22), true);
+  assert.equal(isValidSignedAmount(0), false);
+  assert.equal(isValidSignedAmount(10.001), false);
+  assert.equal(isValidSignedAmount(MAX_AMOUNT + 1), false);
+  assert.equal(isValidSignedAmount(NaN), false);
+});
