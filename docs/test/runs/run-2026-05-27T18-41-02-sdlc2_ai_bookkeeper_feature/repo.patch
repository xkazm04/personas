new file mode 100644
--- /dev/null
+++ b/src/features/ledger/lib/amount.ts
+// Input-boundary validation for monetary amounts.
+//
+// Every amount that enters the ledger — from SMS/OCR receipt capture, a
+// forwarded invoice, or a Plaid bank-feed row — must pass through here before
+// it becomes a `Transaction.amount`. The canonical representation is the one
+// the rest of the app already binds to: a signed `number` in USD, rounded to
+// two decimal places, where credit (income) is positive and debit (expense)
+// is negative (see features/ledger/types.ts and wealth-score/lib/compute.ts,
+// which rely on that sign convention).
+//
+// This module is deliberately a set of pure functions, matching the repo's
+// other validation/normalization libs (customers/lib/normalize.ts,
+// benchmarks/lib/categorize.ts). No I/O, no logging — callers decide what to
+// do with a rejection.
+
+/** Hard ceiling for a single transaction magnitude. Solo-trades transactions
+ *  above $1M are far outside the customer profile ($50K–$500K revenue) and
+ *  almost certainly a parse error (e.g. "$58000" read as "5800000"). */
+export const MAX_AMOUNT = 1_000_000;
+
+/** credit = income (stored positive); debit = expense (stored negative). */
+export type AmountDirection = "credit" | "debit";
+
+export type AmountError =
+  | "empty" //            blank / whitespace-only input
+  | "not-a-number" //     could not be coerced to a number
+  | "not-finite" //       NaN / Infinity
+  | "negative-magnitude" // a magnitude must be ≥ 0; sign is set by direction
+  | "zero" //             a $0.00 transaction is meaningless in the ledger
+  | "too-many-decimals" // more precision than USD cents
+  | "out-of-range"; //    magnitude exceeds MAX_AMOUNT
+
+export type ParseAmountResult =
+  | { ok: true; value: number }
+  | { ok: false; error: AmountError };
+
+const HUMAN_ERROR: Record<AmountError, string> = {
+  empty: "No amount was provided.",
+  "not-a-number": "That doesn't look like a dollar amount.",
+  "not-finite": "Amount is not a finite number.",
+  "negative-magnitude": "Amount can't be negative — direction sets income vs. expense.",
+  zero: "Amount can't be zero.",
+  "too-many-decimals": "Amounts can have at most two decimal places (cents).",
+  "out-of-range": `Amount is above the $${MAX_AMOUNT.toLocaleString("en-US")} per-transaction limit.`,
+};
+
+/** A user-facing explanation for an AmountError — for the SMS reply / review queue. */
+export function explainAmountError(error: AmountError): string {
+  return HUMAN_ERROR[error];
+}
+
+// Currency symbols, thousands separators, and surrounding whitespace are
+// tolerated on string input ("$1,284.50", " 285 "). Anything else after
+// stripping is treated as non-numeric.
+const STRIPPABLE = /[$,\s]/g;
+
+/**
+ * Validate and canonicalize a raw amount magnitude into a signed ledger value.
+ *
+ * `raw` is the magnitude as captured upstream (a number, or a string from OCR /
+ * an SMS body). It must be a positive, finite value with ≤ 2 decimal places and
+ * within [0, MAX_AMOUNT]. `direction` decides the stored sign.
+ */
+export function parseAmount(
+  raw: unknown,
+  direction: AmountDirection,
+): ParseAmountResult {
+  let n: number;
+
+  if (typeof raw === "number") {
+    n = raw;
+  } else if (typeof raw === "string") {
+    const cleaned = raw.replace(STRIPPABLE, "");
+    if (cleaned === "") return { ok: false, error: "empty" };
+    // Number("") is 0 and Number("12px") is NaN; the regex above already
+    // removed the only non-digit characters we accept.
+    n = Number(cleaned);
+    if (Number.isNaN(n)) return { ok: false, error: "not-a-number" };
+  } else if (raw == null) {
+    return { ok: false, error: "empty" };
+  } else {
+    return { ok: false, error: "not-a-number" };
+  }
+
+  if (Number.isNaN(n)) return { ok: false, error: "not-a-number" };
+  if (!Number.isFinite(n)) return { ok: false, error: "not-finite" };
+  if (n < 0) return { ok: false, error: "negative-magnitude" };
+  if (n === 0) return { ok: false, error: "zero" };
+  if (n > MAX_AMOUNT) return { ok: false, error: "out-of-range" };
+  if (!hasAtMostCents(n)) return { ok: false, error: "too-many-decimals" };
+
+  const magnitude = roundToCents(n);
+  // roundToCents can pull a sub-cent value (0.004) down to 0 — reject rather
+  // than silently store a $0 transaction.
+  if (magnitude === 0) return { ok: false, error: "zero" };
+
+  return { ok: true, value: direction === "debit" ? -magnitude : magnitude };
+}
+
+/**
+ * Guard for an already-signed canonical amount (e.g. a Transaction.amount read
+ * from storage or constructed in code). Asserts the same invariants without
+ * re-deriving the sign: finite, non-zero, |amount| ≤ MAX_AMOUNT, ≤ 2 decimals.
+ */
+export function isValidSignedAmount(amount: number): boolean {
+  if (typeof amount !== "number") return false;
+  if (!Number.isFinite(amount)) return false;
+  if (amount === 0) return false;
+  const magnitude = Math.abs(amount);
+  if (magnitude > MAX_AMOUNT) return false;
+  return hasAtMostCents(magnitude);
+}
+
+function hasAtMostCents(n: number): boolean {
+  // Compare against the cent-rounded value with an epsilon to absorb binary
+  // floating-point noise (e.g. 1284.5 storing as 1284.4999999999998).
+  return Math.abs(n - roundToCents(n)) < 1e-9;
+}
+
+function roundToCents(n: number): number {
+  return Math.round((n + Number.EPSILON) * 100) / 100;
+}
+

