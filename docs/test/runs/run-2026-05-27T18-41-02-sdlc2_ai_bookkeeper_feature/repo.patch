+/** Minimal Transaction factory — only the fields compare.ts reads matter. */
+function tx(over: Partial<Transaction> & { amount: number }): Transaction {
+  return {
+    id: over.id ?? "t",
+    date: over.date ?? "2026-01-01",
+    description: over.description ?? "",
+    category: over.category ?? "Service call",
+    confidence: over.confidence ?? 1,
+    ...over,
+  };
+}
+
+/** Minimal CategoryBenchmark factory. */
+function bench(over: Partial<CategoryBenchmark> & { category: CategoryBenchmark["category"] }): CategoryBenchmark {
+  return {
+    category: over.category,
+    zip: over.zip ?? "00000",
+    peerMedian: over.peerMedian ?? 100,
+    peerP25: over.peerP25 ?? 80,
+    peerP75: over.peerP75 ?? 120,
+    peerSampleSize: over.peerSampleSize ?? 50,
+    rationale: over.rationale ?? [],
+    ...over,
