+++ b/src/features/ledger/lib/ingest.ts
+// Ingest boundary for ledger transactions.
+//
+// This is the single seam every amount source funnels through before a row
+// lands in the ledger. Today the dashboard reads typed mock data (data.ts);
+// when the live adapters are built (Twilio SMS/MMS → OCR, Plaid bank feed),
+// each adapter maps its payload to a RawTransaction and calls
+// `ingestTransaction` instead of trusting the upstream amount.
+//
+// Pure function — it classifies input as accepted or rejected and returns
+// both; the caller (an API route, a Cloud Run worker) decides whether to
+// persist accepted rows and route rejections to the review queue / SMS reply.
+
+import { type Transaction } from "../types";
+import {
+  type AmountDirection,
+  type AmountError,
+  explainAmountError,
+  parseAmount,
+} from "./amount";
+
+/** A transaction as captured upstream, before amount validation. `amount` is a
+ *  magnitude (string from OCR/SMS, or a number from a bank feed); `direction`
+ *  carries the income-vs-expense decision the source already made. */
+export interface RawTransaction {
+  id: string;
+  date: string;
+  description: string;
+  category: string;
+  amount: unknown;
+  direction: AmountDirection;
+  confidence: number;
+  customerId?: string;
+}
+
+export interface RejectedTransaction {
+  raw: RawTransaction;
+  error: AmountError;
+  message: string;
+}
+
+export interface IngestResult {
+  accepted: Transaction[];
+  rejected: RejectedTransaction[];
+}
+
+/** Validate a single raw row's amount and, if valid, project it into a
+ *  canonical Transaction. */
+export function ingestTransaction(
+  raw: RawTransaction,
+): { ok: true; transaction: Transaction } | { ok: false; rejection: RejectedTransaction } {
+  const result = parseAmount(raw.amount, raw.direction);
+  if (!result.ok) {
+    return {
+      ok: false,
+      rejection: { raw, error: result.error, message: explainAmountError(result.error) },
+    };
+  }
+  return {
+    ok: true,
+    transaction: {
+      id: raw.id,
+      date: raw.date,
+      description: raw.description,
+      category: raw.category,
+      amount: result.value,
+      confidence: raw.confidence,
+      customerId: raw.customerId,
+    },
+  };
+}
+
+/** Batch ingest — e.g. a Plaid sync returning many rows at once. */
+export function ingestTransactions(rows: readonly RawTransaction[]): IngestResult {
+  const accepted: Transaction[] = [];
+  const rejected: RejectedTransaction[] = [];
+  for (const row of rows) {
+    const out = ingestTransaction(row);
+    if (out.ok) accepted.push(out.transaction);
+    else rejected.push(out.rejection);
+  }
+  return { accepted, rejected };
+}
