+import { test, expect } from "@playwright/test";
+
+import { normalizeTokens, normalizeForDisplay } from "@/features/customers";
+
+// Pure-logic unit tests for the token-set normalizer that underpins the
+// deterministic (step-1) identity-resolution layer. No browser / page is used —
+// these import the functions directly and assert on their behavior. Written in
+// @playwright/test to match the project's existing runner (see
+// playwright.config.ts) rather than introducing a second test framework.
+//
+// The contract under test: any two strings that should be considered the same
+// customer at the deterministic level must produce an equal token Set.
+
+const tokens = (s: string) => Array.from(normalizeTokens(s)).sort();
+
+test.describe("normalizeTokens — basic tokenization", () => {
+  test("lowercases and splits on whitespace", () => {
+    expect(tokens("Marina Pool")).toEqual(["marina", "pool"]);
+  });
+
+  test("collapses runs of whitespace and trims", () => {
+    expect(tokens("  Marina   Pool  ")).toEqual(["marina", "pool"]);
+  });
+
+  test("returns an empty Set for an empty string", () => {
+    expect(normalizeTokens("").size).toBe(0);
+  });
+
+  test("returns an empty Set for a whitespace-only string", () => {
+    expect(normalizeTokens("   ").size).toBe(0);
+  });
+
+  test("dedupes repeated tokens (it is a Set)", () => {
+    expect(normalizeTokens("pool pool pool").size).toBe(1);
+  });
+});
+
+test.describe("normalizeTokens — punctuation handling", () => {
+  test("strips punctuation, treating it as a separator", () => {
+    expect(tokens("Marina Pool & Spa Co.")).toEqual(["marina", "pool", "spa"]);
+  });
+
+  test("punctuation between letters splits rather than joins", () => {
+    // "spa/pool" must not become the single token "spapool".
+    expect(tokens("spa/pool")).toEqual(["pool", "spa"]);
+  });
+
+  test("hyphenated names split into separate tokens", () => {
+    expect(tokens("Smith-Jones")).toEqual(["jones", "smith"]);
+  });
+
+  test("a string of only punctuation yields an empty Set", () => {
+    expect(normalizeTokens(".,;:!?-_*").size).toBe(0);
+  });
+});
+
+test.describe("normalizeTokens — stopwords & legal suffixes", () => {
+  test("drops articles and conjunctions", () => {
+    expect(tokens("The Pool and Spa of Marina")).toEqual([
+      "marina",
+      "pool",
+      "spa",
+    ]);
+  });
+
+  test("drops the standalone ampersand stopword", () => {
+    expect(normalizeTokens("&").size).toBe(0);
+  });
+
+  test.describe("legal-suffix equivalence (the documented contract)", () => {
+    // "Marina Pool & Spa Co." and "Marina Pool & Spa" must collapse to the
+    // same token set so the resolver treats them as one customer.
+    const expected = ["marina", "pool", "spa"];
+    for (const suffix of [
+      "Co.",
+      "Company",
+      "Inc",
+      "Incorporated",
+      "LLC",
+      "Ltd",
+      "Limited",
+      "Corp",
+      "Corporation",
+    ]) {
+      test(`"${suffix}" is dropped`, () => {
+        expect(tokens(`Marina Pool & Spa ${suffix}`)).toEqual(expected);
+      });
+    }
+  });
+});
+
+test.describe("normalizeTokens — single-character noise", () => {
+  test("drops single-character tokens", () => {
+    expect(normalizeTokens("a b c").size).toBe(0);
+  });
+
+  test("keeps a two-character token", () => {
+    expect(tokens("Hi Pool")).toEqual(["hi", "pool"]);
+  });
+
+  test("a single-letter initial is dropped but the surname is kept", () => {
+    expect(tokens("J Smith")).toEqual(["smith"]);
+  });
+});
+
+test.describe("normalizeTokens — equivalence invariant", () => {
+  test("equivalent names produce equal Sets", () => {
+    const a = normalizeTokens("Marina Pool & Spa Co.");
+    const b = normalizeTokens("the marina  pool spa");
+    expect(Array.from(a).sort()).toEqual(Array.from(b).sort());
+  });
+
+  test("distinct names produce different Sets", () => {
+    const a = normalizeTokens("Marina Pool");
+    const b = normalizeTokens("Lakeside Pool");
+    expect(Array.from(a).sort()).not.toEqual(Array.from(b).sort());
+  });
+});
+
+test.describe("normalizeForDisplay", () => {
+  test("joins the normalized tokens with single spaces", () => {
+    expect(normalizeForDisplay("The Marina Pool Co.")).toBe("marina pool");
+  });
+
+  test("returns an empty string for input that normalizes to nothing", () => {
+    expect(normalizeForDisplay("the & of a")).toBe("");
+  });
+
+  test("returns an empty string for empty input", () => {
+    expect(normalizeForDisplay("")).toBe("");
+  });
+});
