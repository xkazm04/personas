@@ -0,0 +1,89 @@
+// Unit tests for currency-aware banker's rounding.
+//
+// Runner: Node's built-in test runner via the tsx loader. Run the whole suite
+// with `npm test` (globs src/**/*.test.ts), or this file alone with:
+//   npx tsx --test ./src/features/ledger/lib/round.test.ts
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { DEFAULT_MINOR_UNITS, minorUnits, roundMoney } from "./round";
+
+test("rounds half to even at the .005 boundary (USD)", () => {
+  // 0 is even → down; 2 is even → 0.015 rounds up to 0.02.
+  assert.equal(roundMoney(0.005, "USD"), 0.0);
+  assert.equal(roundMoney(0.015, "USD"), 0.02);
+  assert.equal(roundMoney(0.025, "USD"), 0.02);
+  assert.equal(roundMoney(0.035, "USD"), 0.04);
+});
+
+test("rounds the classic 2.675 half-even case", () => {
+  assert.equal(roundMoney(2.675, "USD"), 2.68);
+});
+
+test("handles negative values symmetrically (half to even)", () => {
+  assert.equal(roundMoney(-0.005, "USD"), 0.0);
+  assert.equal(roundMoney(-0.015, "USD"), -0.02);
+  assert.equal(roundMoney(-2.675, "USD"), -2.68);
+});
+
+test("leaves already-rounded and ordinary (non-tie) values intact", () => {
+  assert.equal(roundMoney(184.22, "USD"), 184.22);
+  assert.equal(roundMoney(1.014, "USD"), 1.01);
+  assert.equal(roundMoney(1.016, "USD"), 1.02);
+});
+
+test("treats zero (and -0) as 0", () => {
+  assert.equal(roundMoney(0, "USD"), 0);
+  assert.equal(Object.is(roundMoney(-0.001, "USD"), -0), false);
+  assert.equal(roundMoney(-0.001, "USD"), 0);
+});
+
+test("respects zero-decimal currencies (JPY)", () => {
+  assert.equal(roundMoney(1234.5, "JPY"), 1234); // .5 → even 1234
+  assert.equal(roundMoney(1235.5, "JPY"), 1236); // .5 → even 1236
+  assert.equal(roundMoney(1234.4, "JPY"), 1234);
+  assert.equal(roundMoney(1234.6, "JPY"), 1235);
+});
+
+test("respects three-decimal currencies (BHD)", () => {
+  assert.equal(roundMoney(1.2345, "BHD"), 1.234); // .5 at 4th dp → even 4
+  assert.equal(roundMoney(1.2355, "BHD"), 1.236); // → even 6
+  assert.equal(roundMoney(1.2349, "BHD"), 1.235);
+});
+
+test("is case-insensitive on the currency code and falls back to 2dp", () => {
+  assert.equal(roundMoney(9.005, "usd"), 9.0);
+  assert.equal(roundMoney(9.015, "Eur"), 9.02);
+  // Unknown code → DEFAULT_MINOR_UNITS (2).
+  assert.equal(roundMoney(9.015, "XTS"), 9.02);
+});
+
+test("handles very large finite values within safe-integer range", () => {
+  assert.equal(roundMoney(999_999_999.994, "USD"), 999_999_999.99);
+  assert.equal(roundMoney(123_456_789.015, "USD"), 123_456_789.02);
+});
+
+test("handles very small magnitudes", () => {
+  assert.equal(roundMoney(0.004, "USD"), 0.0);
+  assert.equal(roundMoney(0.006, "USD"), 0.01);
+});
+
+test("rejects NaN and Infinity rather than propagating them", () => {
+  assert.throws(() => roundMoney(NaN, "USD"), RangeError);
+  assert.throws(() => roundMoney(Infinity, "USD"), RangeError);
+  assert.throws(() => roundMoney(-Infinity, "USD"), RangeError);
+  // @ts-expect-error — exercising the runtime guard against non-number input.
+  assert.throws(() => roundMoney("12.34", "USD"), RangeError);
+});
+
+test("rejects a blank/invalid currency code", () => {
+  assert.throws(() => roundMoney(1.23, ""), RangeError);
+  assert.throws(() => roundMoney(1.23, "   "), RangeError);
+});
+
+test("minorUnits resolves known, unknown, and default codes", () => {
+  assert.equal(minorUnits("USD"), 2);
+  assert.equal(minorUnits("JPY"), 0);
+  assert.equal(minorUnits("BHD"), 3);
+  assert.equal(minorUnits("ZZZ"), DEFAULT_MINOR_UNITS);
+});
