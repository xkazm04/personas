diff --git a/src/features/rankings/rank.test.ts b/src/features/rankings/rank.test.ts
new file mode 100644
index 0000000..45369a4
--- /dev/null
+++ b/src/features/rankings/rank.test.ts
@@ -0,0 +1,45 @@
+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { rankDelta, formatRankDelta } from "./rank";
+
+test("rankDelta: improvement (now closer to 1) is 'up' with positive magnitude", () => {
+  assert.deepEqual(rankDelta(5, 2), { direction: "up", magnitude: 3 });
+});
+
+test("rankDelta: drop (now further from 1) is 'down' with positive magnitude", () => {
+  assert.deepEqual(rankDelta(2, 5), { direction: "down", magnitude: 3 });
+});
+
+test("rankDelta: no change is 'flat' with zero magnitude", () => {
+  assert.deepEqual(rankDelta(4, 4), { direction: "flat", magnitude: 0 });
+});
+
+test("rankDelta: large swings keep full magnitude", () => {
+  assert.deepEqual(rankDelta(100, 1), { direction: "up", magnitude: 99 });
+  assert.deepEqual(rankDelta(1, 100), { direction: "down", magnitude: 99 });
+});
+
+test("rankDelta: non-finite inputs degrade to flat/0 (no garbage)", () => {
+  assert.deepEqual(rankDelta(NaN, 3), { direction: "flat", magnitude: 0 });
+  assert.deepEqual(rankDelta(3, NaN), { direction: "flat", magnitude: 0 });
+  assert.deepEqual(rankDelta(Infinity, 3), { direction: "flat", magnitude: 0 });
+});
+
+test("formatRankDelta: improvement renders '↑ N'", () => {
+  assert.equal(formatRankDelta({ direction: "up", magnitude: 3 }), "↑ 3");
+});
+
+test("formatRankDelta: flat renders the em-dash marker", () => {
+  assert.equal(formatRankDelta({ direction: "flat", magnitude: 0 }), "—");
+});
+
+// Regression guard for the original defect: drops must NOT collapse to "—".
+test("formatRankDelta: drops render '↓ N' and never collapse to '—'", () => {
+  const rendered = formatRankDelta(rankDelta(2, 5));
+  assert.equal(rendered, "↓ 3");
+  assert.notEqual(rendered, "—");
+});
+
+test("formatRankDelta: a real down-move is visually distinct from no-change", () => {
+  assert.notEqual(formatRankDelta(rankDelta(2, 5)), formatRankDelta(rankDelta(4, 4)));
+});
diff --git a/src/features/rankings/rank.ts b/src/features/rankings/rank.ts
new file mode 100644
index 0000000..1f54670
--- /dev/null
+++ b/src/features/rankings/rank.ts
@@ -0,0 +1,43 @@
+// Pure rank-delta computation extracted from KeywordTable.
+// Ranking is "lower is better" (rank 1 beats rank 5), so an improvement
+// means the current position `now` is a smaller number than the previous `prev`.
+
+export type RankDirection = "up" | "down" | "flat";
+
+export interface RankDelta {
+  /** "up" = improved (moved toward 1), "down" = lost rank, "flat" = no change. */
+  direction: RankDirection;
+  /** Absolute number of positions moved (always >= 0). */
+  magnitude: number;
+}
+
+/**
+ * Compute the directional rank change between a previous and current position.
+ * Non-finite inputs (NaN, Infinity) are treated as "flat"/0 so callers can
+ * never render garbage.
+ */
+export function rankDelta(prev: number, now: number): RankDelta {
+  if (!Number.isFinite(prev) || !Number.isFinite(now)) {
+    return { direction: "flat", magnitude: 0 };
+  }
+  const change = prev - now; // positive => moved up the rankings
+  if (change > 0) return { direction: "up", magnitude: change };
+  if (change < 0) return { direction: "down", magnitude: -change };
+  return { direction: "flat", magnitude: 0 };
+}
+
+/**
+ * Human-readable label for a rank delta. Drops render distinctly ("↓ N")
+ * instead of collapsing into the no-change marker — that collapse was a
+ * real correctness defect in the original inline logic.
+ */
+export function formatRankDelta(delta: RankDelta): string {
+  switch (delta.direction) {
+    case "up":
+      return `↑ ${delta.magnitude}`;
+    case "down":
+      return `↓ ${delta.magnitude}`;
+    case "flat":
+      return "—";
+  }
+}
diff --git a/src/lib/format.test.ts b/src/lib/format.test.ts
new file mode 100644
index 0000000..0b83758
--- /dev/null
+++ b/src/lib/format.test.ts
@@ -0,0 +1,94 @@
+import { test } from "node:test";
+import assert from "node:assert/strict";
+import {
+  formatCurrency,
+  formatSignedCurrency,
+  formatNumber,
+  formatPercent,
+} from "./format";
+
+// ── formatCurrency ────────────────────────────────────────────────────────
+test("formatCurrency: two-decimal default", () => {
+  assert.equal(formatCurrency(1234.5), "$1,234.50");
+});
+
+test("formatCurrency: half-expand rounding (1.005 -> $1.01)", () => {
+  assert.equal(formatCurrency(1.005), "$1.01");
+});
+
+test("formatCurrency: decimals=false rounds to whole dollars", () => {
+  assert.equal(formatCurrency(1234.5, false), "$1,235");
+});
+
+test("formatCurrency: zero", () => {
+  assert.equal(formatCurrency(0), "$0.00");
+});
+
+test("formatCurrency: negative keeps Intl's own sign placement", () => {
+  assert.equal(formatCurrency(-50), "-$50.00");
+});
+
+test("formatCurrency: very large value keeps grouping", () => {
+  assert.equal(formatCurrency(1234567.89), "$1,234,567.89");
+});
+
+test("formatCurrency: NaN leaks as $NaN (pinned, unguarded by design)", () => {
+  assert.equal(formatCurrency(NaN), "$NaN");
+});
+
+// ── formatSignedCurrency ────────────────────────────────────────────────────
+test("formatSignedCurrency: positive gets a leading '+'", () => {
+  assert.equal(formatSignedCurrency(1234.5), "+$1,234.50");
+});
+
+test("formatSignedCurrency: negative uses the TYPOGRAPHIC minus U+2212, not ASCII '-'", () => {
+  const out = formatSignedCurrency(-1234.5);
+  assert.equal(out, "−$1,234.50");
+  assert.ok(out.includes("−"), "expected U+2212 minus sign");
+  assert.ok(!out.includes("-"), "must NOT contain an ASCII hyphen-minus");
+});
+
+test("formatSignedCurrency: zero has no sign", () => {
+  assert.equal(formatSignedCurrency(0), "$0.00");
+});
+
+test("formatSignedCurrency: negative zero is treated as zero (no sign)", () => {
+  assert.equal(formatSignedCurrency(-0), "$0.00");
+});
+
+test("formatSignedCurrency: very large negative value", () => {
+  assert.equal(formatSignedCurrency(-1234567.89), "−$1,234,567.89");
+});
+
+test("formatSignedCurrency: NaN has no sign (NaN > 0 and NaN < 0 both false)", () => {
+  // value is neither > 0 nor < 0, so sign is "", and abs(NaN) formats as $NaN.
+  assert.equal(formatSignedCurrency(NaN), "$NaN");
+});
+
+// ── formatNumber ────────────────────────────────────────────────────────────
+test("formatNumber: thousands grouping", () => {
+  assert.equal(formatNumber(1234567), "1,234,567");
+});
+
+test("formatNumber: zero and negative", () => {
+  assert.equal(formatNumber(0), "0");
+  assert.equal(formatNumber(-42), "-42");
+});
+
+// ── formatPercent ─────────────────────────────────────────────────────────
+test("formatPercent: default zero decimals rounds", () => {
+  assert.equal(formatPercent(12.6), "13%");
+});
+
+test("formatPercent: explicit decimals", () => {
+  assert.equal(formatPercent(12.345, 1), "12.3%");
+});
+
+test("formatPercent: negative and zero", () => {
+  assert.equal(formatPercent(-5), "-5%");
+  assert.equal(formatPercent(0), "0%");
+});
+
+test("formatPercent: NaN leaks as NaN% (pinned, unguarded by design)", () => {
+  assert.equal(formatPercent(NaN), "NaN%");
+});

