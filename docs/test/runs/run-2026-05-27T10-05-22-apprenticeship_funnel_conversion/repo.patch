+++ b/src/features/placements/lib/conversion.test.ts
+import assert from "node:assert/strict";
+import { test } from "node:test";
+
+import type { FunnelStage } from "../types";
+import { computeFunnelConversion } from "./conversion.ts";
+
+test("empty funnel returns no stages and 0% overall", () => {
+  const result = computeFunnelConversion([]);
+  assert.deepEqual(result.stages, []);
+  assert.equal(result.overallPct, 0);
+});
+
+test("first stage has null stepPct and 100% overall", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 1000 },
+    { stage: "Hired", count: 100 },
+  ];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+
+  assert.equal(stages[0].stepPct, null);
+  assert.equal(stages[0].overallPct, 100);
+  assert.equal(stages[1].stepPct, 10);
+  assert.equal(stages[1].overallPct, 10);
+  assert.equal(overallPct, 10);
+});
+
+test("zero top-of-funnel count never produces NaN/Infinity", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 0 },
+    { stage: "Hired", count: 0 },
+  ];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+
+  assert.equal(stages[0].overallPct, 0);
+  assert.equal(stages[1].stepPct, 0);
+  assert.equal(stages[1].overallPct, 0);
+  assert.equal(overallPct, 0);
+  for (const s of stages) {
+    assert.ok(Number.isFinite(s.overallPct));
+    assert.ok(s.stepPct === null || Number.isFinite(s.stepPct));
+  }
+});
+
+test("a mid-funnel zero does not break later stages", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 500 },
+    { stage: "Replied", count: 0 },
+    { stage: "Hired", count: 0 },
+  ];
+  const { stages } = computeFunnelConversion(funnel);
+
+  assert.equal(stages[1].stepPct, 0); // 0 / 500
+  assert.equal(stages[2].stepPct, 0); // 0 / 0 → guarded to 0
+  assert.ok(Number.isFinite(stages[2].stepPct as number));
+});
+
+test("later stage exceeding earlier is clamped to 100%", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 100 },
+    { stage: "Replied", count: 250 }, // dirty data: more than sourced
+    { stage: "Hired", count: 80 },
+  ];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+
+  assert.equal(stages[1].stepPct, 100); // 250/100 → clamped
+  assert.equal(stages[1].overallPct, 100); // 250/100 → clamped
+  assert.equal(overallPct, 80); // 80/100, unaffected
+});
+
+test("single-stage funnel reports 100% overall", () => {
+  const result = computeFunnelConversion([{ stage: "Sourced", count: 42 }]);
+  assert.equal(result.stages[0].stepPct, null);
+  assert.equal(result.overallPct, 100);
+});
+

