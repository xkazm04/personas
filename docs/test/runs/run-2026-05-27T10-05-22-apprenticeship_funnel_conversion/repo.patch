+++ b/src/features/placements/lib/conversion.ts
+import type { FunnelStage } from "../types";
+
+/**
+ * Per-stage conversion result derived from a funnel.
+ *
+ * All percentages are clamped to the [0, 100] range so the UI never renders a
+ * value above 100% (which can happen when a later stage count exceeds an
+ * earlier one in dirty data) and never receives NaN/Infinity from a divide.
+ */
+export interface StageConversion {
+  stage: string;
+  count: number;
+  /**
+   * Percentage of the immediately preceding stage that reached this stage.
+   * `null` for the first stage, which has no predecessor.
+   */
+  stepPct: number | null;
+  /**
+   * Percentage of the first (top-of-funnel) stage that reached this stage.
+   * Always 100 for the first stage; 0 when the top-of-funnel count is 0.
+   */
+  overallPct: number;
+}
+
+export interface FunnelConversion {
+  stages: StageConversion[];
+  /**
+   * Overall sourced→hired conversion: last stage count / first stage count, as
+   * a percentage. 0 for an empty funnel or a zero top-of-funnel count.
+   */
+  overallPct: number;
+}
+
+/**
+ * Safe percentage: `numerator / denominator * 100`, clamped to [0, 100] and
+ * guaranteed finite. A zero (or negative) denominator yields 0 rather than
+ * NaN/Infinity.
+ */
+function safePct(numerator: number, denominator: number): number {
+  if (denominator <= 0) return 0;
+  const pct = (numerator / denominator) * 100;
+  if (!Number.isFinite(pct)) return 0;
+  return Math.min(100, Math.max(0, pct));
+}
+
+/**
+ * Computes stage-to-stage and overall conversion percentages for a placement
+ * funnel. Pure: no I/O, no mutation of the input.
+ *
+ * Edge cases handled:
+ *  - empty funnel        → `{ stages: [], overallPct: 0 }`
+ *  - zero counts         → conversions resolve to 0 (no division by zero)
+ *  - later stage > earlier (dirty data) → clamped to 100%
+ */
+export function computeFunnelConversion(
+  funnel: readonly FunnelStage[],
+): FunnelConversion {
+  if (funnel.length === 0) {
+    return { stages: [], overallPct: 0 };
+  }
+
+  const topCount = funnel[0].count;
+
+  const stages: StageConversion[] = funnel.map((stage, index) => {
+    if (index === 0) {
+      return {
+        stage: stage.stage,
+        count: stage.count,
+        stepPct: null,
+        overallPct: topCount > 0 ? 100 : 0,
+      };
+    }
+
+    const prevCount = funnel[index - 1].count;
+    return {
+      stage: stage.stage,
+      count: stage.count,
+      stepPct: safePct(stage.count, prevCount),
+      overallPct: safePct(stage.count, topCount),
+    };
+  });
+
+  const lastCount = funnel[funnel.length - 1].count;
+  return {
+    stages,
+    overallPct: safePct(lastCount, topCount),
+  };
+}
+
