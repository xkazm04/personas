+++ b/src/features/rankings/rank.ts
@@ -0,0 +1,40 @@
+// Pure rank-delta logic extracted from KeywordTable so it can be unit-tested
+// in isolation. A keyword's rank improves when `now` is a smaller number than
+// `prev` (rank 3 is better than rank 5), so the signed delta is `prev - now`.
+
+export type RankDirection = "up" | "down" | "flat";
+
+export interface RankDelta {
+  /** Signed change: positive = improved, negative = dropped, 0 = unchanged. */
+  change: number;
+  direction: RankDirection;
+  /** Absolute number of positions moved (always >= 0). */
+  magnitude: number;
+}
+
+/**
+ * Compute the rank movement between a previous and current position.
+ * Non-finite inputs are treated as "no movement" (flat / 0) rather than
+ * propagating NaN into the UI.
+ */
+export function rankDelta(prev: number, now: number): RankDelta {
+  if (!Number.isFinite(prev) || !Number.isFinite(now)) {
+    return { change: 0, direction: "flat", magnitude: 0 };
+  }
+  const change = prev - now;
+  const direction: RankDirection = change > 0 ? "up" : change < 0 ? "down" : "flat";
+  return { change, direction, magnitude: Math.abs(change) };
+}
+
+/**
+ * Human-readable label for a rank movement.
+ *   up   -> "↑ N"
+ *   down -> "↓ N"   (previously collapsed to "—" — the rank-drop defect)
+ *   flat -> "—"
+ */
+export function formatRankDelta(prev: number, now: number): string {
+  const { direction, magnitude } = rankDelta(prev, now);
+  if (direction === "up") return `↑ ${magnitude}`;
+  if (direction === "down") return `↓ ${magnitude}`;
+  return "—";
+}
