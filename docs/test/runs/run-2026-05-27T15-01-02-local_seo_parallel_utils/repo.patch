+++ b/src/lib/num.ts
+/**
+ * Constrain a value to the inclusive range [min, max].
+ *
+ * - ±Infinity inputs snap to the nearest bound.
+ * - A NaN value propagates as NaN (caller's data problem, not ours).
+ * - Invalid bounds (min > max, or a non-finite bound) are a programming
+ *   error and throw RangeError rather than silently misbehaving.
+ */
+export function clamp(value: number, min: number, max: number): number {
+  if (!Number.isFinite(min) || !Number.isFinite(max) || min > max) {
+    throw new RangeError(`clamp: invalid bounds [${min}, ${max}]`);
+  }
+  if (Number.isNaN(value)) return NaN;
+  return Math.min(Math.max(value, min), max);
+}
+
+/**
+ * Round a value to a fixed number of decimal places, correcting for the
+ * binary floating-point error that breaks the naive `value * 10^d / 10^d`
+ * approach (e.g. 1.005 must round to 1.01, not 1.00).
+ *
+ * Implemented via exponential-notation re-parse, which performs the shift
+ * in decimal space.
+ *
+ * - A non-finite value is returned unchanged.
+ * - Negative or non-finite `decimals` is treated as 0.
+ */
+export function roundTo(value: number, decimals: number): number {
+  if (!Number.isFinite(value)) return value;
+  const d = Number.isFinite(decimals) && decimals > 0 ? Math.floor(decimals) : 0;
+  const shifted = Number(`${value}e${d}`);
+  return Number(`${Math.round(shifted)}e-${d}`);
+}
+

