+/**
+ * Truncate text to at most `max` characters, appending `ellipsis` when the
+ * text is shortened. The ellipsis is counted against the budget, so the
+ * returned string is never longer than `max`.
+ *
+ * - Text already within budget is returned unchanged.
+ * - When `max` is too small to fit any content plus the ellipsis, a prefix
+ *   of the ellipsis (or the whole ellipsis) is returned, capped at `max`.
+ */
+export function truncate(text: string, max: number, ellipsis = "…"): string {
+  if (text.length <= max) return text;
+  if (max <= 0) return "";
+  if (max <= ellipsis.length) return ellipsis.slice(0, max);
+  return text.slice(0, max - ellipsis.length) + ellipsis;
+}
+
+/**
+ * Title-case each whitespace-delimited word: first character uppercased,
+ * the remainder lowercased. Original whitespace runs are preserved, so
+ * "hello   world" → "Hello   World" (spacing intact).
+ */
+export function titleCase(text: string): string {
+  return text.replace(
+    /\S+/g,
+    (word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase(),
+  );
+}
