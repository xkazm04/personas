+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { rankDelta, formatRankDelta } from "./rank";
+
+test("rankDelta: improvement (now better than prev) is 'up'", () => {
+  const d = rankDelta(5, 3);
+  assert.equal(d.direction, "up");
+  assert.equal(d.change, 2);
+  assert.equal(d.magnitude, 2);
+});
+
+test("rankDelta: drop (now worse than prev) is 'down' — the defect case", () => {
+  const d = rankDelta(3, 7);
+  assert.equal(d.direction, "down");
+  assert.equal(d.change, -4);
+  assert.equal(d.magnitude, 4);
+});
+
+test("rankDelta: no movement is 'flat'", () => {
+  const d = rankDelta(7, 7);
+  assert.equal(d.direction, "flat");
+  assert.equal(d.change, 0);
+  assert.equal(d.magnitude, 0);
+});
+
+test("rankDelta: non-finite inputs are guarded to flat/0 (no NaN leak)", () => {
+  for (const [p, n] of [
+    [NaN, 3],
+    [5, NaN],
+    [Infinity, 3],
+    [5, -Infinity],
+  ] as const) {
+    const d = rankDelta(p, n);
+    assert.equal(d.direction, "flat");
+    assert.equal(d.change, 0);
+    assert.equal(d.magnitude, 0);
+  }
+});
+
+test("formatRankDelta: up renders '↑ N'", () => {
+  assert.equal(formatRankDelta(5, 3), "↑ 2");
