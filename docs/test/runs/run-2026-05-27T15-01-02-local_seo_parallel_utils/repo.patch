+  assert.equal(out, "Hello w…");
+  assert.equal(out.length, 8);
+});
+
+test("truncate never exceeds max length", () => {
+  for (const max of [1, 3, 5, 7, 9]) {
+    assert.ok(truncate("The quick brown fox", max).length <= max);
+  }
+});
+
+test("truncate with max <= ellipsis length returns a prefix of the ellipsis", () => {
+  assert.equal(truncate("Hello world", 0), "");
+  assert.equal(truncate("Hello world", 1, "..."), ".");
+  assert.equal(truncate("Hello world", 2, "..."), "..".slice(0, 2));
+});
+
+test("truncate honors a custom ellipsis", () => {
+  assert.equal(truncate("Hello world", 8, "..."), "Hello...");
+});
+
+test("titleCase capitalizes each word and lowercases the rest", () => {
+  assert.equal(titleCase("hello world"), "Hello World");
+  assert.equal(titleCase("LOCAL seo AGENCY"), "Local Seo Agency");
+});
+
+test("titleCase preserves original whitespace runs", () => {
+  assert.equal(titleCase("hello   world"), "Hello   World");
+  assert.equal(titleCase("  spaced  out  "), "  Spaced  Out  ");
+});
