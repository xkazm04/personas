+test("formatRankDelta: drop renders '↓ N' (was collapsed to '—' before the fix)", () => {
+  assert.equal(formatRankDelta(3, 7), "↓ 4");
+});
+
+test("formatRankDelta: flat renders '—'", () => {
+  assert.equal(formatRankDelta(7, 7), "—");
+});
+
+test("formatRankDelta: non-finite renders '—'", () => {
+  assert.equal(formatRankDelta(NaN, 3), "—");
+});
