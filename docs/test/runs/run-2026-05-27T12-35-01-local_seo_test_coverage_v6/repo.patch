@@ -0,0 +1,56 @@
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { formatRankDelta, rankDelta } from "./rank";
+
+test("rankDelta: improvement (lower number is better)", () => {
+  assert.deepEqual(rankDelta(5, 3), { direction: "up", magnitude: 2 });
+  assert.deepEqual(rankDelta(11, 6), { direction: "up", magnitude: 5 });
+});
+
+test("rankDelta: drop (higher number is worse) — the previously invisible case", () => {
+  assert.deepEqual(rankDelta(3, 6), { direction: "down", magnitude: 3 });
+  assert.deepEqual(rankDelta(1, 2), { direction: "down", magnitude: 1 });
+});
+
+test("rankDelta: no change is flat", () => {
+  assert.deepEqual(rankDelta(7, 7), { direction: "flat", magnitude: 0 });
+});
+
+test("rankDelta: large swing", () => {
+  assert.deepEqual(rankDelta(100, 1), { direction: "up", magnitude: 99 });
+  assert.deepEqual(rankDelta(1, 100), { direction: "down", magnitude: 99 });
+});
+
+test("rankDelta: non-finite inputs collapse to flat/0", () => {
+  assert.deepEqual(rankDelta(NaN, 3), { direction: "flat", magnitude: 0 });
+  assert.deepEqual(rankDelta(3, NaN), { direction: "flat", magnitude: 0 });
+  assert.deepEqual(rankDelta(Infinity, 3), { direction: "flat", magnitude: 0 });
+});
+
+test("formatRankDelta: improvement renders up glyph", () => {
+  assert.equal(formatRankDelta(rankDelta(5, 3)), "↑ 2");
+});
+
+test("formatRankDelta: DROP renders ↓ glyph, NOT — (the defect fix)", () => {
+  const rendered = formatRankDelta(rankDelta(3, 6));
+  assert.equal(rendered, "↓ 3");
+  assert.notEqual(rendered, "—"); // regression guard: drops must never collapse to no-change
+});
+
+test("formatRankDelta: flat renders em dash", () => {
+  assert.equal(formatRankDelta(rankDelta(7, 7)), "—");
+});
+
+test("rankDelta matches the live mock data (sanity: every row currently improves)", () => {
+  // All six seed rows are improvements; confirm none are silently dropped.
+  const rows: Array<[number, number]> = [
+    [5, 3],
+    [2, 1],
+    [11, 6],
+    [8, 4],
+    [4, 2],
+    [7, 7],
+  ];
+  const directions = rows.map(([p, n]) => rankDelta(p, n).direction);
+  assert.deepEqual(directions, ["up", "up", "up", "up", "up", "flat"]);
+});
diff --git a/src/features/rankings/rank.ts b/src/features/rankings/rank.ts
new file mode 100644
index 0000000..06ee54d
--- /dev/null
+++ b/src/features/rankings/rank.ts
@@ -0,0 +1,50 @@
+// Pure rank-delta computation extracted from KeywordTable so it can be unit-tested
+// and reused. A keyword's rank is a position (1 = best). Moving to a *lower* number
+// is an improvement; moving to a *higher* number is a drop.
+
+export type RankDirection = "up" | "down" | "flat";
+
+export interface RankDelta {
+  /** "up" = improved (rank number decreased), "down" = lost rank, "flat" = no change. */
+  direction: RankDirection;
+  /** Absolute number of positions moved (always >= 0). */
+  magnitude: number;
+}
+
+/**
+ * Compute the rank movement between a previous and current position.
+ *
+ * Lower rank numbers are better, so an improvement is `prev > now`.
+ *   rankDelta(5, 3) -> { direction: "up",   magnitude: 2 }   // climbed 2 spots
+ *   rankDelta(3, 6) -> { direction: "down", magnitude: 3 }   // fell 3 spots
+ *   rankDelta(7, 7) -> { direction: "flat", magnitude: 0 }
+ *
+ * Non-finite inputs (NaN/Infinity) are treated as "flat"/0 so the UI never
+ * renders garbage.
+ */
+export function rankDelta(prev: number, now: number): RankDelta {
+  if (!Number.isFinite(prev) || !Number.isFinite(now)) {
+    return { direction: "flat", magnitude: 0 };
+  }
+  const change = prev - now; // positive = improved
+  if (change > 0) return { direction: "up", magnitude: change };
+  if (change < 0) return { direction: "down", magnitude: -change };
+  return { direction: "flat", magnitude: 0 };
+}
+
+/**
+ * Render a rank delta as the short glyph string shown in the keyword table.
+ *   up   -> "↑ N"
+ *   down -> "↓ N"   (previously collapsed to "—" — a real correctness defect)
+ *   flat -> "—"
+ */
+export function formatRankDelta(delta: RankDelta): string {
+  switch (delta.direction) {
+    case "up":
+      return `↑ ${delta.magnitude}`;
+    case "down":
+      return `↓ ${delta.magnitude}`;
+    case "flat":
+      return "—";
+  }
+}
diff --git a/src/lib/format.test.ts b/src/lib/format.test.ts
new file mode 100644
index 0000000..4940dfd
--- /dev/null
+++ b/src/lib/format.test.ts
@@ -0,0 +1,95 @@
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import {
+  formatCurrency,
+  formatNumber,
+  formatPercent,
+  formatSignedCurrency,
+} from "./format";
+
+// IMPORTANT: formatSignedCurrency uses the typographic MINUS SIGN (U+2212, "−"),
+// NOT the ASCII hyphen-minus ("-"). Tests assert the exact glyph on purpose.
+const MINUS = "−";
+
+test("formatCurrency: standard two-decimal output", () => {
+  assert.equal(formatCurrency(1234.5), "$1,234.50");
+  assert.equal(formatCurrency(0), "$0.00");
+});
+
+test("formatCurrency: negative uses ASCII Intl minus", () => {
+  // Intl currency formatting emits "-$1,234.50" (ASCII hyphen) for negatives.
+  assert.equal(formatCurrency(-1234.5), "-$1,234.50");
+});
+
+test("formatCurrency: decimals=false rounds to whole dollars", () => {
+  assert.equal(formatCurrency(1234.5, false), "$1,235"); // half-expand rounds up
+  assert.equal(formatCurrency(1234.4, false), "$1,234");
+});
+
+test("formatCurrency: half-expand rounding on cents (1.005 -> 1.01)", () => {
+  assert.equal(formatCurrency(1.005), "$1.01");
+});
+
+test("formatCurrency: very large value keeps grouping", () => {
+  assert.equal(formatCurrency(1234567.89), "$1,234,567.89");
+});
+
+test("formatCurrency: NaN leaks through as $NaN (pinned current behavior)", () => {
+  // Documents the UNGUARDED behavior — a NaN reaches the UI as "$NaN".
+  assert.equal(formatCurrency(NaN), "$NaN");
+});
+
+test("formatSignedCurrency: positive gets a plus", () => {
+  assert.equal(formatSignedCurrency(1234.5), "+$1,234.50");
+});
+
+test("formatSignedCurrency: negative uses U+2212 minus, not ASCII hyphen", () => {
+  const out = formatSignedCurrency(-1234.5);
+  assert.equal(out, `${MINUS}$1,234.50`);
+  assert.ok(out.includes(MINUS), "must contain U+2212");
+  assert.ok(!out.includes("-"), "must NOT contain ASCII hyphen-minus");
+});
+
+test("formatSignedCurrency: zero has no sign", () => {
+  assert.equal(formatSignedCurrency(0), "$0.00");
+});
+
+test("formatSignedCurrency: negative zero is treated as zero (no sign)", () => {
+  // -0 > 0 is false and -0 < 0 is false, so no sign; Math.abs(-0) -> 0.
+  assert.equal(formatSignedCurrency(-0), "$0.00");
+});
+
+test("formatSignedCurrency: NaN -> no sign + $NaN (NaN comparisons are false)", () => {
+  assert.equal(formatSignedCurrency(NaN), "$NaN");
+});
+
+test("formatSignedCurrency: very large negative", () => {
+  assert.equal(formatSignedCurrency(-1234567.89), `${MINUS}$1,234,567.89`);
+});
+
+test("formatNumber: groups thousands", () => {
+  assert.equal(formatNumber(1234567), "1,234,567");
+  assert.equal(formatNumber(0), "0");
+});
+
+test("formatNumber: negative", () => {
+  assert.equal(formatNumber(-4200), "-4,200");
+});
+
+test("formatPercent: default zero decimals", () => {
+  assert.equal(formatPercent(78), "78%");
+});
+
+test("formatPercent: explicit decimals + rounding", () => {
+  assert.equal(formatPercent(78.456, 1), "78.5%");
+  assert.equal(formatPercent(78.444, 2), "78.44%");
+});
+
+test("formatPercent: negative and zero", () => {
+  assert.equal(formatPercent(-5), "-5%");
+  assert.equal(formatPercent(0), "0%");
+});
+
+test("formatPercent: NaN leaks through as NaN% (pinned current behavior)", () => {
+  assert.equal(formatPercent(NaN), "NaN%");
+});

