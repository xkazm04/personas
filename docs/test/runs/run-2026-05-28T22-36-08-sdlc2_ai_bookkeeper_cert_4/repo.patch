+"use client";
+
+import { useState } from "react";
+import { AnimatePresence, motion, useReducedMotion } from "framer-motion";
+import { easeLedger } from "@/lib/motion";
+import { type Categorization } from "@/lib/categorize";
+
+// ─────────────────────────────────────────────────────────────────────────
+// Smart categorization panel. The user types an expense description + amount;
+// we POST /api/categorize and the AI (or the deterministic heuristic when no
+// GEMINI_API_KEY is set) returns a double-entry categorization. Renders
+// loading / error / result states in the Ruled Ledger aesthetic, mirroring
+// the T-account framing of the LedgerDemo it sits beside.
+// ─────────────────────────────────────────────────────────────────────────
+
+type Status = "idle" | "loading" | "done" | "error";
+
+const EXAMPLES: ReadonlyArray<{ description: string; amount: number }> = [
+  { description: "Home Depot — replacement filter", amount: -184.22 },
+  { description: "Chevron #4781 fuel", amount: -82.4 },
+  { description: "Verizon Wireless business line", amount: -118.99 },
+  { description: "Marina Pool & Spa — May service", amount: 580 },
+];
+
+function money(n: number) {
+  const sign = n < 0 ? "−" : "+";
+  return `${sign}$${Math.abs(n).toLocaleString("en-US", {
+    minimumFractionDigits: 2,
+    maximumFractionDigits: 2,
+  })}`;
+}
+
+export function CategorizePanel() {
+  const [description, setDescription] = useState("");
+  const [amount, setAmount] = useState("");
+  const [status, setStatus] = useState<Status>("idle");
+  const [result, setResult] = useState<Categorization | null>(null);
+  const [error, setError] = useState<string | null>(null);
+  const reduce = useReducedMotion();
+
+  async function categorize(desc: string, amt: number) {
+    setStatus("loading");
+    setError(null);
+    // Optimistic: keep the previous result visible (dimmed) while the next
+    // one streams in, rather than flashing empty.
+    try {
+      const res = await fetch("/api/categorize", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ description: desc, amount: amt }),
+      });
+      if (!res.ok) {
+        const data = (await res.json().catch(() => null)) as
+          | { error?: string }
+          | null;
+        throw new Error(data?.error ?? `Request failed (${res.status}).`);
+      }
+      const data = (await res.json()) as Categorization;
+      setResult(data);
+      setStatus("done");
+    } catch (err) {
+      setError(err instanceof Error ? err.message : "Something went wrong.");
+      setStatus("error");
+    }
+  }
+
+  function onSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    const amt = Number(amount);
+    if (!description.trim()) {
+      setError("Enter a description.");
+      setStatus("error");
+      return;
+    }
+    if (!Number.isFinite(amt) || amt === 0) {
+      setError("Enter a non-zero dollar amount (negative for an expense).");
+      setStatus("error");
+      return;
+    }
+    void categorize(description.trim(), amt);
+  }
+
+  function applyExample(ex: (typeof EXAMPLES)[number]) {
+    setDescription(ex.description);
+    setAmount(String(ex.amount));
+    void categorize(ex.description, ex.amount);
+  }
+
+  const motionProps = reduce
+    ? { initial: false, animate: { opacity: 1, y: 0 } }
+    : {
+        initial: { opacity: 0, y: 10 },
+        animate: { opacity: 1, y: 0 },
+        exit: { opacity: 0, y: -6 },
+        transition: { duration: 0.45, ease: easeLedger },
+      };
+
+  return (
+    <section
+      aria-labelledby="categorize-heading"
+      className="relative border-b border-rule bg-background bg-rule"
+    >
+      <div className="mx-auto max-w-6xl px-8 py-20">
+        <div className="flex flex-wrap items-end justify-between gap-6">
+          <div>
+            <div className="label-stamp">Chapter II½ · AI</div>
+            <h2
+              id="categorize-heading"
+              className="mt-3 font-display text-4xl font-light tracking-[-0.02em] sm:text-5xl"
+            >
+              <span className="engrave">Categorize an expense.</span>
+            </h2>
+            <p className="mt-4 max-w-md text-[15px] leading-relaxed text-muted-strong">
+              Type what you spent. Our model picks the double-entry accounts,
+              names the category, and tells you how sure it is — the same engine
+              that files your books. Works with or without an API key.
+            </p>
+          </div>
+          <div className="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">
+            Gemini · live categorization
+          </div>
+        </div>
+
+        <div className="mt-10 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
+          {/* Input form */}
+          <form onSubmit={onSubmit} className="space-y-4">
+            <div className="label-stamp mb-2">Enter a transaction</div>
+
+            <label className="block">
+              <span className="mb-1.5 block font-mono text-[10px] uppercase tracking-[0.18em] text-muted">
+                Description
+              </span>
+              <input
+                type="text"
+                value={description}
+                onChange={(e) => setDescription(e.target.value)}
+                placeholder="Home Depot — replacement filter"
+                className="w-full rounded-control border border-rule bg-surface px-4 py-3 text-[14px] text-foreground transition placeholder:text-muted/60 focus-visible:border-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40"
+              />
+            </label>
+
+            <label className="block">
+              <span className="mb-1.5 block font-mono text-[10px] uppercase tracking-[0.18em] text-muted">
+                Amount · negative = expense
+              </span>
+              <input
+                type="number"
+                step="0.01"
+                value={amount}
+                onChange={(e) => setAmount(e.target.value)}
+                placeholder="-184.22"
+                className="w-full rounded-control border border-rule bg-surface px-4 py-3 font-mono text-[14px] tabular-nums text-foreground transition placeholder:text-muted/60 focus-visible:border-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40"
+              />
+            </label>
+
+            <button
+              type="submit"
+              disabled={status === "loading"}
+              className="inline-flex items-center gap-2 rounded-control bg-ink px-5 py-3 text-xs font-semibold uppercase tracking-[0.16em] text-paper transition hover:-translate-y-[1px] hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40 disabled:cursor-not-allowed disabled:opacity-60"
+            >
+              {status === "loading" ? "Categorizing…" : "Categorize"}
+              <span aria-hidden>→</span>
+            </button>
+
+            <div className="pt-2">
+              <div className="mb-2 font-mono text-[10px] uppercase tracking-[0.18em] text-muted">
+                Or try an example
+              </div>
+              <div className="flex flex-wrap gap-2">
+                {EXAMPLES.map((ex) => (
+                  <button
+                    key={ex.description}
+                    type="button"
+                    onClick={() => applyExample(ex)}
+                    className="rounded-pill border border-rule bg-surface px-3 py-1.5 text-[11px] text-muted-strong transition hover:border-ink/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40"
+                  >
+                    {ex.description.split(" — ")[0]} · {money(ex.amount)}
+                  </button>
+                ))}
+              </div>
+            </div>
+          </form>
+
+          {/* Result T-account */}
+          <div className="t-account p-0">
+            <span className="row-tag">T · AI</span>
+
+            <div className="flex items-baseline justify-between border-b border-rule px-6 py-4">
+              <div className="font-mono text-[10px] uppercase tracking-[0.18em] text-muted">
+                Proposed entry
+              </div>
+              <div className="font-mono text-[11px] uppercase tracking-[0.18em] text-muted">
+                {result
+                  ? result.source === "gemini"
+                    ? "via Gemini"
+                    : "via heuristic"
+                  : "awaiting input"}
+              </div>
+            </div>
+
+            <div className="min-h-[260px] px-6 py-5">
+              {status === "idle" && !result && (
+                <div className="flex h-[220px] flex-col items-center justify-center gap-2 text-center">
+                  <div className="font-display text-[18px] italic text-muted-strong">
+                    No entry yet.
+                  </div>
+                  <p className="max-w-xs text-[13px] leading-relaxed text-muted">
+                    Type a description and amount, or pick an example, to see
+                    the proposed debit, credit, and confidence.
+                  </p>
+                </div>
+              )}
+
+              {status === "loading" && (
+                <div
+                  aria-live="polite"
+                  className="space-y-3"
+                  role="status"
+                >
+                  <SkeletonRow />
+                  <SkeletonRow />
+                  <SkeletonRow />
+                  <div className="pt-2 font-mono text-[11px] uppercase tracking-[0.18em] text-muted">
+                    Reading the receipt…
+                  </div>
+                </div>
+              )}
+
+              {status === "error" && (
+                <div
+                  role="alert"
+                  className="flex h-[220px] flex-col items-center justify-center gap-2 text-center"
+                >
+                  <div className="rounded-pill bg-warning-soft px-3 py-0.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-warning">
+                    Couldn&apos;t categorize
+                  </div>
+                  <p className="max-w-xs text-[13px] leading-relaxed text-muted-strong">
+                    {error}
+                  </p>
+                </div>
+              )}
+
+              <AnimatePresence mode="wait">
+                {status === "done" && result && (
+                  <motion.dl
+                    key={result.category + result.rationale}
+                    {...motionProps}
+                    className="space-y-3.5"
+                  >
+                    <Field label="Category" value={result.category} />
+                    <Field label="Debit" value={result.debitAccount} accent />
+                    <Field label="Credit" value={result.creditAccount} />
+                    <div className="flex items-center justify-between border-t border-rule pt-3">
+                      <dt className="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">
+                        Confidence
+                      </dt>
+                      <dd className="flex items-center gap-2">
+                        <span className="h-1.5 w-24 overflow-hidden rounded-pill bg-rule">
+                          <span
+                            className="block h-full bg-accent"
+                            style={{
+                              width: `${Math.round(result.confidence * 100)}%`,
+                            }}
+                          />
+                        </span>
+                        <span className="font-mono text-[13px] font-semibold tabular-nums text-foreground">
+                          {Math.round(result.confidence * 100)}%
+                        </span>
+                      </dd>
+                    </div>
+                    <p className="border-t-2 border-double border-ink pt-3 font-display text-[14px] italic leading-snug text-muted-strong">
+                      {result.rationale}
+                    </p>
+                  </motion.dl>
+                )}
+              </AnimatePresence>
+            </div>
+          </div>
+        </div>
+      </div>
+    </section>
+  );
+}
+
+function Field({
+  label,
+  value,
+  accent,
+}: {
+  label: string;
+  value: string;
+  accent?: boolean;
+}) {
+  return (
+    <div className="flex items-baseline justify-between gap-4">
+      <dt className="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">
+        {label}
+      </dt>
+      <dd
+        className={
+          "text-right text-[14px] font-medium " +
+          (accent ? "text-accent" : "text-foreground")
+        }
+      >
+        {value}
+      </dd>
+    </div>
+  );
+}
+
+function SkeletonRow() {
+  return (
+    <div className="flex items-center justify-between gap-4">
+      <span className="h-2.5 w-20 animate-pulse rounded-pill bg-rule" />
+      <span className="h-2.5 w-32 animate-pulse rounded-pill bg-rule" />
+    </div>
+  );
+}
