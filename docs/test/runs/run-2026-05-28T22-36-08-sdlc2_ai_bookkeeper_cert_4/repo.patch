+  CONFIDENCE_REVIEW_THRESHOLD,
+  transactions as mockTransactions,
+} from "@/features/ledger/data";
+import { type Transaction } from "@/features/ledger/types";
+
+export { CONFIDENCE_REVIEW_THRESHOLD };
+export type { Transaction };
+
+/** Every ledger transaction for the current operator, newest-first as stored. */
+export async function getTransactions(): Promise<Transaction[]> {
+  return mockTransactions;
+}
+
+/** A single transaction by id, or undefined if it isn't in the ledger. */
+export async function getTransactionById(
+  id: string,
+): Promise<Transaction | undefined> {
+  return mockTransactions.find((t) => t.id === id);
+}
+
+// ── Pure aggregation helpers ──────────────────────────────────────────────
+// These are exported separately from the async fetchers so they stay unit-
+// testable in isolation (no I/O, no clock, no env). The async layer composes
+// them; the UI can also call them on an already-fetched list.
+
+/** Income (positive amounts) minus expenses (negative). Sums the signed value. */
+export function netTotal(txns: readonly Transaction[]): number {
+  return txns.reduce((sum, t) => sum + t.amount, 0);
+}
+
+/** Total income — sum of positive (credit) amounts only. */
+export function totalIncome(txns: readonly Transaction[]): number {
+  return txns.reduce((sum, t) => (t.amount > 0 ? sum + t.amount : sum), 0);
+}
+
+/** Total expense as a positive magnitude — sum of |negative amounts|. */
+export function totalExpense(txns: readonly Transaction[]): number {
+  return txns.reduce((sum, t) => (t.amount < 0 ? sum - t.amount : sum), 0);
+}
+
+/** Count of rows below the AI-confidence review threshold (need human eyes). */
+export function pendingReviewCount(
+  txns: readonly Transaction[],
+  threshold: number = CONFIDENCE_REVIEW_THRESHOLD,
+): number {
+  return txns.reduce((n, t) => (t.confidence < threshold ? n + 1 : n), 0);
+}
