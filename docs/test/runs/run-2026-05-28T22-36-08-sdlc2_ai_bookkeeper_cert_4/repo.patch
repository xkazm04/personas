@@ -0,0 +1,108 @@
+// Unit tests for the trial-balance verifier.
+//
+// Runner: Node's built-in test runner via the tsx loader. Run the whole suite
+// with `npm test` (globs src/**/*.test.ts), or this file alone with:
+//   npx tsx --test ./src/features/ledger/lib/trial-balance.test.ts
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { MoneyArithmeticError } from "./arithmetic";
+import {
+  type TrialBalanceEntry,
+  isBalanced,
+  verifyTrialBalance,
+} from "./trial-balance";
+
+test("balanced trivial: equal single debit and credit", () => {
+  const entries: TrialBalanceEntry[] = [
+    { account: "cash", currency: "USD", debit: 100 },
+    { account: "rev", currency: "USD", credit: 100 },
+  ];
+  assert.equal(isBalanced(entries), true);
+  assert.equal(verifyTrialBalance(entries).balanced, true);
+});
+
+test("balanced via integer-precision recovery (0.10 + 0.20 vs 0.30)", () => {
+  // The whole point of folding through addMoney: no 0.30000000000000004 drift.
+  const entries: TrialBalanceEntry[] = [
+    { account: "a", currency: "USD", debit: 0.1 },
+    { account: "b", currency: "USD", debit: 0.2 },
+    { account: "rev", currency: "USD", credit: 0.3 },
+  ];
+  assert.equal(isBalanced(entries), true);
+  const result = verifyTrialBalance(entries);
+  assert.equal(result.balanced, true);
+  assert.equal(result.totalDebits, 0.3);
+  assert.equal(result.difference, 0);
+});
+
+test("unbalanced: difference is reported", () => {
+  const entries: TrialBalanceEntry[] = [
+    { account: "cash", currency: "USD", debit: 100 },
+    { account: "rev", currency: "USD", credit: 90 },
+  ];
+  assert.equal(isBalanced(entries), false);
+  const result = verifyTrialBalance(entries);
+  assert.equal(result.balanced, false);
+  assert.equal(result.difference, 10);
+});
+
+test("empty entries: balanced with zero totals", () => {
+  assert.equal(isBalanced([]), true);
+  const result = verifyTrialBalance([]);
+  assert.deepEqual(result, {
+    balanced: true,
+    totalDebits: 0,
+    totalCredits: 0,
+    difference: 0,
+    asymmetricAccounts: [],
+  });
+});
+
+test("single-side accounts surface in asymmetricAccounts (sorted), both-sided do not", () => {
+  const entries: TrialBalanceEntry[] = [
+    { account: "zeta-debit-only", currency: "USD", debit: 50 },
+    { account: "alpha-credit-only", currency: "USD", credit: 30 },
+    { account: "both", currency: "USD", debit: 20 },
+    { account: "both", currency: "USD", credit: 20 },
+  ];
+  const result = verifyTrialBalance(entries);
+  assert.deepEqual(result.asymmetricAccounts, [
+    "alpha-credit-only",
+    "zeta-debit-only",
+  ]);
+});
+
+test("non-finite debit/credit throws MoneyArithmeticError code not-finite", () => {
+  assert.throws(
+    () => isBalanced([{ account: "x", currency: "USD", debit: NaN }]),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "not-finite",
+  );
+  assert.throws(
+    () =>
+      verifyTrialBalance([
+        { account: "x", currency: "USD", debit: 10 },
+        { account: "y", currency: "USD", credit: Infinity },
+      ]),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "not-finite",
+  );
+});
+
+test("mixed currency throws MoneyArithmeticError code mixed-currency", () => {
+  const entries: TrialBalanceEntry[] = [
+    { account: "cash", currency: "USD", debit: 100 },
+    { account: "rev", currency: "EUR", credit: 100 },
+  ];
+  assert.throws(
+    () => isBalanced(entries),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "mixed-currency",
+  );
+  assert.throws(
+    () => verifyTrialBalance(entries),
+    (err: unknown) =>
+      err instanceof MoneyArithmeticError && err.code === "mixed-currency",
+  );
+});
diff --git a/src/features/ledger/lib/trial-balance.ts b/src/features/ledger/lib/trial-balance.ts
new file mode 100644
index 0000000..89adae1
--- /dev/null
+++ b/src/features/ledger/lib/trial-balance.ts
@@ -0,0 +1,141 @@
+// Trial-balance verification for double-entry ledger rows.
+//
+// A trial balance is the bookkeeping check that the sum of all debit entries
+// equals the sum of all credit entries. The arithmetic here is *not* re-derived:
+// debit and credit totals are folded with `addMoney` and their difference taken
+// with `subtractMoney` (ADR 0003), so the balance decision runs through the same
+// integer-minor-unit / half-even path (ADR 0002) that produces stored totals —
+// `0.10 + 0.20` debits vs a `0.30` credit reads as balanced, not as float drift.
+//
+// Corrupt-value and mixed-currency rejection is inherited wholesale from
+// `MoneyArithmeticError`: a non-finite debit/credit surfaces as code
+// `not-finite`, and rows carrying different currencies surface as
+// `mixed-currency` — there is deliberately no new error type here (single source
+// of truth, cf. ADR 0003).
+//
+// Pure, side-effect-free, fail-loud — matching the rest of `lib/`.
+
+import { type CurrencyCode } from "./round";
+import { MoneyArithmeticError, addMoney, subtractMoney } from "./arithmetic";
+
+/** One row of a double-entry trial balance. A missing `debit`/`credit` is `0`. */
+export interface TrialBalanceEntry {
+  account: string;
+  currency: CurrencyCode;
+  debit?: number;
+  credit?: number;
+}
+
+/** Inspection record produced by `verifyTrialBalance`. */
+export interface TrialBalanceResult {
+  /** `totalDebits === totalCredits`. */
+  balanced: boolean;
+  /** `addMoney` fold of every row's debit. */
+  totalDebits: number;
+  /** `addMoney` fold of every row's credit. */
+  totalCredits: number;
+  /** `subtractMoney(totalDebits, totalCredits)` — signed drift, 0 when balanced. */
+  difference: number;
+  /** Accounts active on exactly one side (debit-only or credit-only); sorted, unique. */
+  asymmetricAccounts: string[];
+}
+
+/**
+ * Resolve the single currency shared by every row, or throw. The shared currency
+ * is what `addMoney`/`subtractMoney` operate in; passing per-row values tagged
+ * with their own currency into that arithmetic is what makes a mixed-currency
+ * row fail loud via `MoneyArithmeticError('mixed-currency')`.
+ *
+ * Caller must guard against an empty list before calling (there is no currency
+ * to resolve, and an empty trial balance is vacuously balanced).
+ */
+function resolveCurrency(entries: TrialBalanceEntry[]): CurrencyCode {
+  const currency = entries[0].currency;
+  for (const entry of entries) {
+    if (entry.currency !== currency) {
+      throw new MoneyArithmeticError(
+        "mixed-currency",
+        `Trial balance mixes currencies: row for account ` +
+          `${String(entry.account)} is ${String(entry.currency)}, ` +
+          `expected ${String(currency)}.`,
+      );
+    }
+  }
+  return currency;
+}
+
+/**
+ * True when total debits equal total credits at the currency's minor-unit
+ * precision. Empty input is balanced (`0 === 0`).
+ *
+ * @throws MoneyArithmeticError `mixed-currency` if rows carry differing
+ *   currencies; `not-finite` if any `debit`/`credit` is non-finite.
+ */
+export function isBalanced(entries: TrialBalanceEntry[]): boolean {
+  if (entries.length === 0) return true;
+  const currency = resolveCurrency(entries);
+
+  let totalDebits = 0;
+  let totalCredits = 0;
+  for (const entry of entries) {
+    totalDebits = addMoney(totalDebits, entry.debit ?? 0, currency);
+    totalCredits = addMoney(totalCredits, entry.credit ?? 0, currency);
+  }
+  return totalDebits === totalCredits;
+}
+
+/**
+ * Full inspection of a trial balance: signed difference plus the accounts that
+ * are active on exactly one side. Empty input returns the balanced zero record.
+ *
+ * @throws MoneyArithmeticError `mixed-currency` / `not-finite` — same contract
+ *   as `isBalanced`.
+ */
+export function verifyTrialBalance(
+  entries: TrialBalanceEntry[],
+): TrialBalanceResult {
+  if (entries.length === 0) {
+    return {
+      balanced: true,
+      totalDebits: 0,
+      totalCredits: 0,
+      difference: 0,
+      asymmetricAccounts: [],
+    };
+  }
+  const currency = resolveCurrency(entries);
+
+  let totalDebits = 0;
+  let totalCredits = 0;
+  // Per-account side sums, in first-seen order; values folded via addMoney.
+  const perAccount = new Map<string, { debit: number; credit: number }>();
+
+  for (const entry of entries) {
+    const debit = entry.debit ?? 0;
+    const credit = entry.credit ?? 0;
+    totalDebits = addMoney(totalDebits, debit, currency);
+    totalCredits = addMoney(totalCredits, credit, currency);
+
+    const sums = perAccount.get(entry.account) ?? { debit: 0, credit: 0 };
+    sums.debit = addMoney(sums.debit, debit, currency);
+    sums.credit = addMoney(sums.credit, credit, currency);
+    perAccount.set(entry.account, sums);
+  }
+
+  const asymmetricAccounts: string[] = [];
+  for (const [account, sums] of perAccount) {
+    // Asymmetric: exactly one side is zero and the other is non-zero.
+    if ((sums.debit === 0) !== (sums.credit === 0)) {
+      asymmetricAccounts.push(account);
+    }
+  }
+  asymmetricAccounts.sort();
+
+  return {
+    balanced: totalDebits === totalCredits,
+    totalDebits,
+    totalCredits,
+    difference: subtractMoney(totalDebits, totalCredits, currency),
+    asymmetricAccounts,
+  };
+}
