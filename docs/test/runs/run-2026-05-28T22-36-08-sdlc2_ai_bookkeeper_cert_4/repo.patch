@@ -0,0 +1,64 @@
+"use client";
+
+import { create } from "zustand";
+import { persist } from "zustand/middleware";
+
+// Persisted user preferences for the ledger explorer (search/filter/sort).
+// Theme is persisted separately by the inline layout script + ThemeToggle;
+// this store owns the dashboard's view state so a refresh keeps the user's
+// search, direction filter, and sort exactly where they left it.
+//
+// Follows the precedent set by features/customers/store.ts (interface + create,
+// no provider) but adds the `persist` middleware for localStorage durability.
+
+export type DirectionFilter = "all" | "income" | "expense";
+export type SortKey = "date" | "amount" | "confidence";
+export type SortDir = "asc" | "desc";
+
+interface LedgerPrefsState {
+  search: string;
+  direction: DirectionFilter;
+  sortKey: SortKey;
+  sortDir: SortDir;
+  setSearch: (s: string) => void;
+  setDirection: (d: DirectionFilter) => void;
+  /** Set the sort key; clicking the active key flips direction. */
+  toggleSort: (key: SortKey) => void;
+  reset: () => void;
+}
+
+const DEFAULTS = {
+  search: "",
+  direction: "all" as DirectionFilter,
+  sortKey: "date" as SortKey,
+  sortDir: "desc" as SortDir,
+};
+
+export const useLedgerPrefs = create<LedgerPrefsState>()(
+  persist(
+    (set, get) => ({
+      ...DEFAULTS,
+      setSearch: (search) => set({ search }),
+      setDirection: (direction) => set({ direction }),
+      toggleSort: (key) => {
+        const { sortKey, sortDir } = get();
+        if (sortKey === key) {
+          set({ sortDir: sortDir === "asc" ? "desc" : "asc" });
+        } else {
+          set({ sortKey: key, sortDir: "desc" });
+        }
+      },
+      reset: () => set({ ...DEFAULTS }),
+    }),
+    {
+      name: "ledgerline-ledger-prefs",
+      // Only persist the view state, not the action functions.
+      partialize: (s) => ({
+        search: s.search,
+        direction: s.direction,
+        sortKey: s.sortKey,
+        sortDir: s.sortDir,
+      }),
+    },
+  ),
+);
