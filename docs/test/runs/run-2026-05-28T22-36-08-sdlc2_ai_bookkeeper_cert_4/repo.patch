+              }
+            >
+              {d}
+            </button>
+          ))}
+        </div>
+
+        {hasFilters && (
+          <button
+            type="button"
+            onClick={reset}
+            className="font-mono text-[10px] uppercase tracking-[0.14em] text-muted underline decoration-rule-strong underline-offset-4 transition hover:text-foreground"
+          >
+            Clear
+          </button>
+        )}
+      </div>
+
+      {/* Table or empty state */}
+      {rows.length === 0 ? (
+        <div className="flex flex-col items-center justify-center gap-2 px-6 py-16 text-center">
+          <div className="font-display text-[18px] italic text-muted-strong">
+            No matching entries.
+          </div>
+          <p className="max-w-xs text-[13px] leading-relaxed text-muted">
+            {hasFilters
+              ? "No transactions match your search and filter. Try clearing them."
+              : "This ledger is empty."}
+          </p>
+          {hasFilters && (
+            <button
+              type="button"
+              onClick={reset}
+              className="mt-1 rounded-control border border-rule bg-surface px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-muted-strong transition hover:border-ink/40 hover:text-foreground"
+            >
+              Clear filters
+            </button>
+          )}
+        </div>
+      ) : (
+        <div className="overflow-x-auto">
+          <table className="w-full text-sm">
+            <thead>
+              <tr className="border-b border-rule-strong bg-paper/60 text-left font-mono text-[9.5px] uppercase tracking-[0.18em] text-muted">
+                <th className="w-10 px-2 py-2.5 text-center font-semibold">
+                  #
+                </th>
+                <SortableTh
+                  label="Date"
+                  col="date"
+                  active={sortKey === "date"}
+                  dir={sortDir}
+                  onClick={() => toggleSort("date")}
+                />
+                <th className="px-2 py-2.5 font-semibold">Memo</th>
+                <th className="px-2 py-2.5 font-semibold">Category</th>
+                <SortableTh
+                  label="Amount"
+                  col="amount"
+                  active={sortKey === "amount"}
+                  dir={sortDir}
+                  onClick={() => toggleSort("amount")}
+                  align="right"
+                />
+                <SortableTh
+                  label="AI conf."
+                  col="confidence"
+                  active={sortKey === "confidence"}
+                  dir={sortDir}
+                  onClick={() => toggleSort("confidence")}
+                  align="right"
+                />
+              </tr>
+            </thead>
+            <tbody>
+              {rows.map((t, i) => {
+                const positive = t.amount > 0;
+                const lowConfidence = t.confidence < REVIEW_THRESHOLD;
+                const customer = findCustomer(t.customerId);
+                return (
+                  <tr
+                    key={t.id}
+                    className="group border-b border-rule/70 transition hover:bg-paper"
+                  >
+                    <td className="w-10 px-2 py-3 text-center font-mono text-[10px] text-muted/70 numerals">
+                      {String(i + 1).padStart(2, "0")}
+                    </td>
+                    <td className="px-2 py-3 font-mono text-[11.5px] text-muted">
+                      {t.date}
+                    </td>
+                    <td className="px-2 py-3 text-[13.5px] font-medium text-foreground">
+                      {customer ? (
+                        <CustomerBadge customer={customer} />
+                      ) : (
+                        t.description
+                      )}
+                    </td>
+                    <td className="px-2 py-3 text-[12.5px] italic text-muted-strong">
+                      {t.category}
+                    </td>
+                    <td
+                      className={
+                        positive
+                          ? "px-2 py-3 text-right font-mono text-[13px] font-medium tabular-nums text-success"
+                          : "px-2 py-3 text-right font-mono text-[13px] tabular-nums text-foreground"
+                      }
+                    >
+                      {formatSignedCurrency(t.amount)}
+                    </td>
+                    <td className="px-3 py-3 text-right">
+                      <Badge tone={lowConfidence ? "warning" : "success"}>
+                        {t.confidence}%
+                      </Badge>
+                    </td>
+                  </tr>
+                );
+              })}
+            </tbody>
+          </table>
+        </div>
+      )}
+    </div>
+  );
+}
+
+function SortableTh({
+  label,
+  col,
+  active,
+  dir,
+  onClick,
+  align = "left",
+}: {
+  label: string;
+  col: SortKey;
+  active: boolean;
+  dir: "asc" | "desc";
+  onClick: () => void;
+  align?: "left" | "right";
+}) {
+  return (
+    <th
+      className={
+        "px-2 py-2.5 font-semibold " +
+        (align === "right" ? "text-right" : "text-left")
+      }
+    >
+      <button
+        type="button"
+        onClick={onClick}
+        aria-sort={active ? (dir === "asc" ? "ascending" : "descending") : "none"}
+        data-col={col}
+        className={
+          "inline-flex items-center gap-1 font-mono text-[9.5px] uppercase tracking-[0.18em] transition hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40 " +
+          (active ? "text-foreground" : "text-muted")
+        }
+      >
+        {label}
+        <span aria-hidden className="text-[8px]">
+          {active ? (dir === "asc" ? "▲" : "▼") : "↕"}
+        </span>
+      </button>
+    </th>
+  );
+}
