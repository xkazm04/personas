+"use client";
+
+import { useMemo } from "react";
+import { Badge, Button } from "@/components/ui";
+import { CustomerBadge, findCustomer } from "@/features/customers";
+import { type Transaction } from "@/lib/data";
+import { formatSignedCurrency } from "@/lib/format";
+import { applyLedgerView, toCsv } from "@/lib/ledger-view";
+import {
+  type SortKey,
+  useLedgerPrefs,
+} from "@/lib/preferences";
+
+// Client-side ledger explorer: search + direction filter + sortable columns +
+// CSV export over the data-layer transactions. View state (search / filter /
+// sort) is persisted to localStorage via useLedgerPrefs, so a refresh keeps
+// the user's exact view. Empty / unmatched states are handled inline.
+
+const REVIEW_THRESHOLD = 85;
+
+function downloadCsv(rows: readonly Transaction[]) {
+  const csv = toCsv(rows);
+  const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
+  const url = URL.createObjectURL(blob);
+  const a = document.createElement("a");
+  a.href = url;
+  a.download = `ledger-${new Date().toISOString().slice(0, 10)}.csv`;
+  document.body.appendChild(a);
+  a.click();
+  document.body.removeChild(a);
+  URL.revokeObjectURL(url);
+}
+
+export function LedgerExplorer({
+  transactions,
+}: {
+  transactions: Transaction[];
+}) {
+  const { search, direction, sortKey, sortDir } = useLedgerPrefs();
+  const setSearch = useLedgerPrefs((s) => s.setSearch);
+  const setDirection = useLedgerPrefs((s) => s.setDirection);
+  const toggleSort = useLedgerPrefs((s) => s.toggleSort);
+  const reset = useLedgerPrefs((s) => s.reset);
+
+  const rows = useMemo(
+    () =>
+      applyLedgerView(transactions, { search, direction, sortKey, sortDir }),
+    [transactions, search, direction, sortKey, sortDir],
+  );
+
+  const pendingReview = rows.filter(
+    (t) => t.confidence < REVIEW_THRESHOLD,
+  ).length;
+  const hasFilters = search.trim() !== "" || direction !== "all";
+
+  return (
+    <div className="t-account overflow-hidden">
+      <span className="row-tag">R · txn</span>
+
+      {/* Header + actions */}
+      <div className="flex flex-wrap items-center justify-between gap-3 border-b border-rule px-5 py-3.5">
+        <div>
+          <div className="font-display text-[15px] font-semibold leading-none">
+            The ledger
+          </div>
+          <div className="mt-1 font-mono text-[10px] uppercase tracking-[0.16em] text-muted">
+            AI categorized · {rows.length} of {transactions.length} ·{" "}
+            {pendingReview} await review
+          </div>
+        </div>
+        <div className="flex gap-2">
+          <Button
+            size="sm"
+            variant="secondary"
+            onClick={() => downloadCsv(rows)}
+            disabled={rows.length === 0}
+          >
+            Export CSV
+          </Button>
+          <Button size="sm" variant="primary">
+            Run reconciliation
+          </Button>
+        </div>
+      </div>
+
+      {/* Search + filter controls */}
+      <div className="flex flex-wrap items-center gap-3 border-b border-rule bg-paper/40 px-5 py-3">
+        <label className="relative flex-1 min-w-[180px]">
+          <span className="sr-only">Search transactions</span>
+          <input
+            type="search"
+            value={search}
+            onChange={(e) => setSearch(e.target.value)}
+            placeholder="Search memo or category…"
