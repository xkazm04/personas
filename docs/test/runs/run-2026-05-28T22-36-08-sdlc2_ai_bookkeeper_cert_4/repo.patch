+// Unit tests for the data-layer pure aggregation helpers and async fetchers.
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { type Transaction } from "./transactions";
+import {
+  netTotal,
+  pendingReviewCount,
+  totalExpense,
+  totalIncome,
+} from "./transactions";
+import { getTransactions, getLedgerStats, getMonthlySeries } from "./index";
+import {
+  type MonthDatum,
+  checklistProgress,
+  monthMarginPct,
+  monthNet,
+  summarizeSeries,
+} from "./reports";
+
+const SAMPLE: Transaction[] = [
+  { id: "t1", date: "May 1", description: "a", category: "Materials", amount: -100, confidence: 98 },
+  { id: "t2", date: "May 2", description: "b", category: "Income", amount: 250, confidence: 100 },
+  { id: "t3", date: "May 3", description: "c", category: "Fuel", amount: -50, confidence: 70 },
+];
+
+test("netTotal sums signed amounts", () => {
+  assert.equal(netTotal(SAMPLE), 100);
+  assert.equal(netTotal([]), 0);
+});
+
+test("totalIncome sums positive only; totalExpense sums |negative|", () => {
+  assert.equal(totalIncome(SAMPLE), 250);
+  assert.equal(totalExpense(SAMPLE), 150);
+});
+
+test("pendingReviewCount counts rows below the threshold", () => {
+  assert.equal(pendingReviewCount(SAMPLE, 85), 1); // only the 70 row
+  assert.equal(pendingReviewCount(SAMPLE, 99), 2); // 98 and 70
+  assert.equal(pendingReviewCount(SAMPLE, 0), 0);
+});
+
+const SERIES: MonthDatum[] = [
+  { label: "Jan", revenue: 1000, expenses: 400, state: "closed" },
+  { label: "Feb", revenue: 2000, expenses: 600, state: "closed" },
+  { label: "Mar", revenue: 0, expenses: 0, state: "future" },
+];
+
+test("monthNet and monthMarginPct", () => {
+  assert.equal(monthNet(SERIES[0]), 600);
+  assert.equal(monthMarginPct(SERIES[0]), 60);
+  assert.equal(monthMarginPct(SERIES[2]), 0, "no revenue ⇒ 0% margin, no divide-by-zero");
+});
+
+test("summarizeSeries ignores zero-activity (future) months in averages", () => {
+  const s = summarizeSeries(SERIES);
+  assert.equal(s.monthsWithActivity, 2);
+  assert.equal(s.totalRevenue, 3000);
+  assert.equal(s.totalExpenses, 1000);
+  assert.equal(s.totalNet, 2000);
+  assert.equal(s.avgMonthlyNet, 1000);
+});
+
+test("summarizeSeries handles an all-future (empty-activity) series", () => {
+  const s = summarizeSeries([{ label: "Z", revenue: 0, expenses: 0, state: "future" }]);
+  assert.equal(s.monthsWithActivity, 0);
+  assert.equal(s.avgMonthlyNet, 0);
+});
+
+test("checklistProgress is the done fraction; empty ⇒ 1", () => {
+  assert.equal(
+    checklistProgress([
+      { id: "1", label: "a", done: true },
+      { id: "2", label: "b", done: false },
+    ]),
+    0.5,
+  );
+  assert.equal(checklistProgress([]), 1);
+});
+
+test("async fetchers return the mock fixtures with the right shapes", async () => {
+  const txns = await getTransactions();
+  assert.ok(Array.isArray(txns) && txns.length > 0);
+  assert.ok(typeof txns[0].id === "string" && typeof txns[0].amount === "number");
+
+  const stats = await getLedgerStats();
+  assert.ok(stats.length === 4);
+
+  const series = await getMonthlySeries();
+  assert.ok(series.length === 12);
+});
