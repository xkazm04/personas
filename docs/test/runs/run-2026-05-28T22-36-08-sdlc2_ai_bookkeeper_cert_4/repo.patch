--- /dev/null
+++ b/src/app/api/categorize/route.ts
@@ -0,0 +1,90 @@
+import { type NextRequest, NextResponse } from "next/server";
+import {
+  type CategorizeRequest,
+  type Categorization,
+  buildPrompt,
+  heuristicCategorize,
+  parseModelJson,
+} from "@/lib/categorize";
+
+// Node runtime: the Gemini SDK and process.env access need Node, not Edge.
+export const runtime = "nodejs";
+// Categorization depends on runtime env (GEMINI_API_KEY) + request body, so it
+// must never be statically cached.
+export const dynamic = "force-dynamic";
+
+const GEMINI_MODEL = "gemini-3.5-flash";
+
+/** Validate + coerce the request body into a typed CategorizeRequest. */
+function parseRequest(body: unknown): CategorizeRequest | null {
+  if (typeof body !== "object" || body === null) return null;
+  const b = body as Record<string, unknown>;
+  const description = typeof b.description === "string" ? b.description.trim() : "";
+  const amount =
+    typeof b.amount === "number"
+      ? b.amount
+      : typeof b.amount === "string"
+        ? Number(b.amount)
+        : NaN;
+  if (!description) return null;
+  if (!Number.isFinite(amount)) return null;
+  return { description, amount };
+}
+
+/**
+ * Call Gemini for a live categorization. Returns the parsed result, or null on
+ * any failure (no key, network error, unparseable reply) so the handler can
+ * fall back to the deterministic heuristic.
+ */
+async function geminiCategorize(
+  req: CategorizeRequest,
+): Promise<Categorization | null> {
+  const key = process.env.GEMINI_API_KEY;
+  if (!key) return null;
+
+  try {
+    // Dynamic import keeps the SDK out of the cold-start path on the keyless
+    // (mock) build, which is the path CI and public deploys take.
+    const { GoogleGenerativeAI } = await import("@google/generative-ai");
+    const genAI = new GoogleGenerativeAI(key);
+    const model = genAI.getGenerativeModel({ model: GEMINI_MODEL });
+    const result = await model.generateContent(buildPrompt(req));
+    const text = result.response.text();
+    return parseModelJson(text);
+  } catch (err) {
+    // Log server-side; never leak the key or stack to the client.
+    console.error("[categorize] Gemini call failed, using heuristic:", err);
+    return null;
+  }
+}
+
+export async function POST(request: NextRequest) {
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json(
+      { error: "Invalid JSON body." },
+      { status: 400 },
+    );
+  }
+
+  const parsed = parseRequest(body);
+  if (!parsed) {
+    return NextResponse.json(
+      {
+        error:
+          "Expected { description: string (non-empty), amount: number }.",
+      },
+      { status: 400 },
+    );
+  }
+
+  // Try the live model first; fall back to the deterministic heuristic so a
+  // keyless build, an offline run, or a parse failure all still return a valid
+  // typed categorization.
+  const live = await geminiCategorize(parsed);
+  const result: Categorization = live ?? heuristicCategorize(parsed);
+
+  return NextResponse.json(result satisfies Categorization);
+}
