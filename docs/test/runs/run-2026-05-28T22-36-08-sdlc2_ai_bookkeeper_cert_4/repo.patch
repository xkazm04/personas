+// Unit tests for the ledger-view pure transforms (search / filter / sort / CSV).
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { type Transaction } from "@/lib/data";
+import {
+  applyLedgerView,
+  matchesDirection,
+  matchesSearch,
+  toCsv,
+} from "./ledger-view";
+
+const T: Transaction[] = [
+  { id: "t1", date: "May 18", description: "Home Depot", category: "Materials", amount: -184.22, confidence: 98 },
+  { id: "t2", date: "May 17", description: "Marina Pool", category: "Income · Service", amount: 580, confidence: 100 },
+  { id: "t3", date: "May 16", description: "Chevron", category: "Fuel", amount: -82.4, confidence: 73 },
+];
+
+test("matchesSearch: case-insensitive across description + category", () => {
+  assert.equal(matchesSearch(T[0], "home"), true);
+  assert.equal(matchesSearch(T[0], "MATERIALS"), true);
+  assert.equal(matchesSearch(T[0], "fuel"), false);
+  assert.equal(matchesSearch(T[0], "   "), true, "blank query matches all");
+});
+
+test("matchesDirection: income vs expense vs all", () => {
+  assert.equal(matchesDirection(T[1], "income"), true);
+  assert.equal(matchesDirection(T[1], "expense"), false);
+  assert.equal(matchesDirection(T[0], "expense"), true);
+  assert.equal(matchesDirection(T[0], "all"), true);
+});
+
+test("applyLedgerView: filters by direction then sorts by amount asc", () => {
+  const rows = applyLedgerView(T, {
+    search: "",
+    direction: "expense",
+    sortKey: "amount",
+    sortDir: "asc",
+  });
+  assert.deepEqual(
+    rows.map((r) => r.id),
+    ["t1", "t3"],
+    "−184.22 before −82.40 ascending",
+  );
+});
+
+test("applyLedgerView: sort by confidence desc", () => {
+  const rows = applyLedgerView(T, {
+    search: "",
+    direction: "all",
+    sortKey: "confidence",
+    sortDir: "desc",
+  });
+  assert.deepEqual(rows.map((r) => r.confidence), [100, 98, 73]);
+});
+
+test("applyLedgerView: search narrows the set", () => {
+  const rows = applyLedgerView(T, {
+    search: "pool",
+    direction: "all",
+    sortKey: "date",
+    sortDir: "desc",
+  });
+  assert.deepEqual(rows.map((r) => r.id), ["t2"]);
+});
+
+test("applyLedgerView: does not mutate the input array", () => {
+  const before = T.map((t) => t.id);
+  applyLedgerView(T, { search: "", direction: "all", sortKey: "amount", sortDir: "asc" });
+  assert.deepEqual(T.map((t) => t.id), before);
+});
+
+test("toCsv: header + RFC-4180 quoting of commas/quotes", () => {
+  const rows: Transaction[] = [
+    { id: "x", date: "May 1", description: 'Acme, Inc. "the" co', category: "Materials", amount: -10.5, confidence: 90 },
+  ];
+  const csv = toCsv(rows);
+  const lines = csv.split("\r\n");
+  assert.equal(lines[0], "Date,Description,Category,Amount,Confidence");
+  // Comma + embedded quotes ⇒ field is quoted and inner quotes doubled.
+  assert.ok(lines[1].includes('"Acme, Inc. ""the"" co"'));
+  assert.ok(lines[1].includes("-10.50"));
+  assert.ok(lines[1].includes("90%"));
+});
+
+test("toCsv: empty list yields just the header row", () => {
+  assert.equal(toCsv([]), "Date,Description,Category,Amount,Confidence");
+});
diff --git a/src/lib/ledger-view.ts b/src/lib/ledger-view.ts
new file mode 100644
index 0000000..7c5387d
--- /dev/null
+++ b/src/lib/ledger-view.ts
@@ -0,0 +1,103 @@
+// Pure transforms for the ledger explorer UI: search, direction filter, sort,
+// and CSV export. Kept side-effect-free and free of React / DOM so the logic
+// is unit-testable and reusable on the server. The component (LedgerExplorer)
+// wires these to state + the data layer.
+
+import { type Transaction } from "@/lib/data";
+
+export type DirectionFilter = "all" | "income" | "expense";
+export type SortKey = "date" | "amount" | "confidence";
+export type SortDir = "asc" | "desc";
+
+export interface LedgerViewParams {
+  search: string;
+  direction: DirectionFilter;
+  sortKey: SortKey;
+  sortDir: SortDir;
+}
+
+/** Case-insensitive substring match across description + category. */
+export function matchesSearch(t: Transaction, query: string): boolean {
+  const q = query.trim().toLowerCase();
+  if (!q) return true;
+  return (
+    t.description.toLowerCase().includes(q) ||
+    t.category.toLowerCase().includes(q)
+  );
+}
+
+/** Income = positive amount, expense = negative. `all` passes everything. */
+export function matchesDirection(
+  t: Transaction,
+  direction: DirectionFilter,
+): boolean {
+  if (direction === "income") return t.amount > 0;
+  if (direction === "expense") return t.amount < 0;
+  return true;
+}
+
+/**
+ * Comparator for two transactions given a key. Date sorts by the row's natural
+ * order proxy (id) since the mock dates are display strings, not parseable —
+ * ids are assigned newest-first (t1 newest), so descending id == newest first.
+ * Returns the ascending comparison; the caller flips for descending.
+ */
+function compare(a: Transaction, b: Transaction, key: SortKey): number {
+  switch (key) {
+    case "amount":
+      return a.amount - b.amount;
+    case "confidence":
+      return a.confidence - b.confidence;
+    case "date": {
+      // ids are "t1".."t19"; numeric suffix preserves chronological order.
+      const na = Number(a.id.replace(/\D/g, "")) || 0;
+      const nb = Number(b.id.replace(/\D/g, "")) || 0;
+      // Higher id == more recent, so ascending-by-date == ascending-by-id-desc.
+      // Express as ascending date: older first ⇒ larger id is later ⇒ invert.
+      return nb - na;
+    }
+  }
+}
+
+/**
+ * Apply search + direction filter, then sort. Returns a NEW array; never
+ * mutates the input. Stable for equal keys (Array.prototype.sort is stable in
+ * modern engines).
+ */
+export function applyLedgerView(
+  txns: readonly Transaction[],
+  params: LedgerViewParams,
+): Transaction[] {
+  const filtered = txns.filter(
+    (t) =>
+      matchesSearch(t, params.search) &&
+      matchesDirection(t, params.direction),
+  );
+  const sorted = [...filtered].sort((a, b) => compare(a, b, params.sortKey));
+  return params.sortDir === "desc" ? sorted.reverse() : sorted;
+}
+
+/** Escape a single CSV field per RFC 4180 (quote if it contains , " or newline). */
+function csvField(value: string | number): string {
+  const s = String(value);
+  if (/[",\n\r]/.test(s)) {
+    return `"${s.replace(/"/g, '""')}"`;
+  }
+  return s;
+}
+
+/**
+ * Render the given transactions as an RFC-4180 CSV string with a header row.
+ * Amount is written as a signed decimal; confidence as an integer percent.
+ */
+export function toCsv(txns: readonly Transaction[]): string {
+  const header = ["Date", "Description", "Category", "Amount", "Confidence"];
+  const rows = txns.map((t) => [
+    csvField(t.date),
+    csvField(t.description),
+    csvField(t.category),
+    csvField(t.amount.toFixed(2)),
+    csvField(`${t.confidence}%`),
+  ]);
+  return [header.join(","), ...rows.map((r) => r.join(","))].join("\r\n");
+}
