+++ b/src/lib/data/reports.ts
@@ -0,0 +1,98 @@
+// Swap this module's body for real DB/API calls; signatures are the contract.
+//
+// Data-layer boundary for derived reporting surfaces: the headline stat
+// columns, the month-over-month series, and the month-end close checklist.
+// Today the bodies read the in-repo mock fixtures (features/ledger/data.ts);
+// tomorrow they read a warehouse / materialized view. Keep the async
+// signatures stable and the swap is a one-file change.
+
+import {
+  closeChecklist as mockChecklist,
+  inboxThread as mockInbox,
+  ledgerStats as mockStats,
+  monthlySeries as mockSeries,
+  reviewQueue as mockReviewQueue,
+} from "@/features/ledger/data";
+import {
+  type ChatMessage,
+  type ChecklistItem,
+  type LedgerStat,
+  type MonthDatum,
+  type ReviewItem,
+} from "@/features/ledger/types";
+
+export type { ChatMessage, ChecklistItem, LedgerStat, MonthDatum, ReviewItem };
+
+/** Headline stat columns for the dashboard folio header. */
+export async function getLedgerStats(): Promise<LedgerStat[]> {
+  return mockStats;
+}
+
+/** Month-over-month revenue / expense series (12 months, with state). */
+export async function getMonthlySeries(): Promise<MonthDatum[]> {
+  return mockSeries;
+}
+
+/** The month-end close checklist. */
+export async function getCloseChecklist(): Promise<ChecklistItem[]> {
+  return mockChecklist;
+}
+
+/** The concierge SMS thread shown in the dashboard InboxCard. */
+export async function getInboxThread(): Promise<ChatMessage[]> {
+  return mockInbox;
+}
+
+/** Low-confidence items awaiting a human category decision. */
+export async function getReviewQueue(): Promise<ReviewItem[]> {
+  return mockReviewQueue;
+}
+
+// ── Pure aggregation helpers ──────────────────────────────────────────────
+
+/** Net (revenue − expenses) for a single month datum. */
+export function monthNet(m: MonthDatum): number {
+  return m.revenue - m.expenses;
+}
+
+/** Net-margin percentage for a month, 0 when there's no revenue. */
+export function monthMarginPct(m: MonthDatum): number {
+  if (m.revenue <= 0) return 0;
+  return (monthNet(m) / m.revenue) * 100;
+}
+
+/**
+ * Roll up a month series into a summary. Only months with recorded activity
+ * (`closed` / `open`, i.e. revenue > 0) count toward totals and averages so a
+ * trailing run of `future` zero-months never drags the average to zero.
+ */
+export interface SeriesSummary {
+  monthsWithActivity: number;
+  totalRevenue: number;
+  totalExpenses: number;
+  totalNet: number;
+  avgMonthlyNet: number;
+}
+
+export function summarizeSeries(
+  series: readonly MonthDatum[],
+): SeriesSummary {
+  const active = series.filter((m) => m.revenue > 0 || m.expenses > 0);
+  const totalRevenue = active.reduce((s, m) => s + m.revenue, 0);
+  const totalExpenses = active.reduce((s, m) => s + m.expenses, 0);
+  const totalNet = totalRevenue - totalExpenses;
+  return {
+    monthsWithActivity: active.length,
+    totalRevenue,
+    totalExpenses,
+    totalNet,
+    avgMonthlyNet: active.length ? totalNet / active.length : 0,
+  };
+}
+
+/** Fraction of checklist items complete, 0..1. Empty list ⇒ 1 (nothing due). */
+export function checklistProgress(items: readonly ChecklistItem[]): number {
+  if (items.length === 0) return 1;
+  const done = items.reduce((n, i) => (i.done ? n + 1 : n), 0);
+  return done / items.length;
+}
