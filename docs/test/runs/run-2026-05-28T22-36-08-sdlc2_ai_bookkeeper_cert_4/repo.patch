+"use client";
+
+import Link from "next/link";
+
+// Route-segment error boundary for the dashboard. Catches a failure in the
+// async data-layer fetch (or any descendant render) and offers a retry without
+// a full reload. Client component, as required for error boundaries.
+export default function DashboardError({
+  error,
+  reset,
+}: {
+  error: Error & { digest?: string };
+  reset: () => void;
+}) {
+  return (
+    <main className="grid min-h-screen place-items-center bg-background px-8">
+      <div className="t-account max-w-md p-8 text-center">
+        <div className="label-stamp">Folio · error</div>
+        <h1 className="mt-4 font-display text-3xl font-light tracking-[-0.02em]">
+          The ledger didn&apos;t load.
+        </h1>
+        <p className="mt-3 text-[14px] leading-relaxed text-muted-strong">
+          We hit a snag pulling your books. Nothing was lost — try again, or
+          head back to the landing page.
+        </p>
+        {error.digest && (
+          <p className="mt-2 font-mono text-[10px] uppercase tracking-[0.18em] text-muted">
+            ref · {error.digest}
+          </p>
+        )}
+        <div className="mt-6 flex items-center justify-center gap-3">
+          <button
+            type="button"
+            onClick={reset}
+            className="inline-flex items-center gap-2 rounded-control bg-ink px-5 py-3 text-xs font-semibold uppercase tracking-[0.16em] text-paper transition hover:-translate-y-[1px] hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent)]/40"
+          >
+            Try again
+            <span aria-hidden>↻</span>
+          </button>
+          <Link
+            href="/"
+            className="text-xs text-muted underline decoration-rule-strong underline-offset-4 transition hover:text-foreground"
+          >
+            Back to home
+          </Link>
+        </div>
+      </div>
+    </main>
+  );
+}
