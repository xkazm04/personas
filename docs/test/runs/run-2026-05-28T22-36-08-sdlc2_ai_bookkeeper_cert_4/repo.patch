+import { type HTMLAttributes } from "react";
+import { cn } from "@/lib/cn";
+
+// Shared loading-skeleton primitive. A paper-toned pulsing block in the Ruled
+// Ledger palette (uses the `--rule` surface, not a generic gray). Compose it
+// into row/card skeletons for async lists.
+export function Skeleton({
+  className,
+  ...props
+}: HTMLAttributes<HTMLDivElement>) {
+  return (
+    <div
+      aria-hidden
+      className={cn("animate-pulse rounded-control bg-rule", className)}
+      {...props}
+    />
+  );
+}
+
+// A ruled placeholder row matching the ledger table cadence (28px rhythm).
+export function SkeletonRow() {
+  return (
+    <div className="flex items-center gap-4 border-b border-rule/70 px-2 py-3">
+      <Skeleton className="h-2.5 w-6 rounded-pill" />
+      <Skeleton className="h-2.5 w-14 rounded-pill" />
+      <Skeleton className="h-2.5 flex-1 rounded-pill" />
+      <Skeleton className="h-2.5 w-20 rounded-pill" />
+      <Skeleton className="h-4 w-10 rounded-pill" />
+    </div>
+  );
+}
+
+// A card-sized placeholder: header strip + several rows.
+export function SkeletonCard({ rows = 5 }: { rows?: number }) {
+  return (
+    <div className="t-account overflow-hidden">
+      <div className="flex items-center justify-between border-b border-rule px-5 py-3.5">
+        <Skeleton className="h-3 w-32 rounded-pill" />
+        <Skeleton className="h-5 w-20 rounded-pill" />
+      </div>
+      <div className="px-3 py-2">
+        {Array.from({ length: rows }).map((_, i) => (
+          <SkeletonRow key={i} />
+        ))}
+      </div>
+    </div>
+  );
+}
