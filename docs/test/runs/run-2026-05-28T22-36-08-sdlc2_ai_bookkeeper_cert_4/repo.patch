+// Unit tests for the categorization heuristic + defensive model-JSON parser.
+//
+// Runner: Node's built-in test runner via tsx. Run the whole suite with
+// `npm test`, or this file alone with:
+//   npx tsx --test ./src/lib/categorize.test.ts
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import {
+  buildPrompt,
+  heuristicCategorize,
+  parseModelJson,
+} from "./categorize";
+
+test("heuristic: income (positive amount) books Cash ← Service Revenue", () => {
+  const r = heuristicCategorize({ description: "Marina Pool deposit", amount: 580 });
+  assert.equal(r.debitAccount, "Cash");
+  assert.equal(r.creditAccount, "Service Revenue");
+  assert.equal(r.category, "Income · Service");
+  assert.equal(r.source, "heuristic");
+  assert.ok(r.confidence > 0 && r.confidence <= 1);
+});
+
+test("heuristic: fuel keyword maps to Vehicle & Fuel Expense", () => {
+  const r = heuristicCategorize({ description: "Chevron #4781", amount: -82.4 });
+  assert.equal(r.category, "Fuel");
+  assert.equal(r.debitAccount, "Vehicle & Fuel Expense");
+  assert.equal(r.creditAccount, "Cash");
+});
+
+test("heuristic: hardware vendor maps to Materials", () => {
+  const r = heuristicCategorize({ description: "Home Depot — Tustin", amount: -184.22 });
+  assert.equal(r.category, "Materials");
+  assert.equal(r.debitAccount, "Materials Expense");
+});
+
+test("heuristic: telecom maps to Utilities", () => {
+  const r = heuristicCategorize({ description: "Verizon Wireless", amount: -118.99 });
+  assert.equal(r.category, "Phone / Internet");
+});
+
+test("heuristic: unknown expense falls back to Uncategorized at low confidence", () => {
+  const r = heuristicCategorize({ description: "Zzz mystery vendor", amount: -50 });
+  assert.equal(r.category, "Uncategorized");
+  assert.equal(r.debitAccount, "Uncategorized Expense");
+  assert.ok(r.confidence <= 0.5);
+});
+
+test("heuristic: confidence is always clamped to [0,1] and rounded to 2dp", () => {
+  const r = heuristicCategorize({ description: "Ferguson Plumbing Supply", amount: -612 });
+  assert.ok(r.confidence >= 0 && r.confidence <= 1);
+  assert.equal(Math.round(r.confidence * 100) / 100, r.confidence);
+});
+
+test("parseModelJson: clean JSON parses with source=gemini", () => {
+  const r = parseModelJson(
+    '{"debitAccount":"Materials Expense","creditAccount":"Cash","category":"Materials","confidence":0.91,"rationale":"Hardware purchase."}',
+  );
+  assert.ok(r);
+  assert.equal(r.category, "Materials");
+  assert.equal(r.confidence, 0.91);
+  assert.equal(r.source, "gemini");
+});
+
+test("parseModelJson: strips ```json fences", () => {
+  const text =
+    '```json\n{"debitAccount":"Fuel","creditAccount":"Cash","category":"Fuel","confidence":0.8,"rationale":"Gas."}\n```';
+  const r = parseModelJson(text);
+  assert.ok(r);
+  assert.equal(r.category, "Fuel");
+});
+
+test("parseModelJson: extracts JSON embedded in prose", () => {
+  const text =
+    'Sure! Here is the entry: {"debitAccount":"Office Expense","creditAccount":"Cash","category":"Office","confidence":0.7,"rationale":"Postage."} Hope that helps.';
+  const r = parseModelJson(text);
+  assert.ok(r);
+  assert.equal(r.debitAccount, "Office Expense");
+});
+
+test("parseModelJson: normalizes 0..100 confidence to 0..1", () => {
+  const r = parseModelJson(
+    '{"debitAccount":"A","creditAccount":"B","category":"C","confidence":85,"rationale":"x"}',
+  );
+  assert.ok(r);
+  assert.equal(r.confidence, 0.85);
+});
+
+test("parseModelJson: returns null on garbage / missing fields", () => {
+  assert.equal(parseModelJson("not json at all"), null);
+  assert.equal(parseModelJson(""), null);
+  assert.equal(
+    parseModelJson('{"debitAccount":"A","category":"C"}'),
+    null,
+    "missing creditAccount/rationale/confidence ⇒ null",
+  );
+  assert.equal(
+    parseModelJson('{"debitAccount":"A","creditAccount":"B","category":"C","rationale":"x"}'),
+    null,
+    "missing confidence ⇒ null",
+  );
+});
+
+test("buildPrompt: includes description, amount, and demands JSON-only", () => {
+  const p = buildPrompt({ description: "Shell fuel", amount: -84.1 });
+  assert.ok(p.includes("Shell fuel"));
+  assert.ok(p.includes("-84.1"));
+  assert.ok(/only a JSON object/i.test(p));
+});
diff --git a/src/lib/categorize.ts b/src/lib/categorize.ts
new file mode 100644
index 0000000..58f03a9
--- /dev/null
+++ b/src/lib/categorize.ts
@@ -0,0 +1,227 @@
+// Smart transaction categorization — shared types + the deterministic
+// heuristic fallback used when no Gemini key is configured (and when a live
+// Gemini response fails to parse). Pure and side-effect-free: this module does
+// NOT import the Gemini SDK or read env, so it stays unit-testable and safe to
+// import from anywhere. The API route (app/api/categorize/route.ts) owns the
+// env check and the live model call.
+
+/** The double-entry categorization the model (or the heuristic) produces. */
+export interface Categorization {
+  /** Account debited (where the value goes). */
+  debitAccount: string;
+  /** Account credited (where the value comes from). */
+  creditAccount: string;
+  /** Human-friendly bookkeeping category, e.g. "Materials", "Fuel". */
+  category: string;
+  /** Model/heuristic confidence, 0..1. */
+  confidence: number;
+  /** One-line plain-English justification. */
+  rationale: string;
+  /** Provenance so the UI can show whether this came from Gemini or the mock. */
+  source: "gemini" | "heuristic";
+}
+
+/** Request shape the API route accepts. */
+export interface CategorizeRequest {
+  description: string;
+  amount: number;
+}
+
+// ── Keyword → account mapping ─────────────────────────────────────────────
+// Ordered most-specific-first. Each rule maps a set of lowercase keywords to a
+// chart-of-accounts category and the expense/COGS account it debits. Credits
+// default to "Cash" for an outflow (negative amount) or "Service Revenue" for
+// an inflow (positive amount); income overrides the whole thing below.
+
+interface Rule {
+  category: string;
+  /** Account debited for an expense (outflow) under this rule. */
+  debitAccount: string;
+  keywords: readonly string[];
+}
+
+const EXPENSE_RULES: readonly Rule[] = [
+  {
+    category: "Fuel",
+    debitAccount: "Vehicle & Fuel Expense",
+    keywords: ["chevron", "shell", "arco", "76 ", "gas", "fuel", "exxon", "bp ", "mobil"],
+  },
+  {
+    category: "Materials",
+    debitAccount: "Materials Expense",
+    keywords: [
+      "home depot",
+      "lowe",
+      "ferguson",
+      "grainger",
+      "ace hardware",
+      "supply",
+      "hardware",
+    ],
+  },
+  {
+    category: "Phone / Internet",
+    debitAccount: "Utilities Expense",
+    keywords: ["verizon", "at&t", "att ", "t-mobile", "comcast", "spectrum", "internet", "phone"],
+  },
+  {
+    category: "Office",
+    debitAccount: "Office Expense",
+    keywords: ["usps", "fedex", "ups ", "staples", "office", "postage", "amazon"],
+  },
+  {
+    category: "Software / Subscriptions",
+    debitAccount: "Software Expense",
+    keywords: ["adobe", "google", "microsoft", "quickbooks", "stripe fee", "subscription", "saas"],
+  },
+  {
+    category: "Meals",
+    debitAccount: "Meals Expense",
+    keywords: ["restaurant", "cafe", "coffee", "starbucks", "doordash", "grubhub", "lunch"],
+  },
+  {
+    category: "Insurance",
+    debitAccount: "Insurance Expense",
+    keywords: ["insurance", "geico", "state farm", "progressive", "allstate"],
+  },
+  {
+    category: "Rent",
+    debitAccount: "Rent Expense",
+    keywords: ["rent", "lease", "wework", "storage"],
+  },
+  {
+    category: "Bank / Fees",
+    debitAccount: "Bank Fees",
+    keywords: ["bank fee", "service charge", "overdraft", "wire fee", "atm "],
+  },
+] as const;
+
+/** Round to 2 dp without IEEE drift, clamp to [0,1]. */
+function confidence(n: number): number {
+  const clamped = Math.max(0, Math.min(1, n));
+  return Math.round(clamped * 100) / 100;
+}
+
+/**
+ * Deterministic keyword-based categorization. Always returns a result — falls
+ * back to an "Uncategorized" / low-confidence answer when nothing matches, so
+ * callers never have to handle a null. Income (positive amount) is detected
+ * first and posts Cash ← Service Revenue.
+ */
+export function heuristicCategorize(
+  req: CategorizeRequest,
+): Categorization {
+  const desc = req.description.toLowerCase().trim();
+  const isIncome = req.amount > 0;
+
+  if (isIncome) {
+    return {
+      debitAccount: "Cash",
+      creditAccount: "Service Revenue",
+      category: "Income · Service",
+      confidence: confidence(0.82),
+      rationale:
+        "Positive amount booked as service revenue — cash in, revenue recognized.",
+      source: "heuristic",
+    };
+  }
+
+  for (const rule of EXPENSE_RULES) {
+    const hit = rule.keywords.find((k) => desc.includes(k));
+    if (hit) {
+      return {
+        debitAccount: rule.debitAccount,
+        creditAccount: "Cash",
+        category: rule.category,
+        // Longer keyword matches are more specific ⇒ slightly higher confidence.
+        confidence: confidence(0.7 + Math.min(hit.trim().length, 12) * 0.015),
+        rationale: `Matched "${hit.trim()}" → ${rule.category}; expense paid from cash.`,
+        source: "heuristic",
+      };
+    }
+  }
+
+  return {
+    debitAccount: "Uncategorized Expense",
+    creditAccount: "Cash",
+    category: "Uncategorized",
+    confidence: confidence(0.4),
+    rationale:
+      "No keyword matched; booked to Uncategorized Expense for human review.",
+    source: "heuristic",
+  };
+}
+
+/**
+ * Parse a model's free-text reply into a Categorization. Strips ```json fences,
+ * tolerates surrounding prose, and validates the shape. Returns null on any
+ * failure so the caller can fall back to the heuristic.
+ */
+export function parseModelJson(text: string): Categorization | null {
+  if (!text) return null;
+  // Strip markdown code fences (```json ... ``` or ``` ... ```).
+  let cleaned = text.trim().replace(/^```(?:json)?\s*/i, "").replace(/\s*```$/i, "");
+  // If the model wrapped JSON in prose, grab the first {...} block.
+  if (!cleaned.startsWith("{")) {
+    const start = cleaned.indexOf("{");
+    const end = cleaned.lastIndexOf("}");
+    if (start === -1 || end === -1 || end <= start) return null;
+    cleaned = cleaned.slice(start, end + 1);
+  }
+
+  let raw: unknown;
+  try {
+    raw = JSON.parse(cleaned);
+  } catch {
+    return null;
+  }
+  if (typeof raw !== "object" || raw === null) return null;
+  const o = raw as Record<string, unknown>;
+
+  const debitAccount = typeof o.debitAccount === "string" ? o.debitAccount : null;
+  const creditAccount =
+    typeof o.creditAccount === "string" ? o.creditAccount : null;
+  const category = typeof o.category === "string" ? o.category : null;
+  const rationale = typeof o.rationale === "string" ? o.rationale : null;
+  const rawConf =
+    typeof o.confidence === "number"
+      ? o.confidence
+      : typeof o.confidence === "string"
+        ? Number(o.confidence)
+        : NaN;
+
+  if (!debitAccount || !creditAccount || !category || !rationale) return null;
+  if (!Number.isFinite(rawConf)) return null;
+
+  // Some models answer 0..100; normalize to 0..1.
+  const normConf = rawConf > 1 ? rawConf / 100 : rawConf;
+
+  return {
+    debitAccount,
+    creditAccount,
+    category,
+    confidence: confidence(normConf),
+    rationale,
+    source: "gemini",
+  };
+}
+
+/** The prompt sent to Gemini. Demands JSON-only output. */
+export function buildPrompt(req: CategorizeRequest): string {
+  return [
+    "You are a bookkeeping assistant for a US solo trade (pool/plumbing service).",
+    "Classify the transaction below into double-entry accounts.",
+    "",
+    `Description: ${req.description}`,
+    `Amount (USD, negative = expense, positive = income): ${req.amount}`,
+    "",
+    "Respond with ONLY a JSON object, no prose, no markdown fences, matching exactly:",
+    "{",
+    '  "debitAccount": string,',
+    '  "creditAccount": string,',
+    '  "category": string,',
+    '  "confidence": number between 0 and 1,',
+    '  "rationale": string (one short sentence)',
+    "}",
+  ].join("\n");
+}
