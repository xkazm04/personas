+++ b/src/app/api/checkout/resolve-bundle.test.ts
+import assert from "node:assert/strict";
+import test from "node:test";
+import { type Bundle } from "@/lib/tokens/economy";
+import { checkoutMetadata, resolveCheckoutBundle } from "./resolve-bundle";
+
+// A bundle WITH a configured product id — stands in for the env-populated
+// BUNDLES so the happy path is exercisable without POLAR_PRODUCT_* set.
+const configured: Bundle = {
+  key: "builder",
+  label: "Builder",
+  tokens: 2000,
+  priceLabel: "$15",
+  centsPerToken: 0.75,
+  polarProductId: "prod_test_123",
+};
+const lookup = (key: string): Bundle | undefined =>
+  key === configured.key ? configured : undefined;
+
+test("resolves a known bundle that has a configured product id", () => {
+  const r = resolveCheckoutBundle("builder", lookup);
+  assert.equal(r.ok, true);
+  assert.ok(r.ok);
+  assert.equal(r.productId, "prod_test_123");
+  assert.equal(r.bundle.key, "builder");
+});
+
+test("unknown bundle key → unknown_bundle", () => {
+  const r = resolveCheckoutBundle("does-not-exist", lookup);
+  assert.deepEqual(r, { ok: false, error: "unknown_bundle" });
+});
+
+test("a resolved bundle WITHOUT a polarProductId is rejected (env not configured)", () => {
+  const unconfigured: Bundle = { ...configured, polarProductId: undefined };
+  const r = resolveCheckoutBundle("builder", () => unconfigured);
+  assert.deepEqual(r, { ok: false, error: "unknown_bundle" });
+});
+
+test("an empty polarProductId string is treated as not configured", () => {
+  const r = resolveCheckoutBundle(
+    "builder",
+    () => ({ ...configured, polarProductId: "" }),
+  );
+  assert.deepEqual(r, { ok: false, error: "unknown_bundle" });
+});
+
+for (const falsy of [undefined, null, "", 0, false]) {
+  test(`falsy bundle field (${JSON.stringify(falsy)}) → unknown_bundle without a lookup`, () => {
+    let called = false;
+    const r = resolveCheckoutBundle(falsy, (k) => {
+      called = true;
+      return lookup(k);
+    });
+    assert.deepEqual(r, { ok: false, error: "unknown_bundle" });
+    assert.equal(called, false, "lookup must be skipped for a falsy bundle");
+  });
+}
+
+test("non-string bundle values are coerced via String() before lookup", () => {
+  const seen: string[] = [];
+  resolveCheckoutBundle(123, (k) => {
+    seen.push(k);
+    return undefined;
+  });
+  resolveCheckoutBundle({ a: 1 }, (k) => {
+    seen.push(k);
+    return undefined;
+  });
+  assert.deepEqual(seen, ["123", "[object Object]"]);
+});
+
+test("checkoutMetadata echoes userId + bundle key + tokens as a string", () => {
+  assert.deepEqual(checkoutMetadata(configured, "user_42"), {
+    userId: "user_42",
+    bundle: "builder",
+    tokens: "2000",
+  });
+});
+
+test("checkoutMetadata stringifies the token count (webhook reads strings)", () => {
+  const meta = checkoutMetadata({ ...configured, tokens: 500 }, "u1");
+  assert.equal(meta.tokens, "500");
+  assert.equal(typeof meta.tokens, "string");
+});
+

