+++ b/src/app/api/checkout/resolve-bundle.ts
+import { type Bundle, bundleByKey } from "@/lib/tokens/economy";
+
+export type CheckoutResolution =
+  | { ok: true; bundle: Bundle; productId: string }
+  | { ok: false; error: "unknown_bundle" };
+
+/**
+ * Pure resolution of the checkout request's `bundle` field → a purchasable
+ * bundle that has a configured Polar product id.
+ *
+ * Extracted from route.ts so the `unknown_bundle` 400 path is unit-testable
+ * without pulling in `server-only` (route.ts imports @/lib/auth/session and
+ * @/lib/polar/client, which fail under `tsx --test`). Mirrors the
+ * parse-request.ts / resolve-order.ts pattern.
+ *
+ * `lookup` is injectable so the happy path can be exercised in tests: the real
+ * `bundleByKey` reads `polarProductId` from env at module load, so without a
+ * configured POLAR_PRODUCT_* every bundle resolves to `unknown_bundle`.
+ */
+export function resolveCheckoutBundle(
+  raw: unknown,
+  lookup: (key: string) => Bundle | undefined = bundleByKey,
+): CheckoutResolution {
+  const bundle = raw ? lookup(String(raw)) : undefined;
+  if (!bundle?.polarProductId) {
+    return { ok: false, error: "unknown_bundle" };
+  }
+  return { ok: true, bundle, productId: bundle.polarProductId };
+}
+
+/**
+ * Metadata echoed back on the Polar order webhook so the credit lands on the
+ * right user/bundle. Pure — kept beside the resolver it pairs with.
+ */
+export function checkoutMetadata(
+  bundle: Bundle,
+  userId: string,
+): { userId: string; bundle: string; tokens: string } {
+  return { userId, bundle: bundle.key, tokens: String(bundle.tokens) };
+}
+
