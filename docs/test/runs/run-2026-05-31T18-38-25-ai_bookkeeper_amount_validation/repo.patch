diff --git a/migrations/0001_init.sql b/migrations/0001_init.sql
deleted file mode 100644
index e498773..0000000
--- a/migrations/0001_init.sql
+++ /dev/null
@@ -1,72 +0,0 @@
--- 0001_init — the app's private schema + auth/token tables.
---
--- Inferred from the SQL in src/lib/auth/db.ts and src/lib/tokens/ledger.ts (the
--- repo had no DDL — the tables "already existed" in a shared project). Pure
--- Postgres, so it runs unchanged on PGlite (local), Supabase, and Cloud SQL.
--- Fully idempotent (IF NOT EXISTS) — safe to re-run.
---
--- NOTE: schema name matches the APP_AUTH_SCHEMA default. If you override that
--- env var, change `app_bookkeeper` here to match.
-
-create schema if not exists app_bookkeeper;
-
--- One row per signed-in user (mirrors the Supabase auth user id).
-create table if not exists app_bookkeeper.profiles (
-  id           uuid primary key,
-  email        text,
-  full_name    text,
-  avatar_url   text,
-  onboarded_at timestamptz,
-  created_at   timestamptz not null default now(),
-  updated_at   timestamptz not null default now()
-);
-
--- First-auth consent record (one per acceptance; append-only).
-create table if not exists app_bookkeeper.consents (
-  id               bigint generated always as identity primary key,
-  user_id          uuid not null,
-  consent_version  text not null,
-  terms_accepted   boolean not null,
-  privacy_accepted boolean not null,
-  marketing_opt_in boolean not null,
-  ip               text,
-  user_agent       text,
-  created_at       timestamptz not null default now()
-);
-create index if not exists consents_user_id_idx
-  on app_bookkeeper.consents (user_id);
-
--- Per-user token balance.
-create table if not exists app_bookkeeper.token_accounts (
-  user_id    uuid primary key,
-  balance    integer not null default 0,
-  created_at timestamptz not null default now(),
-  updated_at timestamptz not null default now()
-);
-
--- Append-only token ledger (debits, credits, grants). `metadata` is jsonb.
-create table if not exists app_bookkeeper.token_ledger (
-  id            bigint generated always as identity primary key,
-  user_id       uuid not null,
-  delta         integer not null,
-  reason        text not null,
-  operation     text,
-  ref           text,
-  balance_after integer not null,
-  metadata      jsonb not null default '{}'::jsonb,
-  created_at    timestamptz not null default now()
-);
-
--- Idempotency guards the ledger code relies on:
---   • credit()/charge() look up by (ref, reason) — unique so a Polar order or a
---     request id can never be applied twice.
-create unique index if not exists token_ledger_ref_reason_uniq
-  on app_bookkeeper.token_ledger (ref, reason)
-  where ref is not null;
---   • grantSignupTokens() looks up by (user_id, reason='signup_grant') — unique
---     so the one-time grant can never double-credit.
-create unique index if not exists token_ledger_signup_grant_uniq
-  on app_bookkeeper.token_ledger (user_id)
-  where reason = 'signup_grant';
-create index if not exists token_ledger_user_id_idx
-  on app_bookkeeper.token_ledger (user_id);
