new file mode 100644
index 0000000..76cbf60
--- /dev/null
+++ b/src/app/api/categorize/parse-request.ts
@@ -0,0 +1,31 @@
+import type { CategorizeRequest } from "@/lib/categorize";
+import { isValidSignedAmount } from "@/features/ledger";
+
+/**
+ * Validate + coerce the request body into a typed CategorizeRequest.
+ *
+ * Lives in its own module (not inline in route.ts) so it can be unit-tested
+ * without dragging the route's server-only LLM/token dependencies into the
+ * Node test runner. Returning null signals a 400 to the caller.
+ *
+ * ADR 0008: this is the live HTTP ingestion boundary, so it enforces the
+ * canonical monetary invariants (ADR 0001) via isValidSignedAmount — signed
+ * (negative=expense, positive=income), non-zero, |amount| <= MAX_AMOUNT
+ * ($1,000,000), and at most 2 decimals — replacing the prior ad-hoc
+ * Number.isFinite check, which let through zero, out-of-range, and sub-cent
+ * amounts.
+ */
+export function parseRequest(body: unknown): CategorizeRequest | null {
+  if (typeof body !== "object" || body === null) return null;
+  const b = body as Record<string, unknown>;
+  const description = typeof b.description === "string" ? b.description.trim() : "";
+  const amount =
+    typeof b.amount === "number"
+      ? b.amount
+      : typeof b.amount === "string"
+        ? Number(b.amount)
+        : NaN;
+  if (!description) return null;
+  if (!isValidSignedAmount(amount)) return null;
+  return { description, amount };
+}
diff --git a/src/app/api/categorize/route.test.ts b/src/app/api/categorize/route.test.ts
new file mode 100644
index 0000000..f7f9d1d
--- /dev/null
+++ b/src/app/api/categorize/route.test.ts
@@ -0,0 +1,60 @@
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { parseRequest } from "./parse-request";
+
+// ADR 0008: the live POST /api/categorize boundary must enforce the canonical
+// monetary-amount invariants (ADR 0001) via isValidSignedAmount, instead of the
+// prior ad-hoc Number.isFinite check. parseRequest returns the parsed
+// CategorizeRequest on valid input and null on invalid input (→ HTTP 400).
+
+test("parseRequest accepts a valid signed expense", () => {
+  assert.deepEqual(parseRequest({ description: "Coffee", amount: -184.22 }), {
+    description: "Coffee",
+    amount: -184.22,
+  });
+});
+
+test("parseRequest accepts a valid positive income", () => {
+  assert.deepEqual(parseRequest({ description: "Invoice paid", amount: 580 }), {
+    description: "Invoice paid",
+    amount: 580,
+  });
+});
+
+test("parseRequest accepts a numeric string amount", () => {
+  assert.deepEqual(parseRequest({ description: "Refund", amount: "-50" }), {
+    description: "Refund",
+    amount: -50,
+  });
+});
+
+test("parseRequest rejects a zero amount", () => {
+  assert.equal(parseRequest({ description: "Nothing", amount: 0 }), null);
+});
+
+test("parseRequest rejects an amount over the ceiling", () => {
+  assert.equal(
+    parseRequest({ description: "Too big", amount: 1_000_001 }),
+    null,
+  );
+});
+
+test("parseRequest rejects sub-cent precision", () => {
+  assert.equal(parseRequest({ description: "Sub-cent", amount: -82.999 }), null);
+});
+
+test("parseRequest rejects non-finite amounts (NaN / Infinity)", () => {
+  assert.equal(parseRequest({ description: "NaN", amount: NaN }), null);
+  assert.equal(
+    parseRequest({ description: "Infinity", amount: Infinity }),
+    null,
+  );
+});
+
+test("parseRequest rejects a non-numeric string amount", () => {
+  assert.equal(parseRequest({ description: "Words", amount: "twelve" }), null);
+});
+
+test("parseRequest rejects an empty description", () => {
+  assert.equal(parseRequest({ description: "   ", amount: -50 }), null);
+});
