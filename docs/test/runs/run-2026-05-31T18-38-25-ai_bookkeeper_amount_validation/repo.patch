+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { resolveCreditAction } from "./resolve-order";
+
+// The Polar webhook moves money into the token ledger, so its event→action
+// resolution is the highest-risk extractable logic on the route. These tests
+// pin the exact credit/clawback decision (amount sign, reason, idempotency ref)
+// for every event class, plus the under-specified no-op cases. Bundle token
+// counts come from BUNDLES in @/lib/tokens/economy: starter=500, builder=2000,
+// pro=8000, scale=30000. We resolve bundles by the explicit metadata.bundle key
+// (env-independent), not the env-derived polarProductId.
+
+test("order.paid credits the bundle's tokens as a purchase, keyed by order id", () => {
+  assert.deepEqual(
+    resolveCreditAction({
+      type: "order.paid",
+      data: { id: "ord_1", metadata: { userId: "u_1", bundle: "starter" } },
+    }),
+    {
+      userId: "u_1",
+      amount: 500,
+      reason: "purchase",
+      ref: "ord_1",
+      metadata: { bundle: "starter" },
+    },
+  );
+});
+
+test("order.created is treated as a completed purchase", () => {
+  assert.deepEqual(
+    resolveCreditAction({
+      type: "order.created",
+      data: { id: "ord_2", metadata: { userId: "u_2", bundle: "builder" } },
+    }),
+    {
+      userId: "u_2",
+      amount: 2000,
+      reason: "purchase",
+      ref: "ord_2",
+      metadata: { bundle: "builder" },
+    },
+  );
+});
+
+test("refund.created claws back the bundle's tokens with a refund: ref", () => {
+  assert.deepEqual(
+    resolveCreditAction({
+      type: "refund.created",
+      data: { id: "ord_3", metadata: { userId: "u_3", bundle: "pro" } },
+    }),
+    {
+      userId: "u_3",
+      amount: -8000,
+      reason: "refund",
+      ref: "refund:ord_3",
+      metadata: { bundle: "pro" },
+    },
+  );
+});
+
+test("order.refunded is also a clawback", () => {
+  assert.deepEqual(
+    resolveCreditAction({
+      type: "order.refunded",
+      data: { id: "ord_4", metadata: { userId: "u_4", bundle: "scale" } },
+    }),
+    {
+      userId: "u_4",
+      amount: -30000,
+      reason: "refund",
+      ref: "refund:ord_4",
+      metadata: { bundle: "scale" },
+    },
+  );
+});
+
+test("a purchase with no userId is a no-op (null)", () => {
+  assert.equal(
+    resolveCreditAction({
+      type: "order.paid",
+      data: { id: "ord_5", metadata: { bundle: "starter" } },
+    }),
+    null,
+  );
+});
+
+test("a purchase with an unknown bundle key and no product id is a no-op", () => {
+  assert.equal(
+    resolveCreditAction({
+      type: "order.paid",
+      data: { id: "ord_6", metadata: { userId: "u_6", bundle: "mystery" } },
+    }),
+    null,
+  );
+});
+
+test("a refund with no userId is a no-op (null)", () => {
+  assert.equal(
+    resolveCreditAction({
+      type: "order.refunded",
+      data: { id: "ord_7", metadata: { bundle: "pro" } },
+    }),
+    null,
+  );
+});
+
+test("an unrelated event type resolves to null", () => {
+  assert.equal(
+    resolveCreditAction({
+      type: "subscription.updated",
+      data: { id: "sub_1", metadata: { userId: "u_8", bundle: "starter" } },
+    }),
+    null,
+  );
+});
+
+test("a refund does NOT fall back to product id resolution (key only)", () => {
+  // Refunds carry no product id to fall back on; an unknown bundle key → no-op,
+  // even though a same-id purchase event might have resolved via productId.
+  assert.equal(
+    resolveCreditAction({
+      type: "refund.created",
+      data: {
+        id: "ord_9",
+        productId: "prod_anything",
+        metadata: { userId: "u_9" },
+      },
+    }),
+    null,
+  );
+});
+

