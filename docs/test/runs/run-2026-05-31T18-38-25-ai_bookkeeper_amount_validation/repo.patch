+++ b/src/app/api/polar/webhook/resolve-order.ts
+import type { CreditReason } from "@/lib/db/store";
+import { bundleByKey, bundleByProductId } from "@/lib/tokens/economy";
+
+/**
+ * Pure resolution of a verified Polar webhook event into the token-ledger
+ * action it implies (a purchase credit or a refund clawback), or null when the
+ * event is irrelevant or under-specified.
+ *
+ * Lives in its own module (not inline in route.ts) so the money-moving logic is
+ * unit-testable without dragging the route's server-only `credit()` /
+ * signature-verification dependencies into the Node test runner — the same
+ * pattern as categorize/parse-request.ts. The route stays a thin shell:
+ * verify signature → resolveCreditAction → credit().
+ *
+ * Behaviour mirrors the historic inline logic exactly:
+ *   • order.paid / order.created → +bundle.tokens, reason "purchase",
+ *     idempotency ref = order id. Bundle is resolved by explicit
+ *     metadata.bundle key first, then falling back to the Polar product id.
+ *   • refund.created / order.refunded → -bundle.tokens, reason "refund",
+ *     idempotency ref = "refund:<order id>". Bundle is resolved by the
+ *     metadata.bundle key ONLY (a refund has no product id to fall back on).
+ * Any event missing a userId or an identifiable bundle yields null (no-op).
+ */
+export type WebhookEvent = { type: string; data: Record<string, unknown> };
+
+export type CreditAction = {
+  userId: string;
+  amount: number;
+  reason: CreditReason;
+  ref: string;
+  metadata: { bundle: string };
+};
+
+const PURCHASE_EVENTS = new Set(["order.paid", "order.created"]);
+const REFUND_EVENTS = new Set(["refund.created", "order.refunded"]);
+
+export function resolveCreditAction(event: WebhookEvent): CreditAction | null {
+  if (PURCHASE_EVENTS.has(event.type)) {
+    const order = event.data as {
+      id: string;
+      productId?: string;
+      product_id?: string;
+      metadata?: Record<string, string>;
+    };
+    const userId = order.metadata?.userId;
+    const productId = order.productId ?? order.product_id;
+    const b =
+      (order.metadata?.bundle && bundleByKey(order.metadata.bundle)) ||
+      (productId ? bundleByProductId(productId) : undefined);
+    if (!userId || !b) return null;
+    return {
+      userId,
+      amount: b.tokens,
+      reason: "purchase",
+      ref: order.id,
+      metadata: { bundle: b.key },
+    };
+  }
+
+  if (REFUND_EVENTS.has(event.type)) {
+    const order = event.data as {
+      id: string;
+      metadata?: Record<string, string>;
+    };
+    const userId = order.metadata?.userId;
+    const b = order.metadata?.bundle
+      ? bundleByKey(order.metadata.bundle)
+      : undefined;
+    if (!userId || !b) return null;
+    return {
+      userId,
+      amount: -b.tokens,
+      reason: "refund",
+      ref: `refund:${order.id}`,
+      metadata: { bundle: b.key },
+    };
+  }
+
+  return null;
+}
+

