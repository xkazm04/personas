+// Central auth configuration. Imported on both client and server, so it must
+// NOT use `server-only` and must rely on NEXT_PUBLIC_* vars for anything the
+// browser needs. This app is Firebase-only (GCP Identity Platform); the
+// former Supabase fallback has been removed.
+
+import { isFirebaseConfigured } from "@/lib/firebase/config";
+
+/** True only when the cloud auth provider (Firebase) is configured. Everything
+ *  gates on this so the app builds & runs with no secrets (graceful
+ *  degradation). */
+export function isAuthConfigured(): boolean {
+  return isFirebaseConfigured();
+}
+
+/** Loosened LOCAL auth: when DEV_AUTH=1 in development, getUser() returns a
+ *  fixed dev user with no cloud / OAuth round-trip. Never honored in
+ *  production, so it can't be flipped on by accident in a real deploy. */
+export function isDevAuth(): boolean {
+  return process.env.DEV_AUTH === "1" && process.env.NODE_ENV !== "production";
+}
+
+/** True when SOME auth source can identify a user — real Firebase OR dev-auth.
+ *  The token guard / balance surfaces gate on this so local PGlite + dev-auth
+ *  meters for real instead of falling through to the unconfigured free pass. */
+export function isAuthAvailable(): boolean {
+  return isAuthConfigured() || isDevAuth();
+}
+
+/** Bump when consent copy changes; recorded against each consent row. */
+export const CONSENT_VERSION =
+  process.env.NEXT_PUBLIC_CONSENT_VERSION ?? "2026-05-29";
+

