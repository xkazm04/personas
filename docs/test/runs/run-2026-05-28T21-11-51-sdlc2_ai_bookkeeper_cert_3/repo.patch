+import { test, expect } from "@playwright/test";
+
+// Regression guard for ADR 0006 (stabilization: home-route link & navigation).
+//
+// The home/brand link in the site header must be a real next/link client
+// route — NOT a raw <a href="/"> (which @next/next/no-html-link-for-pages
+// forbids, and which forces a full document reload). `eslint .` is the
+// structural guard against the raw <a>; this spec is the *behavioral* guard
+// that the brand link actually performs client-side navigation back to /.
+//
+// Follows the existing @playwright/test convention in this dir (see
+// dashboard.spec.ts) — the dev server + baseURL auto-boot via
+// playwright.config.ts.
+test.describe("home navigation", () => {
+  test("brand link returns to / via client navigation (no full reload)", async ({
+    page,
+  }) => {
+    await page.goto("/pricing");
+
+    // Tag the live window. A full document reload (raw <a>) recreates the
+    // window and clears this flag; a client-side next/link navigation keeps it.
+    await page.evaluate(() => {
+      (window as unknown as { __noReload?: boolean }).__noReload = true;
+    });
+
+    // The footer "Ledgerline" is a plain <span>, so the only link whose
+    // accessible name contains "Ledgerline" is the header brand link.
+    // .first() pins to the header regardless.
+    await page
+      .getByRole("link", { name: /Ledgerline/ })
+      .first()
+      .click();
+
+    await expect(page).toHaveURL(/\/$/);
+
+    // SPA navigation preserved the window → no full reload occurred.
+    const noReload = await page.evaluate(
+      () => (window as unknown as { __noReload?: boolean }).__noReload,
+    );
+    expect(noReload).toBe(true);
+
+    // Home route rendered.
+    await expect(page.getByRole("heading", { level: 1 })).toBeVisible();
+  });
+});

