+// Deterministic content hash for the id fallback (see normalize). Same
+// cheap rolling hash used by the cert stub — not cryptographic, just
+// stable + length-bounded so identical payloads map to identical ids.
+function stableHash(obj: object): string {
+  const json = JSON.stringify(obj);
+  let hash = 0;
+  for (let i = 0; i < json.length; i++) {
+    hash = ((hash << 5) - hash + json.charCodeAt(i)) | 0;
+  }
+  return (hash >>> 0).toString(36);
+}
+
+export function toNum(v: string | number | null | undefined): number | null {
   if (v == null || v === "") return null;
-  if (typeof v === "string" && v.toLowerCase().trim() === "none") return null;
-  const n = typeof v === "number" ? v : Number(v.replace(/[^0-9.-]/g, ""));
+  if (typeof v === "number") return Number.isFinite(v) ? v : null;
+  if (v.toLowerCase().trim() === "none") return null;
+  const cleaned = v.replace(/[^0-9.-]/g, "");
+  // Guard: a string with no digits (e.g. "not a number") strips to "" and
+  // Number("") === 0. Without this check junk would become a $0 award and
+  // poison awardSize scoring. Require at least one digit before parsing.
+  if (!/\d/.test(cleaned)) return null;
+  const n = Number(cleaned);
