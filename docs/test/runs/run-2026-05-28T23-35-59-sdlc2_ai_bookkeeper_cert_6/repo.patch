+  assert.equal(formatMoneyCompact(880_000, "USD"), "$880K");
+  assert.equal(formatMoneyCompact(1_250_000, "USD"), "$1.3M");
+  assert.equal(formatMoneyCompact(999, "USD"), "$999");
+  assert.equal(formatMoneyCompact(0, "USD"), "$0");
+});
+
+test("formatMoneyCompact is fail-loud on non-finite values", () => {
+  assert.throws(() => formatMoneyCompact(NaN, "USD"), MoneyArithmeticError);
+  assert.throws(() => formatMoneyCompact(Infinity, "USD"), MoneyArithmeticError);
+});
