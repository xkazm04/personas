+// Currency-aware money formatting for the display layer.
+//
+// This is the display-side pair to the `round.ts` / `arithmetic.ts` stack in the
+// shared money kernel (`src/lib/money`, ADR 0005). Where `roundMoney` (ADR 0002)
+// and `addMoney`/`subtractMoney` (ADR 0003) keep the *stored* value canonical,
+// `formatMoney` turns that canonical value into a human-readable string ÔÇö and
+// does so by first normalizing through `roundMoney`, so what the user sees can
+// never disagree with what the ledger stores by float drift. Symbol placement,
+// grouping, and minor-unit precision are delegated to `Intl.NumberFormat`
+// (style: "currency"), which is locale- and currency-correct by construction
+// ($1,234.50 / 1.234,56 ÔéČ / ┬ą1,235).
+//
+// Pure, side-effect-free, fail-loud. A non-finite value or a mixed-currency
+// `Money` is a corrupt figure and throws a `MoneyArithmeticError` (ADR 0003's
+// typed error) rather than rendering a misleading string.
+
+import { type CurrencyCode, roundMoney } from "./round";
+import { MoneyArithmeticError, type MoneyInput } from "./arithmetic";
+
+/**
+ * Resolve a `MoneyInput` to a finite number in `currency`, or throw the same
+ * typed error `arithmetic.ts` uses. A tagged `Money` whose currency differs from
+ * `currency` is the only expressible mixed-currency format request ÔÇö rejected so
+ * a EUR amount is never silently rendered with a USD symbol.
+ */
+function resolveValue(value: MoneyInput, currency: CurrencyCode): number {
+  let amount: number;
+
+  if (typeof value === "number") {
+    amount = value;
+  } else if (value != null && typeof value === "object") {
+    if (value.currency !== currency) {
+      throw new MoneyArithmeticError(
+        "mixed-currency",
+        `Cannot format value: currency ${String(value.currency)} does not ` +
+          `match format currency ${currency}.`,
+      );
+    }
+    amount = value.amount;
+  } else {
+    throw new MoneyArithmeticError(
+      "not-finite",
+      `Value to format must be a number or Money, received ${String(value)}.`,
+    );
+  }
+
+  if (typeof amount !== "number" || !Number.isFinite(amount)) {
+    throw new MoneyArithmeticError(
+      "not-finite",
+      `Value to format must be a finite number, received ${String(amount)}.`,
+    );
+  }
+  return amount;
+}
+
+/** Display-shaping options for `formatMoney` ÔÇö never affect the stored value,
+ *  only how the (already drift-normalized) figure is rendered. */
+export interface MoneyFormatOptions {
+  /**
+   * Override the currency's default minor-unit digit count for *display only*
+   * (sets both min and max fraction digits). The value is still normalized to
+   * the currency's true minor units via `roundMoney` first, so this only
+   * controls rendered precision ÔÇö e.g. whole-dollar display (`0`) for compact
+   * dashboards. Omit to use the currency's natural precision (USDÔćĺ2, JPYÔćĺ0).
+   */
+  fractionDigits?: number;
+  /** Render with `Intl` compact notation ($1.3M, ┬ą1,235, 880 KÔéČ). */
+  compact?: boolean;
+}
+
+/**
+ * Format a money `value` as a locale-correct currency string.
+ *
+ * - **`Intl.NumberFormat` (style: "currency")** drives symbol placement,
+ *   digit grouping, and minor-unit precision ÔÇö so JPY renders with zero decimals,
+ *   USD with two, and the symbol sits where the locale expects it.
+ * - **`locale` defaults to `"en-US"`** when omitted.
+ * - **Normalized through `roundMoney` first** (ADR 0002), so the formatted string
+ *   reflects the canonical stored value: `formatMoney(addMoney(0.1, 0.2, "USD"),
+ *   "USD")` is exactly `"$0.30"`, never `"$0.30000000000000004"` and never a
+ *   value that drifted from what arithmetic stored.
+ * - **`options`** (ADR 0005) shapes display only: `fractionDigits` overrides
+ *   rendered precision; `compact` switches to abbreviated notation.
+ * - **Fail-loud:** a non-finite value or a mixed-currency `Money` throws a
+ *   `MoneyArithmeticError` (ADR 0003); a blank/invalid currency throws via
+ *   `roundMoney`/`minorUnits` (`RangeError`).
+ *
+ * @throws MoneyArithmeticError if `value` is non-finite or carries a different
+ *   currency; RangeError if `currency` is blank or unknown to `Intl`.
+ */
+export function formatMoney(
+  value: MoneyInput,
+  currency: CurrencyCode,
+  locale: string = "en-US",
+  options: MoneyFormatOptions = {},
+): string {
+  const amount = resolveValue(value, currency);
+
+  // Normalize to the currency's canonical minor-unit value before display.
+  // roundMoney also re-validates the currency code and the finite invariant,
+  // and normalizes -0 Ôćĺ 0 so we never render "-$0.00".
+  const normalized = roundMoney(amount, currency);
+
+  // Intl is authoritative for locale-correct symbol/grouping/precision. By
+  // default we let it derive fraction digits from the currency (USDÔćĺ2, JPYÔćĺ0,
+  // BHDÔćĺ3), which matches roundMoney's minor-unit table for standard ISO-4217
+  // codes. Display options only narrow how that canonical figure is shown.
+  const intlOptions: Intl.NumberFormatOptions = {
+    style: "currency",
+    currency,
+  };
+  if (options.fractionDigits !== undefined) {
+    intlOptions.minimumFractionDigits = options.fractionDigits;
+    intlOptions.maximumFractionDigits = options.fractionDigits;
+  }
+  if (options.compact) {
+    intlOptions.notation = "compact";
+  }
+
+  return new Intl.NumberFormat(locale, intlOptions).format(normalized);
+}
+
+/**
+ * Compact (abbreviated) currency display for dashboards and visuals
+ * ($880K, $1.3M, ┬ą1,235). The single drift-safe replacement for hand-rolled
+ * `` `$${(v/1e6).toFixed(1)}M` `` abbreviators (ADR 0005 Task 4): the figure is
+ * normalized through `roundMoney` first and abbreviation is delegated to `Intl`
+ * compact notation, so it is currency-aware and can never disagree with the
+ * stored value. `Intl` compact's default precision matches the prior style
+ * ($880,000 Ôćĺ "$880K", $1,250,000 Ôćĺ "$1.3M").
+ *
+ * Values below the currency's first compact threshold render in full
+ * (`$999`, `$0`), matching the old `< 1_000` fall-through.
+ *
+ * @throws MoneyArithmeticError / RangeError on the same fail-loud conditions as
+ *   `formatMoney`.
+ */
+export function formatMoneyCompact(
+  value: MoneyInput,
+  currency: CurrencyCode,
+  locale: string = "en-US",
+): string {
+  return formatMoney(value, currency, locale, { compact: true });
+}
