+// Golden-string tests for the app-wide display formatters.
+//
+// These lock the back-compat contract after ADR 0005 re-implemented
+// formatCurrency / formatSignedCurrency as kernel-backed wrappers: the rendered
+// strings (incl. the U+2212 signed-minus the UI relies on) must not shift, and
+// formatting must now be drift-safe via the money kernel.
+//   npx tsx --test ./src/lib/format.test.ts
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import {
+  formatCurrency,
+  formatSignedCurrency,
+  formatNumber,
+  formatPercent,
+} from "./format";
+
+test("formatCurrency: cents by default, whole dollars when decimals=false", () => {
+  assert.equal(formatCurrency(1234.5), "$1,234.50");
+  assert.equal(formatCurrency(7), "$7.00");
+  assert.equal(formatCurrency(880, false), "$880");
+  assert.equal(formatCurrency(880000, false), "$880,000");
+});
+
+test("formatCurrency is drift-safe (normalized through the money kernel)", () => {
+  // 0.1 + 0.2 === 0.30000000000000004 ÔÇö must still render as $0.30.
+  assert.equal(formatCurrency(0.1 + 0.2), "$0.30");
+});
+
+test("formatSignedCurrency: + prefix, U+2212 minus, unsigned zero", () => {
+  assert.equal(formatSignedCurrency(5), "+$5.00");
+  assert.equal(formatSignedCurrency(-5), "Ôłĺ$5.00");
+  assert.equal(formatSignedCurrency(0), "$0.00");
+  // The negative sign is the U+2212 MINUS SIGN, not an ASCII hyphen.
+  assert.ok(formatSignedCurrency(-5).startsWith("Ôłĺ"));
+  assert.ok(!formatSignedCurrency(-5).startsWith("-"));
+});
+
+test("formatNumber / formatPercent are unchanged", () => {
+  assert.equal(formatNumber(1234567), "1,234,567");
+  assert.equal(formatPercent(42), "42%");
+  assert.equal(formatPercent(42.5, 1), "42.5%");
+});
