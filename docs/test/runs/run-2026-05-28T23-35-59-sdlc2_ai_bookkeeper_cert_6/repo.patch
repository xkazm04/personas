diff --git a/src/features/ledger/lib/arithmetic.ts b/src/features/ledger/lib/arithmetic.ts
index e4f20e7..3af973b 100644
--- a/src/features/ledger/lib/arithmetic.ts
+++ b/src/features/ledger/lib/arithmetic.ts
@@ -1,135 +1,7 @@
-// Currency-aware money addition and subtraction.
+// Back-compat re-export shim (ADR 0005).
 //
-// Builds directly on `round.ts`: arithmetic is performed at the currency's
-// minor-unit precision (cents for USD, none for JPY, mils for BHD) by scaling
-// each operand to integer minor units, doing the add/subtract in integer space,
-// then scaling back. This is what makes `0.1 + 0.2` yield exactly `0.30` for USD
-// instead of IEEE-754's `0.30000000000000004` ÔÇö the float drift never survives
-// the round-trip through integers. The final figure is passed through
-// `roundMoney` so the result is canonical to the currency's minor units and the
-// half-even tie convention (ADR 0002) is the single source of truth for rounding.
-//
-// Pure, side-effect-free, fail-loud ÔÇö matching `amount.ts` / `round.ts`. A
-// non-finite operand or a currency mismatch is a corrupt money figure and throws
-// rather than silently propagating into balances (cf. ADR 0001/0002 boundary).
-
-import { type CurrencyCode, minorUnits, roundMoney } from "./round";
-
-/** A money figure tagged with its currency. Operands may be passed either as a
- *  bare `number` (already in the operation's `currency`) or as a tagged `Money`,
- *  in which case its `currency` must match ÔÇö this is how a mixed-currency add is
- *  detected and rejected rather than silently producing a meaningless sum. */
-export interface Money {
-  amount: number;
-  currency: CurrencyCode;
-}
-
-/** A bare amount (assumed to be in the operation's currency) or a tagged Money. */
-export type MoneyInput = number | Money;
-
-/** Discriminates the two ways a money operation can be rejected. */
-export type MoneyArithmeticErrorCode = "mixed-currency" | "not-finite";
-
-/**
- * Typed error for invalid money arithmetic. Extends `RangeError` so existing
- * fail-loud catch sites (which already expect `RangeError` from `roundMoney` /
- * `parseAmount`) keep working, while `.code` lets callers distinguish *why*.
- */
-export class MoneyArithmeticError extends RangeError {
-  readonly code: MoneyArithmeticErrorCode;
-  constructor(code: MoneyArithmeticErrorCode, message: string) {
-    super(message);
-    this.name = "MoneyArithmeticError";
-    this.code = code;
-  }
-}
-
-/** Resolve a MoneyInput to a finite number in `currency`, or throw a typed error. */
-function resolveOperand(
-  operand: MoneyInput,
-  currency: CurrencyCode,
-  label: string,
-): number {
-  let amount: number;
-
-  if (typeof operand === "number") {
-    amount = operand;
-  } else if (operand != null && typeof operand === "object") {
-    if (operand.currency !== currency) {
-      throw new MoneyArithmeticError(
-        "mixed-currency",
-        `Cannot operate on ${label}: currency ${String(operand.currency)} ` +
-          `does not match operation currency ${currency}.`,
-      );
-    }
-    amount = operand.amount;
-  } else {
-    throw new MoneyArithmeticError(
-      "not-finite",
-      `Operand ${label} must be a number or Money, received ${String(operand)}.`,
-    );
-  }
-
-  if (typeof amount !== "number" || !Number.isFinite(amount)) {
-    throw new MoneyArithmeticError(
-      "not-finite",
-      `Operand ${label} must be a finite number, received ${String(amount)}.`,
-    );
-  }
-  return amount;
-}
-
-/**
- * Core integer-space combine. Both operands are scaled to integer minor units
- * (absorbing the float noise that makes `0.1 * 100 === 10.000000000000002`),
- * combined as integers, scaled back, then run through `roundMoney` so the result
- * is canonical and half-even per ADR 0002.
- */
-function combine(
-  a: MoneyInput,
-  b: MoneyInput,
-  currency: CurrencyCode,
-  sign: 1 | -1,
-): number {
-  // `minorUnits` validates the currency code (throws RangeError on blank).
-  const factor = 10 ** minorUnits(currency);
-
-  const aMinor = Math.round(resolveOperand(a, currency, "a") * factor);
-  const bMinor = Math.round(resolveOperand(b, currency, "b") * factor);
-
-  // Integer arithmetic ÔÇö no sub-unit drift. Result divided back to a decimal,
-  // then canonicalized (handles -0 normalization and any residual float noise).
-  const resultMinor = aMinor + sign * bMinor;
-  return roundMoney(resultMinor / factor, currency);
-}
-
-/**
- * Add two money figures of the same `currency`, at the currency's minor-unit
- * precision. Composes with `roundMoney` (ADR 0002) for the final value.
- *
- * @throws MoneyArithmeticError if an operand is non-finite or carries a
- *   different currency; RangeError if `currency` is blank/invalid.
- */
-export function addMoney(
-  a: MoneyInput,
