@@ -0,0 +1,101 @@
+// Currency-aware monetary rounding (banker's rounding / round-half-to-even).
+//
+// `amount.ts` validates amounts at the input boundary and canonicalizes USD to
+// two decimals with `roundToCents` (half-UP via Math.round). This module is the
+// general arithmetic primitive for rounding a money value to *any* currency's
+// minor units using half-EVEN, the convention financial systems use to avoid
+// the upward bias half-up introduces when summing many rows (see ADR 0001's
+// "residual risk: sub-cent drift in aggregates").
+//
+// Half-even means a value exactly halfway between two representable units
+// rounds toward the even neighbour: 0.005 Ôćĺ 0.00, 0.015 Ôćĺ 0.02, 2.675 Ôćĺ 2.68.
+//
+// Pure, side-effect-free, matching the repo's other co-located libs
+// (amount.ts, customers/lib/normalize.ts, benchmarks/lib/categorize.ts).
+
+/** ISO-4217-style code. Kept as a widened string so callers aren't blocked on
+ *  an exhaustive enum; unknown codes fall back to DEFAULT_MINOR_UNITS. */
+export type CurrencyCode = string;
+
+/** Minor-unit (decimal) digits per currency. Most are 2; a few common
+ *  exceptions are spelled out. Unlisted codes default to 2. */
+export const MINOR_UNITS: Readonly<Record<string, number>> = {
+  USD: 2,
+  EUR: 2,
+  GBP: 2,
+  CAD: 2,
+  AUD: 2,
+  CHF: 2,
+  CNY: 2,
+  // zero-decimal currencies
+  JPY: 0,
+  KRW: 0,
+  CLP: 0,
+  ISK: 0,
+  VND: 0,
+  // three-decimal currencies
+  BHD: 3,
+  KWD: 3,
+  OMR: 3,
+  TND: 3,
+};
+
+/** Minor-unit digits for any currency not listed in MINOR_UNITS. */
+export const DEFAULT_MINOR_UNITS = 2;
+
+/** Resolve a currency's minor-unit digit count (case-insensitive). */
+export function minorUnits(currency: CurrencyCode): number {
+  if (typeof currency !== "string" || currency.trim() === "") {
+    throw new RangeError("roundMoney: currency must be a non-empty string code.");
+  }
+  const units = MINOR_UNITS[currency.trim().toUpperCase()];
+  return units ?? DEFAULT_MINOR_UNITS;
+}
+
+// Floating-point ties are never exactly representable ÔÇö 0.005 * 100 is
+// 0.49999999999999994, not 0.5 ÔÇö so half-detection uses an epsilon. This is
+// reliable while the scaled magnitude stays within Number.MAX_SAFE_INTEGER
+// (~9.0e15); beyond that, integer spacing exceeds 1 and the input no longer
+// carries sub-unit precision anyway.
+const HALF_EPSILON = 1e-9;
+
+/**
+ * Round a monetary `value` to `currency`'s minor units using banker's rounding
+ * (round-half-to-even).
+ *
+ * NaN/Infinity-safe in the strict sense: a non-finite `value` is a corrupt
+ * money figure, so it is rejected with a RangeError rather than silently
+ * propagating into balances ÔÇö consistent with the ledger's fail-loud boundary
+ * (cf. amount.ts rejecting `not-finite`). Callers that may hold untrusted input
+ * should validate via `parseAmount` first; this primitive assumes a real number.
+ *
+ * @throws RangeError if `value` is not a finite number, or `currency` is blank.
+ */
+export function roundMoney(value: number, currency: CurrencyCode): number {
+  if (typeof value !== "number" || !Number.isFinite(value)) {
+    throw new RangeError(
+      `roundMoney: value must be a finite number, received ${String(value)}.`,
+    );
+  }
+
+  const digits = minorUnits(currency);
+  const factor = 10 ** digits;
+  const scaled = value * factor;
+
+  const floor = Math.floor(scaled);
+  const remainder = scaled - floor;
+
+  let roundedUnits: number;
+  if (Math.abs(remainder - 0.5) <= HALF_EPSILON) {
+    // Exact half: pick the even neighbour.
+    roundedUnits = floor % 2 === 0 ? floor : floor + 1;
+  } else {
+    // Not a tie: ordinary nearest. Math.round breaks its own ties upward, but
+    // ties are handled above, so only genuine non-half values reach here.
+    roundedUnits = Math.round(scaled);
+  }
+
+  const result = roundedUnits / factor;
+  // Normalize -0 to 0 so formatters and equality checks behave.
+  return result === 0 ? 0 : result;
+}

