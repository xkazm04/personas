+// Unit tests for fiscal-period mapping (ADR 0006).
+//
+// Runner: Node's built-in test runner via the tsx loader. Run the whole suite
+// with `npm test` (globs src/**/*.test.ts), or this file alone with:
+//   npx tsx --test ./src/features/ledger/lib/period.test.ts
+//
+// Dates are constructed with the numeric `new Date(y, mIndex, d)` constructor
+// (mIndex is 0-based) so the tests are timezone-deterministic ‚Äî never
+// `new Date("2026-01-15")`, which parses as UTC midnight.
+
+import assert from "node:assert/strict";
+import { test } from "node:test";
+import { getFiscalPeriod } from "./period";
+
+test("calendar-year default: Jan 15 ‚Üí quarter 1, fiscal month 1", () => {
+  const p = getFiscalPeriod(new Date(2026, 0, 15));
+  assert.equal(p.year, 2026);
+  assert.equal(p.quarter, 1);
+  assert.equal(p.month, 1);
+});
+
+test("July fiscal start: Jul 1 ‚Üí fiscal month 1, quarter 1, year 2026", () => {
+  const p = getFiscalPeriod(new Date(2026, 6, 1), 7);
+  assert.equal(p.year, 2026);
+  assert.equal(p.quarter, 1);
+  assert.equal(p.month, 1);
+});
+
+test("July fiscal start: Mar 15 ‚Üí prior fiscal year 2025, quarter 3, month 9", () => {
+  const p = getFiscalPeriod(new Date(2026, 2, 15), 7);
+  assert.equal(p.year, 2025);
+  assert.equal(p.quarter, 3);
+  assert.equal(p.month, 9);
+});
+
+test("calendar-year default: Dec 31 ‚Üí quarter 4, fiscal month 12", () => {
+  const p = getFiscalPeriod(new Date(2026, 11, 31));
+  assert.equal(p.year, 2026);
+  assert.equal(p.quarter, 4);
+  assert.equal(p.month, 12);
+});
+
+test("leap-year Feb 29: periodEnd is Feb 29 23:59:59.999, no throw", () => {
+  const p = getFiscalPeriod(new Date(2024, 1, 29));
+  assert.equal(p.periodStart.getTime(), new Date(2024, 1, 1, 0, 0, 0, 0).getTime());
+  assert.equal(p.periodEnd.getTime(), new Date(2024, 1, 29, 23, 59, 59, 999).getTime());
+  assert.equal(p.periodEnd.getDate(), 29);
+});
+
+test("period boundaries are contiguous and non-overlapping (Mar ‚Üí Apr)", () => {
+  const mar = getFiscalPeriod(new Date(2026, 2, 10));
+  const apr = getFiscalPeriod(new Date(2026, 3, 10));
+  // March ends Mar 31 23:59:59.999, April starts Apr 1 00:00:00.000.
+  assert.equal(mar.periodEnd.getTime(), new Date(2026, 2, 31, 23, 59, 59, 999).getTime());
+  assert.equal(apr.periodStart.getTime(), new Date(2026, 3, 1, 0, 0, 0, 0).getTime());
+  // Exactly 1ms apart ‚Äî no gap, no overlap.
+  assert.equal(apr.periodStart.getTime() - mar.periodEnd.getTime(), 1);
+});
+
+test("invalid fiscalYearStartMonth=0 throws RangeError", () => {
+  assert.throws(() => getFiscalPeriod(new Date(2026, 0, 15), 0), RangeError);
+});
+
+test("invalid fiscalYearStartMonth=13 throws RangeError", () => {
+  assert.throws(() => getFiscalPeriod(new Date(2026, 0, 15), 13), RangeError);
+});
+
+test("non-finite date throws RangeError", () => {
+  assert.throws(() => getFiscalPeriod(new Date(NaN)), RangeError);
+});
+
+test("non-Date argument throws RangeError", () => {
+  // @ts-expect-error ‚Äî guarding the runtime boundary, not the type boundary.
+  assert.throws(() => getFiscalPeriod("2026-01-15"), RangeError);
+});
