+// Fiscal-period mapping for a calendar Date (ADR 0006).
+//
+// Maps an arbitrary `Date` to the fiscal period that contains it so reporting
+// code can group transactions by fiscal year / quarter / month. This is a pure
+// date utility with *no* money semantics ‚Äî it does not touch roundMoney /
+// addMoney / formatMoney and is independent of ADR 0001‚Äì0005.
+//
+// Two conventions are pinned here (the spec left them open):
+//
+//   1. The "period" unit is the CALENDAR MONTH containing the date ‚Äî the
+//      ERP/bookkeeping accounting-period convention. `periodStart`/`periodEnd`
+//      therefore bound that calendar month (local time).
+//   2. The fiscal-year LABEL (`year`) is the calendar year in which the fiscal
+//      year STARTS. With a July start, Mar 2026 belongs to fiscal year 2025.
+//
+// All derivation uses LOCAL date accessors (getFullYear/getMonth/getDate) and
+// the numeric Date constructor so results are timezone-deterministic ‚Äî never
+// parse from an ISO string here.
+//
+// Pure, side-effect-free, fail-loud with RangeError, matching the repo's other
+// co-located ledger libs (round.ts, arithmetic.ts, format.ts, trial-balance.ts).
+
+/** A fiscal period: the calendar month containing a date, labelled against a
+ *  configurable fiscal-year start. */
+export interface FiscalPeriod {
+  /** Fiscal-year label = the calendar year in which the fiscal year starts. */
+  year: number;
+  /** Fiscal quarter, 1‚Äì4. */
+  quarter: 1 | 2 | 3 | 4;
+  /** Fiscal month number, 1‚Äì12 (1 = first month of the fiscal year). */
+  month: number;
+  /** First day of the calendar month containing `date`, local 00:00:00.000. */
+  periodStart: Date;
+  /** Last day of that calendar month, local 23:59:59.999. */
+  periodEnd: Date;
+}
+
+/**
+ * Resolve the fiscal period containing `date`.
+ *
+ * @param date A valid Date.
+ * @param fiscalYearStartMonth The calendar month (1‚Äì12) the fiscal year starts
+ *   on. Defaults to 1 (the fiscal year equals the calendar year).
+ *
+ * @throws RangeError if `date` is not a finite Date, or `fiscalYearStartMonth`
+ *   is supplied and is not an integer in 1..12 (so 0 and 13 are rejected).
+ */
+export function getFiscalPeriod(
+  date: Date,
+  fiscalYearStartMonth: number = 1,
+): FiscalPeriod {
+  if (!(date instanceof Date) || !Number.isFinite(date.getTime())) {
+    throw new RangeError(
+      `getFiscalPeriod: date must be a valid Date, received ${String(date)}.`,
+    );
+  }
+  if (
+    !Number.isInteger(fiscalYearStartMonth) ||
+    fiscalYearStartMonth < 1 ||
+    fiscalYearStartMonth > 12
+  ) {
+    throw new RangeError(
+      `getFiscalPeriod: fiscalYearStartMonth must be an integer in 1..12, received ${String(
+        fiscalYearStartMonth,
+      )}.`,
+    );
+  }
+
+  const calYear = date.getFullYear();
+  const calMonth = date.getMonth() + 1; // getMonth is 0-based.
+
+  const fiscalMonth = ((calMonth - fiscalYearStartMonth + 12) % 12) + 1;
+  const quarter = (Math.floor((fiscalMonth - 1) / 3) + 1) as 1 | 2 | 3 | 4;
+  const year = calMonth >= fiscalYearStartMonth ? calYear : calYear - 1;
+
+  const periodStart = new Date(calYear, calMonth - 1, 1, 0, 0, 0, 0);
+  // Day 0 of the next month = last day of this month; leap Feb ‚Üí 29 naturally.
+  const periodEnd = new Date(calYear, calMonth, 0, 23, 59, 59, 999);
+
+  return { year, quarter, month: fiscalMonth, periodStart, periodEnd };
+}

