+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { clamp, roundTo } from "./num";
+
+// --- clamp ---
+
+test("clamp returns value when within range", () => {
+  assert.equal(clamp(5, 0, 10), 5);
+});
+
+test("clamp pins to min and max at the bounds", () => {
+  assert.equal(clamp(-3, 0, 10), 0);
+  assert.equal(clamp(99, 0, 10), 10);
+  assert.equal(clamp(0, 0, 10), 0);
+  assert.equal(clamp(10, 0, 10), 10);
+});
+
+test("clamp snaps ±Infinity value to the nearer bound", () => {
+  assert.equal(clamp(Infinity, 0, 10), 10);
+  assert.equal(clamp(-Infinity, 0, 10), 0);
+});
+
+test("clamp propagates a NaN value as NaN", () => {
+  assert.ok(Number.isNaN(clamp(NaN, 0, 10)));
+});
+
+test("clamp throws RangeError when min > max", () => {
+  assert.throws(() => clamp(5, 10, 0), RangeError);
+});
+
+test("clamp throws RangeError on a non-finite bound", () => {
+  assert.throws(() => clamp(5, 0, Infinity), RangeError);
+  assert.throws(() => clamp(5, NaN, 10), RangeError);
+});
+
+// --- roundTo ---
+
+test("roundTo beats binary float error (1.005 → 1.01)", () => {
+  assert.equal(roundTo(1.005, 2), 1.01);
+  assert.equal(roundTo(2.345, 2), 2.35);
+});
+
+test("roundTo defaults to whole numbers", () => {
+  assert.equal(roundTo(2.5), 3);
+  assert.equal(roundTo(2.4), 2);
+});
+
+test("roundTo returns non-finite value unchanged", () => {
+  assert.equal(roundTo(Infinity, 2), Infinity);
+  assert.ok(Number.isNaN(roundTo(NaN, 2)));
+});
+
+test("roundTo treats negative/NaN decimals as 0", () => {
+  assert.equal(roundTo(3.7, -2), 4);
+  assert.equal(roundTo(3.7, NaN), 4);
+});
