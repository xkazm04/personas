@@ -0,0 +1,39 @@
+/**
+ * Numeric helpers with explicit, tested handling of NaN/Infinity edge cases.
+ */
+
+/**
+ * Clamp `value` into the inclusive range [min, max].
+ *
+ * - `±Infinity` value snaps to the nearer bound.
+ * - `NaN` value propagates as `NaN` (no silent coercion).
+ * - Invalid bounds (`min > max`, or a non-finite bound) throw `RangeError` —
+ *   a bad range is a programming error, not data to be papered over.
+ */
+export function clamp(value: number, min: number, max: number): number {
+  if (!Number.isFinite(min) || !Number.isFinite(max)) {
+    throw new RangeError(`clamp: bounds must be finite (min=${min}, max=${max})`);
+  }
+  if (min > max) {
+    throw new RangeError(`clamp: min (${min}) must not exceed max (${max})`);
+  }
+  if (Number.isNaN(value)) return NaN;
+  return Math.min(Math.max(value, min), max);
+}
+
+/**
+ * Round `value` to `decimals` places, beating binary-float error.
+ *
+ * Naive `Math.round(value * 10**d) / 10**d` mis-rounds 1.005 → 1.00 because
+ * 1.005 isn't exactly representable. Re-parsing via exponential notation
+ * sidesteps that, so `roundTo(1.005, 2) === 1.01`.
+ *
+ * - Non-finite `value` is returned unchanged.
+ * - Non-finite or negative `decimals` is treated as 0.
+ */
+export function roundTo(value: number, decimals = 0): number {
+  if (!Number.isFinite(value)) return value;
+  const d = Number.isFinite(decimals) && decimals > 0 ? Math.floor(decimals) : 0;
+  const shifted = Number(`${value}e${d}`);
+  return Number(`${Math.round(shifted)}e-${d}`);
+}
