+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { truncate, titleCase } from "./str";
+
+// --- truncate ---
+
+test("truncate leaves within-budget text unchanged", () => {
+  assert.equal(truncate("short", 10), "short");
+  assert.equal(truncate("exactly10!", 10), "exactly10!");
+});
+
+test("truncate counts the ellipsis against max (result length ≤ max)", () => {
+  const out = truncate("Hello world", 8);
+  assert.equal(out, "Hello w…");
+  assert.equal(out.length, 8);
+});
+
+test("truncate with max ≤ ellipsis length returns a prefix of the ellipsis", () => {
+  assert.equal(truncate("Hello world", 0), "");
+  assert.equal(truncate("Hello world", 1, "..."), ".");
+});
+
+test("truncate honors a custom multi-char ellipsis", () => {
+  const out = truncate("Hello world", 8, "...");
+  assert.equal(out, "Hello...");
+  assert.equal(out.length, 8);
+});
+
+// --- titleCase ---
+
+test("titleCase uppercases first letter, lowercases the rest", () => {
+  assert.equal(titleCase("hello world"), "Hello World");
+  assert.equal(titleCase("HELLO WORLD"), "Hello World");
+  assert.equal(titleCase("mIxEd CaSe"), "Mixed Case");
+});
+
+test("titleCase preserves whitespace runs", () => {
+  assert.equal(titleCase("hello   world"), "Hello   World");
+});
+
+test("titleCase handles empty and whitespace-only input", () => {
+  assert.equal(titleCase(""), "");
+  assert.equal(titleCase("   "), "   ");
+});
