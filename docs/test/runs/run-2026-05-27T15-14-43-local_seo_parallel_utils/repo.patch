+++ b/src/lib/str.ts
@@ -0,0 +1,27 @@
+/**
+ * String presentation helpers for SEO copy and table cells.
+ */
+
+/**
+ * Truncate `text` to at most `max` characters, counting the ellipsis against
+ * the budget so the result length is always ≤ `max`.
+ *
+ * - Text already within budget is returned unchanged.
+ * - When `max <= ellipsis.length`, returns a prefix of the ellipsis.
+ */
+export function truncate(text: string, max: number, ellipsis = "…"): string {
+  if (text.length <= max) return text;
+  if (max <= ellipsis.length) return ellipsis.slice(0, Math.max(0, max));
+  return text.slice(0, max - ellipsis.length) + ellipsis;
+}
+
+/**
+ * Title-case `text`: first character of each word uppercased, the rest
+ * lowercased. Original whitespace runs are preserved (split on word chars,
+ * not collapsed), so "hello   world" → "Hello   World".
+ */
+export function titleCase(text: string): string {
+  return text.replace(/\S+/g, (word) =>
+    word.charAt(0).toUpperCase() + word.slice(1).toLowerCase(),
+  );
+}

