+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { slugify } from "./slug";
+
+test("lowercases and hyphenates a simple phrase", () => {
+  assert.equal(slugify("Hello World"), "hello-world");
+});
+
+test("collapses runs of non-alphanumerics into a single hyphen", () => {
+  assert.equal(slugify("a   b___c!!!d"), "a-b-c-d");
+});
+
+test("strips leading and trailing separators", () => {
+  assert.equal(slugify("  --Best Plumber, Austin!--  "), "best-plumber-austin");
+});
+
+test("empty and all-separator inputs produce an empty string", () => {
+  assert.equal(slugify(""), "");
+  assert.equal(slugify("   "), "");
+  assert.equal(slugify("---!!!___"), "");
+});
+
+test("is idempotent on an already-slugified value", () => {
+  const once = slugify("SEO Services in San José");
+  assert.equal(slugify(once), once);
+});
+
+test("preserves digits", () => {
+  assert.equal(slugify("Top 10 Plumbers 2026"), "top-10-plumbers-2026");
+});
+
+test("is ASCII-only by design — diacritics become separators", () => {
+  assert.equal(slugify("Café déjà vu"), "caf-d-j-vu");
+});
