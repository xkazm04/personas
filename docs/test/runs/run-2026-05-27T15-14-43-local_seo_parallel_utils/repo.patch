+/**
+ * URL-safe slug generator for SEO paths (e.g. /locations/{city}-{service}).
+ *
+ * Pipeline: lowercase → trim → collapse every run of non-alphanumerics into a
+ * single hyphen → strip leading/trailing hyphens.
+ *
+ * ASCII-only by design: non-Latin characters (accents, CJK) are treated as
+ * separators, so "Café déjà vu" → "caf-d-j-vu". Diacritic folding
+ * (café → cafe) is intentionally out of scope — add it as a separate utility
+ * if SEO requires transliteration.
+ */
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .trim()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "");
+}
