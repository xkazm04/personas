+++ b/src/lib/db/row-schemas.ts
+// ─────────────────────────────────────────────────────────────────────────
+// Zod schemas for persisted Store rows, validated at the read boundary.
+//
+// Both stores map raw records (Firestore docs / pg rows) to domain types with
+// bare casts and silent fallbacks (`row.id as string`, `?? ""`), so a corrupt
+// or partially-written record surfaces as plausible-but-wrong data — an `id` of
+// undefined, an empty name — and flows undetected into the dashboard, recaps,
+// and LLM prompts. Running each mapped row through these schemas turns that into
+// a loud, observable drop (logged) instead of a silent data-integrity hole.
+//
+// Validation runs on the ALREADY-MAPPED domain row, so it's store-agnostic: one
+// schema guards both the Firestore and PGlite read paths.
+// ─────────────────────────────────────────────────────────────────────────
+import { z } from "zod";
+import { log } from "@/lib/log";
+import type { BusinessRow, ReviewRow } from "./store";
+
+export const BusinessRowSchema: z.ZodType<BusinessRow> = z.object({
+  id: z.string().min(1),
+  user_id: z.string().min(1),
+  name: z.string(),
+  city: z.string(),
+  vertical: z.string(),
+  website: z.string().nullable(),
+  gbp_connected: z.boolean(),
+  autopilot_enabled: z.boolean(),
+  created_at: z.string().min(1),
+});
+
+export const ReviewRowSchema: z.ZodType<ReviewRow> = z.object({
+  external_id: z.string().min(1),
+  author: z.string().nullable(),
+  rating: z.number(),
+  platform: z.string(),
+  text: z.string().nullable(),
+  state: z.string(),
+  review_date: z.string().nullable(),
+  draft_reply: z.string().nullable(),
+});
+
+/**
+ * Validate mapped rows at the read boundary, DROPPING (and logging) any that
+ * fail the schema rather than letting malformed data through. The good rows are
+ * returned unchanged; a corrupt persisted record becomes a debuggable warning.
+ */
+export function validateRows<T>(schema: z.ZodType<T>, rows: readonly T[], scope: string): T[] {
+  const ok: T[] = [];
+  for (const row of rows) {
+    const result = schema.safeParse(row);
+    if (result.success) {
+      ok.push(result.data);
+    } else {
+      log.warn(scope, "dropped malformed persisted row", {
+        issues: result.error.issues.slice(0, 3).map((i) => ({
+          path: i.path.join("."),
+          message: i.message,
+        })),
+      });
+    }
+  }
+  return ok;
+}
+
