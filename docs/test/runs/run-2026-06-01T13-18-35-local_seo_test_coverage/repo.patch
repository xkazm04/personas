+
+/** Sentinel returned by {@link readJson} when the body isn't valid JSON. */
+export const INVALID_JSON = Symbol("invalid-json");
+
+/**
+ * Read + JSON-parse a request body once, returning {@link INVALID_JSON} instead
+ * of throwing on a malformed body. Replaces the `try { await request.json() }
+ * catch { 400 }` block repeated across the API routes with one guarded call:
+ *
+ *   const body = await readJson(request);
+ *   if (body === INVALID_JSON) return NextResponse.json({ error: ... }, { status: 400 });
+ */
+export async function readJson(request: Request): Promise<unknown> {
+  try {
+    return await request.json();
+  } catch {
+    return INVALID_JSON;
+  }
+}
