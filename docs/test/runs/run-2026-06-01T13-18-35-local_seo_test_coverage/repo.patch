+/**
+ * Constant-time secret comparison. Hashes both sides to a fixed-length digest
+ * first so neither the result nor the timing leaks the secret's length, then
+ * compares the digests with crypto.timingSafeEqual.
+ */
+function secretMatches(provided: string, expected: string): boolean {
+  const a = createHash("sha256").update(provided).digest();
+  const b = createHash("sha256").update(expected).digest();
+  return timingSafeEqual(a, b);
+}
