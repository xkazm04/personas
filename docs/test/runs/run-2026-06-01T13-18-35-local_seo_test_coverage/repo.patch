+import { describe, it } from "node:test";
+import assert from "node:assert/strict";
+import {
+  VERTICALS,
+  VERTICAL_LABELS,
+  normalizeVertical,
+  verticalNoun,
+  type Vertical,
+} from "./verticals";
+
+describe("VERTICALS vocabulary", () => {
+  it("is the canonical, ordered, non-empty list ending in 'other'", () => {
+    assert.deepEqual(
+      [...VERTICALS],
+      ["dental", "hvac", "chiropractic", "med-spa", "law", "other"],
+    );
+    assert.equal(VERTICALS[VERTICALS.length - 1], "other");
+  });
+
+  it("has a display label for every vertical (no missing keys)", () => {
+    for (const v of VERTICALS) {
+      assert.equal(typeof VERTICAL_LABELS[v], "string");
+      assert.ok(VERTICAL_LABELS[v].length > 0, `label for ${v} is empty`);
+    }
+    assert.equal(Object.keys(VERTICAL_LABELS).length, VERTICALS.length);
+  });
+});
+
+describe("normalizeVertical", () => {
+  it("passes through every known vertical unchanged", () => {
+    for (const v of VERTICALS) {
+      assert.equal(normalizeVertical(v), v);
+    }
+  });
+
+  it("defaults unknown strings to 'other'", () => {
+    assert.equal(normalizeVertical("plumbing"), "other");
+    assert.equal(normalizeVertical("DENTAL"), "other"); // case-sensitive by design
+    assert.equal(normalizeVertical(""), "other");
+  });
+
+  it("defaults undefined / missing input to 'other'", () => {
+    assert.equal(normalizeVertical(), "other");
+    assert.equal(normalizeVertical(undefined), "other");
+  });
+});
+
+describe("verticalNoun", () => {
+  it("maps each vertical to its human-readable noun", () => {
+    assert.equal(verticalNoun("dental"), "dental practice");
+    assert.equal(verticalNoun("hvac"), "HVAC company");
+    assert.equal(verticalNoun("chiropractic"), "chiropractic clinic");
+    assert.equal(verticalNoun("med-spa"), "med spa");
+    assert.equal(verticalNoun("law"), "law firm");
+    assert.equal(verticalNoun("other"), "local business");
+  });
+
+  it("returns a non-empty noun for every vertical in the canonical list", () => {
+    for (const v of VERTICALS) {
+      const noun = verticalNoun(v as Vertical);
+      assert.equal(typeof noun, "string");
+      assert.ok(noun.length > 0, `noun for ${v} is empty`);
+    }
+  });
+});
