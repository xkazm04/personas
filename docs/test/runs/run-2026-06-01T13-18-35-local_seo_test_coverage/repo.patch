+import { redactPII } from "./telemetry";
+
+describe("redactPII", () => {
+  it("redacts email addresses", () => {
+    assert.equal(
+      redactPII("contact jane.doe@example.com about it"),
+      "contact [redacted:email] about it",
+    );
+  });
+
+  it("redacts US-style phone numbers", () => {
+    assert.equal(redactPII("call 555-123-4567 today"), "call [redacted:phone] today");
+  });
+
+  it("redacts SSNs", () => {
+    assert.equal(redactPII("ssn 123-45-6789 here"), "ssn [redacted:ssn] here");
+  });
+
+  it("redacts credit-card-length digit runs without mislabelling them as a phone", () => {
+    const out = redactPII("card 4111 1111 1111 1111 end");
+    assert.match(out, /\[redacted:card\]/);
+    assert.doesNotMatch(out, /\d{13,}/);
+  });
+
+  it("redacts multiple PII spans in one string", () => {
+    const out = redactPII("reach me at a@b.co or 555-123-4567");
+    assert.equal(out, "reach me at [redacted:email] or [redacted:phone]");
+  });
+
+  it("leaves PII-free text untouched", () => {
+    const clean = "Thanks so much for the kind words about our clinic!";
+    assert.equal(redactPII(clean), clean);
+  });
+});
diff --git a/src/lib/telemetry.ts b/src/lib/telemetry.ts
new file mode 100644
index 0000000..77eda88
--- /dev/null
+++ b/src/lib/telemetry.ts
@@ -0,0 +1,70 @@
+/**
+ * Project-scoped wrapper around the vendored LightTrack client (./lighttrack).
+ *
+ * Two jobs:
+ *  1. `tracker(source)` — one source of truth for the project name, so call
+ *     sites read `tracker("audit")` instead of repeating the
+ *     `{ project: "local-seo-agency", source }` literal in four files.
+ *  2. `captureIO()` / `redactPII()` — the redact-and-gate policy for raw LLM
+ *     prompt/output capture. Prompts embed raw customer review text and
+ *     prospect-entered business data (names, emails, phones — PHI-adjacent for
+ *     medical/dental verticals), so shipping them verbatim to an external
+ *     telemetry endpoint is a privacy/compliance leak. Capture is therefore OFF
+ *     by default and, when explicitly enabled, scrubbed of the PII classes the
+ *     noPII guard detects and truncated.
+ */
+import { LightTrack } from "./lighttrack";
+
+/** Project id baked into every tracker so call sites pass only their source. */
+const PROJECT = "local-seo-agency";
+
+/**
+ * Factory for a project-scoped {@link LightTrack} client. Bakes in the project
+ * name (and any future shared config) so renaming the project or attaching
+ * shared metadata is a one-line change here instead of an edit per surface.
+ */
+export function tracker(source: string): LightTrack {
+  return new LightTrack({ project: PROJECT, source });
+}
+
+// ── PII redaction for telemetry capture ────────────────────────────────────
+
+/** Whether raw prompt/output content may be shipped (still redacted) to LightTrack. */
+const CAPTURE_IO = /^(1|true|yes|on)$/i.test(process.env.LIGHTTRACK_CAPTURE_IO ?? "");
+
+/** Cap on captured content length — telemetry never needs the whole prompt. */
+const MAX_CAPTURE_CHARS = 8000;
+
+// Mirrors lighttrack's noPII detector classes, made global for replacement and
+// anchored to end on a digit so a match never swallows the following separator
+// or word. Order matters: redact card-length digit runs before the broad phone
+// pattern, which would otherwise consume them.
+const REDACTORS: ReadonlyArray<readonly [string, RegExp]> = [
+  ["email", /[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}/g],
+  ["ssn", /\b\d{3}-\d{2}-\d{4}\b/g],
+  ["card", /\b\d(?:[ -]?\d){12,15}\b/g],
+  ["phone", /\+?\d(?:[\s().-]?\d){9,}/g],
+];
+
+/** Replace email / SSN / card / phone-like spans with `[redacted:<kind>]`. */
+export function redactPII(text: string): string {
+  let out = text;
+  for (const [kind, re] of REDACTORS) {
+    out = out.replace(re, `[redacted:${kind}]`);
+  }
+  return out;
+}
+
+/**
+ * Build the `{ input, output }` slice for an `lt.track(...)` call under the
+ * redact-and-gate policy. Returns `{}` unless `LIGHTTRACK_CAPTURE_IO` is set, so
+ * by default no raw prompt/output content leaves the trust boundary. When
+ * enabled, content is PII-redacted then truncated.
+ */
+export function captureIO(input: string, output: string): { input?: string; output?: string } {
+  if (!CAPTURE_IO) return {};
+  return {
+    input: redactPII(input).slice(0, MAX_CAPTURE_CHARS),
+    output: redactPII(output).slice(0, MAX_CAPTURE_CHARS),
+  };
+}
