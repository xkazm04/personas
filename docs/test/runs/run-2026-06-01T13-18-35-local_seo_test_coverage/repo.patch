   // Keep these external from the server bundler: firebase-admin has dynamic
   // requires that bundlers mishandle, and @electric-sql/pglite ships a WASM
   // module loaded at runtime by the local PGlite store.
   serverExternalPackages: ["firebase-admin", "@electric-sql/pglite"],
+  async headers() {
+    return [{ source: "/:path*", headers: securityHeaders }];
+  },
 };
 export default nextConfig;
