+++ b/src/features/placements/lib/conversion.ts
+import type { FunnelStage } from "../types";
+
+/**
+ * Conversion metrics for a single funnel stage.
+ *
+ * Percentages are always finite numbers clamped to [0, 100] — never NaN,
+ * Infinity, or negative — so they are safe to render directly in the UI.
+ */
+export interface StageConversion {
+  /** The originating stage label, e.g. "Sourced". */
+  stage: string;
+  /** Raw count at this stage. */
+  count: number;
+  /**
+   * Conversion from the immediately previous stage, in percent [0, 100].
+   * `null` for the first stage (no previous stage to convert from).
+   */
+  stepPct: number | null;
+  /** Conversion from the top of the funnel, in percent [0, 100]. */
+  overallPct: number;
+}
+
+/**
+ * Conversion analysis for an entire funnel.
+ */
+export interface FunnelConversion {
+  /** Per-stage conversion rows, in funnel order. */
+  stages: StageConversion[];
+  /**
+   * Overall top-of-funnel → bottom-of-funnel conversion (e.g. sourced → hired),
+   * in percent [0, 100]. `0` for an empty funnel.
+   */
+  overallPct: number;
+}
+
+/**
+ * Single division site for the whole module. Guarantees a finite result in
+ * [0, 100]:
+ *  - denominator <= 0  → 0   (covers division by zero and the empty funnel)
+ *  - non-finite result → 0   (defends against NaN/Infinity from bad inputs)
+ *  - result clamped to [0, 100] (defends against dirty data where a later
+ *    stage exceeds an earlier one, which would otherwise yield > 100%)
+ */
+function safePct(numerator: number, denominator: number): number {
+  if (denominator <= 0) return 0;
+  const pct = (numerator / denominator) * 100;
+  if (!Number.isFinite(pct)) return 0;
+  return Math.min(100, Math.max(0, pct));
+}
+
+/**
+ * Compute stage-to-stage and overall conversion percentages for a funnel.
+ *
+ * Pure and total: returns a valid result for any input, including an empty
+ * funnel, zero counts, and data where a later stage exceeds an earlier one.
+ */
+export function computeFunnelConversion(funnel: readonly FunnelStage[]): FunnelConversion {
+  if (funnel.length === 0) {
+    return { stages: [], overallPct: 0 };
+  }
+
+  const top = funnel[0].count;
+
+  const stages: StageConversion[] = funnel.map((stage, index) => {
+    const previous = index === 0 ? null : funnel[index - 1].count;
+    return {
+      stage: stage.stage,
+      count: stage.count,
+      stepPct: previous === null ? null : safePct(stage.count, previous),
+      overallPct: safePct(stage.count, top),
+    };
+  });
+
+  const bottom = funnel[funnel.length - 1].count;
+
+  return {
+    stages,
+    overallPct: safePct(bottom, top),
+  };
+}
+
