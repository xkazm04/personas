+import assert from "node:assert/strict";
+import { test } from "node:test";
+
+import { computeFunnelConversion } from "./conversion.ts";
+import type { FunnelStage } from "../types.ts";
+
+test("empty funnel → no stages, 0% overall", () => {
+  const result = computeFunnelConversion([]);
+  assert.deepEqual(result.stages, []);
+  assert.equal(result.overallPct, 0);
+});
+
+test("first stage has null stepPct and 100% overall", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 1000 },
+    { stage: "Hired", count: 100 },
+  ];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+  assert.equal(stages[0].stepPct, null);
+  assert.equal(stages[0].overallPct, 100);
+  assert.equal(stages[1].stepPct, 10);
+  assert.equal(stages[1].overallPct, 10);
+  assert.equal(overallPct, 10);
+});
+
+test("zero top-of-funnel → no NaN/Infinity, all 0%", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 0 },
+    { stage: "Hired", count: 0 },
+  ];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+  for (const s of stages) {
+    if (s.stepPct !== null) assert.ok(Number.isFinite(s.stepPct));
+    assert.ok(Number.isFinite(s.overallPct));
+  }
+  assert.equal(stages[1].stepPct, 0); // 0 / 0 → 0, not NaN
+  assert.equal(overallPct, 0);
+});
+
+test("mid-funnel zero denominator → downstream step is 0, not Infinity", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 100 },
+    { stage: "Replied", count: 0 },
+    { stage: "Hired", count: 5 },
+  ];
+  const { stages } = computeFunnelConversion(funnel);
+  assert.equal(stages[2].stepPct, 0); // 5 / 0 → 0, not Infinity
+  assert.ok(Number.isFinite(stages[2].overallPct));
+});
+
+test("later stage exceeding earlier one is clamped to 100%", () => {
+  const funnel: FunnelStage[] = [
+    { stage: "Sourced", count: 100 },
+    { stage: "Replied", count: 250 }, // dirty data: more than sourced
+  ];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+  assert.equal(stages[1].stepPct, 100);
+  assert.equal(stages[1].overallPct, 100);
+  assert.equal(overallPct, 100);
+});
+
+test("single-stage funnel → 100% overall, null step", () => {
+  const funnel: FunnelStage[] = [{ stage: "Sourced", count: 42 }];
+  const { stages, overallPct } = computeFunnelConversion(funnel);
+  assert.equal(stages.length, 1);
+  assert.equal(stages[0].stepPct, null);
+  assert.equal(stages[0].overallPct, 100);
+  assert.equal(overallPct, 100);
+});
+

