@@ -0,0 +1,33 @@
+/**
+ * String presentation helpers. Pure, dependency-free.
+ */
+
+/**
+ * Truncate `text` to at most `max` characters, appending `ellipsis` when the
+ * text is longer. The returned string (including the ellipsis) does not exceed
+ * `max` characters, as long as `max >= ellipsis.length`.
+ *
+ * - Text already within `max` is returned unchanged (no ellipsis).
+ * - A non-positive `max` yields just the `ellipsis`.
+ *
+ * @example truncate("Hello world", 8)        // "Hello w…"
+ * @example truncate("Hi", 8)                  // "Hi"
+ */
+export function truncate(text: string, max: number, ellipsis = "…"): string {
+  if (text.length <= max) return text;
+  const keep = Math.max(0, max - ellipsis.length);
+  return text.slice(0, keep) + ellipsis;
+}
+
+/**
+ * Title-case `text`: capitalize the first character of each whitespace-
+ * separated word and lowercase the rest. Original whitespace is preserved.
+ *
+ * @example titleCase("hELLO   wORLD") // "Hello   World"
+ */
+export function titleCase(text: string): string {
+  return text.replace(
+    /\S+/g,
+    (word) => word[0].toUpperCase() + word.slice(1).toLowerCase(),
+  );
+}

