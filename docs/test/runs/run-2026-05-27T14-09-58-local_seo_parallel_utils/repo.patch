+
+test("slugify trims surrounding whitespace", () => {
+  assert.equal(slugify("   Hello World   "), "hello-world");
+});
+
+test("slugify collapses runs of non-alphanumerics to a single hyphen", () => {
+  assert.equal(slugify("a   b---c___d"), "a-b-c-d");
+  assert.equal(slugify("Hello, World! & Friends"), "hello-world-friends");
+});
+
+test("slugify strips leading and trailing hyphens", () => {
+  assert.equal(slugify("---Hello---"), "hello");
+  assert.equal(slugify("!!!edge!!!"), "edge");
+});
+
+test("slugify preserves digits", () => {
+  assert.equal(slugify("Top 10 SEO Tips 2026"), "top-10-seo-tips-2026");
+});
+
+test("slugify on empty / all-separator input yields empty string", () => {
+  assert.equal(slugify(""), "");
+  assert.equal(slugify("   "), "");
+  assert.equal(slugify("---"), "");
