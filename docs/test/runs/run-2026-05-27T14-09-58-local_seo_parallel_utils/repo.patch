+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { clamp, roundTo } from "./num";
+
+// --- clamp ---
+
+test("clamp returns the value when within range", () => {
+  assert.equal(clamp(5, 0, 10), 5);
+});
+
+test("clamp pins to min and max bounds", () => {
+  assert.equal(clamp(-3, 0, 10), 0);
+  assert.equal(clamp(42, 0, 10), 10);
+});
+
+test("clamp treats bounds as inclusive", () => {
+  assert.equal(clamp(0, 0, 10), 0);
+  assert.equal(clamp(10, 0, 10), 10);
+});
+
+test("clamp handles Infinity by snapping to the bound", () => {
+  assert.equal(clamp(Infinity, 0, 10), 10);
+  assert.equal(clamp(-Infinity, 0, 10), 0);
+});
+
+test("clamp propagates NaN value as NaN", () => {
+  assert.ok(Number.isNaN(clamp(NaN, 0, 10)));
+});
+
+test("clamp throws when min > max", () => {
+  assert.throws(() => clamp(5, 10, 0), RangeError);
+});
+
+test("clamp throws when a bound is NaN", () => {
+  assert.throws(() => clamp(5, NaN, 10), RangeError);
+  assert.throws(() => clamp(5, 0, NaN), RangeError);
+});
+
+// --- roundTo ---
+
+test("roundTo rounds to the requested decimals", () => {
+  assert.equal(roundTo(3.14159, 2), 3.14);
+  assert.equal(roundTo(3.14159, 4), 3.1416);
+});
+
+test("roundTo defaults to 0 decimals (integer)", () => {
+  assert.equal(roundTo(2.5), 3);
+  assert.equal(roundTo(2.4), 2);
+});
+
+test("roundTo avoids binary FP artifacts (1.005 -> 1.01)", () => {
+  assert.equal(roundTo(1.005, 2), 1.01);
+  assert.equal(roundTo(2.345, 2), 2.35);
+});
+
+test("roundTo handles negatives", () => {
+  assert.equal(roundTo(-1.2345, 2), -1.23);
+});
+
+test("roundTo returns non-finite input unchanged", () => {
+  assert.ok(Number.isNaN(roundTo(NaN, 2)));
+  assert.equal(roundTo(Infinity, 2), Infinity);
+  assert.equal(roundTo(-Infinity, 2), -Infinity);
+});
+
+test("roundTo treats non-finite / negative decimals as 0", () => {
+  assert.equal(roundTo(2.7, NaN), 3);
+  assert.equal(roundTo(2.7, -1), 3);
+});
