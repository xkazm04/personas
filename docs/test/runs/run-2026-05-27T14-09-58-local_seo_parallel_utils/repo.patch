+/**
+ * URL-safe slug helpers. Pure, dependency-free.
+ */
+
+/**
+ * Convert arbitrary text into a URL-safe slug:
+ * - lowercases
+ * - trims surrounding whitespace
+ * - replaces every run of non-alphanumeric characters with a single hyphen
+ * - strips leading/trailing hyphens
+ *
+ * Only ASCII `a-z0-9` survive as-is; everything else (spaces, punctuation,
+ * accented/Unicode letters) collapses to a hyphen separator.
+ *
+ * @example slugify("  Hello, World!  ") // "hello-world"
+ * @example slugify("Café déjà vu")       // "caf-d-j-vu"
+ */
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .trim()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "");
+}
