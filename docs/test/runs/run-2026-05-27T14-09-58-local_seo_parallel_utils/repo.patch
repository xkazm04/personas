@@ -0,0 +1,38 @@
+/**
+ * Numeric helpers. Pure, dependency-free, finite-safe.
+ */
+
+/**
+ * Constrain `value` to the inclusive range [`min`, `max`].
+ *
+ * - `±Infinity` clamps to the relevant bound (`clamp(Infinity, 0, 10) === 10`).
+ * - `NaN` input propagates as `NaN` (it has no meaningful position in a range).
+ *
+ * @throws RangeError if `min > max`, or if a bound is `NaN`.
+ */
+export function clamp(value: number, min: number, max: number): number {
+  if (Number.isNaN(min) || Number.isNaN(max)) {
+    throw new RangeError("clamp: min/max must not be NaN");
+  }
+  if (min > max) {
+    throw new RangeError(`clamp: min (${min}) must be <= max (${max})`);
+  }
+  if (Number.isNaN(value)) return NaN;
+  return Math.min(Math.max(value, min), max);
+}
+
+/**
+ * Round `value` to `decimals` fractional digits (default 0).
+ *
+ * Uses exponential-notation re-parsing to avoid binary floating-point
+ * artifacts (e.g. `roundTo(1.005, 2) === 1.01`, not `1`).
+ *
+ * - Non-finite `value` (`NaN`, `±Infinity`) is returned unchanged.
+ * - Non-finite or negative `decimals` is treated as `0`.
+ */
+export function roundTo(value: number, decimals = 0): number {
+  if (!Number.isFinite(value)) return value;
+  const d = Number.isFinite(decimals) ? Math.max(0, Math.trunc(decimals)) : 0;
+  const shifted = Math.round(Number(`${value}e${d}`));
+  return Number(`${shifted}e-${d}`);
+}
