+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { truncate, titleCase } from "./str";
+
+// --- truncate ---
+
+test("truncate leaves short-enough text unchanged", () => {
+  assert.equal(truncate("Hi", 8), "Hi");
+  assert.equal(truncate("exactly8", 8), "exactly8");
+});
+
+test("truncate appends the default ellipsis and respects max length", () => {
+  const out = truncate("Hello world", 8);
+  assert.equal(out, "Hello w…");
+  assert.equal(out.length, 8);
+});
+
+test("truncate accepts a custom ellipsis", () => {
+  assert.equal(truncate("Hello world", 8, "..."), "Hello...");
+});
+
+test("truncate with non-positive max yields just the ellipsis", () => {
+  assert.equal(truncate("Hello", 0), "…");
+});
+
+test("truncate counts the ellipsis against the budget", () => {
+  // max 5, ellipsis '…' (len 1) -> keep 4 chars + ellipsis
+  assert.equal(truncate("abcdefgh", 5), "abcd…");
+});
+
+// --- titleCase ---
+
+test("titleCase capitalizes the first letter of each word", () => {
+  assert.equal(titleCase("hello world"), "Hello World");
+});
+
+test("titleCase lowercases the remainder of each word", () => {
+  assert.equal(titleCase("hELLO wORLD"), "Hello World");
+  assert.equal(titleCase("MCDONALDS"), "Mcdonalds");
+});
+
+test("titleCase preserves original whitespace runs", () => {
+  assert.equal(titleCase("hello   world"), "Hello   World");
+});
+
+test("titleCase handles empty and whitespace-only input", () => {
+  assert.equal(titleCase(""), "");
+  assert.equal(titleCase("   "), "   ");
+});
+
+test("titleCase capitalizes single-character words", () => {
+  assert.equal(titleCase("a b c"), "A B C");
+});
