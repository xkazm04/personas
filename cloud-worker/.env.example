# Copy to .env and fill in, OR just export these before `npm start`.
# (server.mjs reads process.env directly — no dotenv dependency. On Windows
#  PowerShell: $env:DASHSCOPE_API_KEY="sk-...". Bash: export DASHSCOPE_API_KEY=sk-...)

# Port the worker listens on. The desktop allows http:// only for localhost.
PORT=8080

# --- Qwen Cloud (qwencloud.com) ---
# Leave DASHSCOPE_API_KEY empty to run in MOCK mode (canned joke, no network).
# Get a general (sk-...) key at https://home.qwencloud.com/api-keys and set it
# here to run on real Qwen. (The Coding Plan sk-sp-... keys DON'T work with a
# custom backend like this — they're only for CLIs such as Claude Code/qwen-code.)
# Either name works: DASHSCOPE_API_KEY or QWEN_API_KEY.
DASHSCOPE_API_KEY=

# OpenAI-compatible base URL. Default is Singapore/international.
#   US:      https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   Beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model. qwen3-coder-plus / qwen3-max have verified pricing in server.mjs (so the
# cost stamp is accurate). Current Qwen Cloud examples use qwen3.7-plus or
# qwen3.6-plus (1M ctx) — usable, but confirm their per-token price first.
QWEN_MODEL=qwen3-coder-plus

# Force mock mode even when a key is set (useful to test transport only).
# MOCK=1
