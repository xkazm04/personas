# Dependencies
node_modules/

# Build output
dist/
.baseline/

# Rust build artifacts (any target/ dir, including nested)
**/target/
src-tauri/src-tauri/

# Local SQLite databases (per-machine app state — never committed)
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Environment
.env
.env.local

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Logs
*.log

# Python bytecode
**/__pycache__/
*.pyc

# TypeScript build cache
tsconfig.tsbuildinfo

# Database
personas.db

# Drive plugin dev-mode managed root (release builds use app_data_dir)
.dev-drive/

# Machine-specific MCP config
.mcp.json

# Playwright test artifacts
src-tauri/.playwright-mcp/

# Demo recordings (generated by /record-demo skill)
recordings/

# Claude Code (allow commands, skills, context docs, and CLAUDE.md to be tracked)
.claude/*
!.claude/CLAUDE.md
!.claude/active-runs.md
!.claude/skills/
!.claude/codebase-catalogs.md
!.claude/codebase-context.md
!.claude/codebase-context-overrides.md
!.claude/codebase-stack.md

# Security audit results (generated by scripts/security-audit.sh)
security-results/

# Bundle analysis report (generated by npm run analyze)
dist/bundle-report.html

# Integration test reports (generated)
src/test/integration/reports/

# Generated reports
adoption-reports/

# Debug / intermediate artifacts
scripts/templates/_debug/

# Temporary scratch files
tmp/

# /research skill Phase 2a YouTube cache (per-run scratch — see
# .claude/skills/research/skill.md Phase 2a; runs are expected to clean up
# after parsing, but this gitignore keeps stragglers out of git status)
.research-cache/

# Planning docs (GSD)
.planning/

# Test results (generated, not needed in repo)
docs/tests/results/

# Per-run JSON reports written by tools/test-mcp/e2e_*.py drivers
# (often capture env vars in output_preview — secret-scanning hazard)
logs/
tools/test-mcp/reports/
