{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "radio",
  "description": "Permissions for the hidden radio player WebviewWindow. Listens for radio:command events and invokes radio_* commands.",
  "windows": ["radio"],
  "platforms": ["linux", "macOS", "windows"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:webview:allow-internal-toggle-devtools"
  ]
}
