{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "mobile-specific permissions",
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:default",
    "notification:default",
    "notification:allow-is-permission-granted",
