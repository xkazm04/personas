{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.tsx",
    "src/test/setup.ts",
    "src/**/*.test.{ts,tsx}",
    "src/**/__tests__/**/*.{ts,tsx}",
    "tests/playwright/**/*.{ts,tsx}",
    "scripts/**/*.{mjs,js,ts}",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts",
    "playwright.config.ts",
    "eslint.config.{js,mjs,ts}"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/lib/bindings/**",
    "src/lib/commandNames.generated.ts",
    "src/lib/commandNames.overrides.ts",
    "src/lib/n8nLimits.generated.ts",
    "src/i18n/generated/**",
    "src/i18n/section-locales/**",
    "src/lib/harness/**"
  ],
  "ignoreBinaries": ["tauri", "cargo"],
  "ignoreDependencies": [],
  "vite": {
    "config": ["vite.config.ts"]
  },
  "vitest": {
    "config": ["vitest.config.ts", "vitest.e2e.config.ts"]
  }
}
